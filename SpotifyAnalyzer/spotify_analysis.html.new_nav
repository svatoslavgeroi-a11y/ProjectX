                <div class="achievement-badge" style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--panel-border); border-radius: 16px; padding: 20px; display: flex; gap: 16px; align-items: flex-start;">
                    <div style="font-size: 24px; background: rgba(255, 107, 107, 0.1); color: #FF6B6B; width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"><i class="fas fa-crown"></i></div>
                    <div>
                        <div style="font-weight: 700; font-size: 14px; color: var(--text-main); margin-bottom: 4px;">Абсолютный Доминатор</div>
