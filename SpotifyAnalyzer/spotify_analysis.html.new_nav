        // --- DYNAMIC WEEKLY ACHIEVEMENTS CALCULATION ---
        function calculateWeeklyAchievements() {
            if (!weeklyTop) return;

            const weeks = Object.keys(weeklyTop);
            const artistWeeklyStats = {};

            weeks.forEach(week => {
                const data = weeklyTop[week];
                const artists = data.artists || [];
                artists.forEach((art, idx) => {
                    const cleanName = art.replace(/\s+-\s+\d+$/, '').trim();
                    if (!cleanName || cleanName === '—') return;

                    const canonicalName = Object.keys(artistsHistory).find(k => k.toLowerCase() === cleanName.toLowerCase()) || cleanName;

                    if (!artistWeeklyStats[canonicalName]) {
                        artistWeeklyStats[canonicalName] = {
                            appearances: 0,
                            weeksList: [],
                            ranks: []
                        };
                    }

                    artistWeeklyStats[canonicalName].appearances += 1;
                    artistWeeklyStats[canonicalName].weeksList.push(week);
                    artistWeeklyStats[canonicalName].ranks.push(idx + 1);
                });
            });

            for (const [artist, stats] of Object.entries(artistWeeklyStats)) {
                // 1. Владыка Недель (10+ weeks)
                if (stats.appearances >= 10) {
                    if (!achievements[artist]) {
                        achievements[artist] = [];
                    }
                    if (!achievements[artist].includes('Владыка Недель')) {
                        achievements[artist].push('Владыка Недель');
                    }

                    if (!achievementsDetailed[artist]) {
                        achievementsDetailed[artist] = [];
                    }
                    const alreadyHas = achievementsDetailed[artist].some(ach => ach.title === 'Владыка Недель');
                    if (!alreadyHas) {
                        achievementsDetailed[artist].push({
                            artist: artist,
                            title: 'Владыка Недель',
                            icon: 'fas fa-fort-awesome',
                            class: 'lord-of-weeks',
                            description: 'Артист показал непревзойденную стабильность на недельной дистанции, удерживаясь в недельном Топ-5 в течение 10 и более недель!',
                            details: `Удерживался в Топ-5 в течение ${stats.appearances} недель.`
                        });
                    }
                }

                // 2. Сверхзвуковой Взлет (first appearance is rank 1)
                if (stats.appearances > 0 && stats.ranks[0] === 1) {
                    if (!achievements[artist]) {
                        achievements[artist] = [];
                    }
                    if (!achievements[artist].includes('Сверхзвуковой Взлет')) {
                        achievements[artist].push('Сверхзвуковой Взлет');
                    }

                    if (!achievementsDetailed[artist]) {
                        achievementsDetailed[artist] = [];
                    }
                    const alreadyHas = achievementsDetailed[artist].some(ach => ach.title === 'Сверхзвуковой Взлет');
                    if (!alreadyHas) {
                        const firstWeek = stats.weeksList[0];
                        achievementsDetailed[artist].push({
                            artist: artist,
                            title: 'Сверхзвуковой Взлет',
                            icon: 'fas fa-rocket',
                            class: 'rocket-rise',
                            description: 'Мгновенный телепорт на вершину: артист ворвался в недельные чарты и сразу занял 1-е место!',
                            details: `Взлетел на 1-е место на неделе: ${firstWeek.split(' - ')[0]}`
                        });
                    }
                }
            }
        }
        calculateWeeklyAchievements();

        // --- INITIALIZE HALL OF FAME PODIUMS ---
        function initHallOfFame() {
            const fameTotalTracks = document.getElementById('fame-total-tracks');
            if (fameTotalTracks && tracks) {
                fameTotalTracks.textContent = tracks.length.toLocaleString();
            }

            if (!artistsHistory || !topTracksHistory) return;

            // Calculate Top 3 Artists of all time by avg_rank (lower avg_rank is better)
            const topArtists = Object.keys(artistsHistory)
                .filter(art => artistsHistory[art].avg_rank !== null && artistsHistory[art].avg_rank > 0 && art !== '—')
                .sort((a, b) => artistsHistory[a].avg_rank - artistsHistory[b].avg_rank)
                .slice(0, 3);

            // Calculate Top 3 Tracks of all time
            const topTracks = [...topTracksHistory]
                .sort((a, b) => {
                    if (b.appearances_count !== a.appearances_count) {
                        return b.appearances_count - a.appearances_count;
                    }
                    return a.avg_rank - b.avg_rank;
                })
                .slice(0, 3);

            // Populate Artists Podium
            if (topArtists[0]) {
                document.getElementById('podium-art-1-name').textContent = topArtists[0];
                document.getElementById('podium-art-1-name').title = topArtists[0];
                document.getElementById('podium-art-1-score').textContent = `Ср. ранг: ${artistsHistory[topArtists[0]].avg_rank.toFixed(1)}`;
            }
            if (topArtists[1]) {
                document.getElementById('podium-art-2-name').textContent = topArtists[1];
                document.getElementById('podium-art-2-name').title = topArtists[1];
                document.getElementById('podium-art-2-score').textContent = `Ср. ранг: ${artistsHistory[topArtists[1]].avg_rank.toFixed(1)}`;
            }
            if (topArtists[2]) {
                document.getElementById('podium-art-3-name').textContent = topArtists[2];
                document.getElementById('podium-art-3-name').title = topArtists[2];
                document.getElementById('podium-art-3-score').textContent = `Ср. ранг: ${artistsHistory[topArtists[2]].avg_rank.toFixed(1)}`;
            }

            // Populate Tracks Podium
            if (topTracks[0]) {
                document.getElementById('podium-track-1-name').textContent = topTracks[0].name;
                document.getElementById('podium-track-1-name').title = `${topTracks[0].name} — ${topTracks[0].artist}`;
                document.getElementById('podium-track-1-score').textContent = `${topTracks[0].appearances_count} мес. (Ср: ${topTracks[0].avg_rank.toFixed(1)})`;
            }
            if (topTracks[1]) {
                document.getElementById('podium-track-2-name').textContent = topTracks[1].name;
                document.getElementById('podium-track-2-name').title = `${topTracks[1].name} — ${topTracks[1].artist}`;
                document.getElementById('podium-track-2-score').textContent = `${topTracks[1].appearances_count} мес. (Ср: ${topTracks[1].avg_rank.toFixed(1)})`;
            }
            if (topTracks[2]) {
                document.getElementById('podium-track-3-name').textContent = topTracks[2].name;
                document.getElementById('podium-track-3-name').title = `${topTracks[2].name} — ${topTracks[2].artist}`;
                document.getElementById('podium-track-3-score').textContent = `${topTracks[2].appearances_count} мес. (Ср: ${topTracks[2].avg_rank.toFixed(1)})`;
            }
        }
        
        // Wait for page resources to load then run podium populator
        setTimeout(initHallOfFame, 100);

        // --- FAVORITES SYSTEM LOGIC ---
        let favoriteIds = [];
        try {
            favoriteIds = JSON.parse(localStorage.getItem('spotify_favorite_tracks') || '[]').map(String);
        } catch(e) {
            favoriteIds = [];
        }

        function isFavorite(trackId) {
            if (trackId === undefined || trackId === null) return false;
            return favoriteIds.includes(String(trackId));
        }

        function updateFavoritesBadges() {
            const count = favoriteIds.length;
            const badges = document.querySelectorAll('.favorites-badge');
            badges.forEach(badge => {
                badge.textContent = count;
                badge.style.display = count > 0 ? 'inline-block' : 'none';
            });
        }

        function toggleFavorite(event, trackId) {
            if (event) {
                event.stopPropagation();
                event.preventDefault();
            }

            const strId = String(trackId);
            const index = favoriteIds.indexOf(strId);
            if (index > -1) {
                favoriteIds.splice(index, 1);
            } else {
                favoriteIds.push(strId);
            }

            localStorage.setItem('spotify_favorite_tracks', JSON.stringify(favoriteIds));

            // Update all heart icons for this track across the page
            const heartBtns = document.querySelectorAll(`button[onclick*="toggleFavorite"][onclick*="${trackId}"]`);
            heartBtns.forEach(btn => {
                const isActive = isFavorite(trackId);
                if (isActive) {
                    btn.classList.add('active');
                    btn.title = 'Удалить из избранного';
                    btn.innerHTML = '<i class="fas fa-heart"></i>';
                } else {
                    btn.classList.remove('active');
                    btn.title = 'Добавить в избранное';
                    btn.innerHTML = '<i class="far fa-heart"></i>';
                }
            });

            // Update badges
            updateFavoritesBadges();

            // If we are currently on the Favorites tab, refresh the grid
            const favPane = document.getElementById('pane-favorites');
            if (favPane && favPane.classList.contains('active')) {
                renderFavorites();
            }
        }

        // Initialize badges on load
        setTimeout(updateFavoritesBadges, 100);

        function getFavoritedTracks() {
            return tracks.filter(t => isFavorite(t.id));
        }

        function renderFavorites() {
            const grid = document.getElementById('favoritesGrid');
            const label = document.getElementById('favorites-count-label');
            if (!grid) return;

            const favTracks = getFavoritedTracks();
            const query = (document.getElementById('favoritesSearch')?.value || '').toLowerCase().trim();
            
            const filteredFavs = favTracks.filter(t => {
                const trackName = (t.name || '').toLowerCase();
                const trackArtist = (t.artist || '').toLowerCase();
                const trackAlbum = (t.album || '').toLowerCase();
                return trackName.includes(query) || trackArtist.includes(query) || trackAlbum.includes(query);
            });

            if (favTracks.length === 0) {
                label.innerHTML = `У вас пока нет избранных треков. Нажмите на сердечко <i class="far fa-heart" style="color: #FF6B6B;"></i> на карточке любого трека на вкладке <strong>«Главный архив»</strong>!`;
                grid.innerHTML = '';
                return;
            }

            if (filteredFavs.length === 0) {
                label.textContent = `Найдено 0 из ${favTracks.length} избранных треков (нет совпадений по поиску).`;
                grid.innerHTML = `
                    <div style="grid-column: 1/-1; text-align: center; padding: 40px 0; color: var(--text-muted);">
                        <i class="fas fa-search" style="font-size: 36px; margin-bottom: 12px; opacity: 0.3;"></i>
                        <br>Нет избранных треков, соответствующих поиску.
                    </div>
                `;
                return;
            }

            label.textContent = `Ваша коллекция: ${filteredFavs.length} ${getNounDeclension(filteredFavs.length, 'трек', 'трека', 'треков')}`;

            // Build grid HTML
            let html = '';
            filteredFavs.forEach(track => {
                // Determine if key is Minor
                const isMinor = (track.key || '').includes("Минор");
                const keyBadgeClass = isMinor ? 'badge-key minor' : 'badge-key';
                const keyIcon = isMinor ? '<i class="fas fa-violin"></i>' : '<i class="fas fa-sun"></i>';
                const camelotDisplay = track.camelot_key && track.camelot_key !== 'N/A' ? ` [${track.camelot_key}]` : '';

                const danceOffset = 100 - ((track.danceability || 0) * 100);
                const energyVal = (track.energy === 'N/A' || track.energy === null || track.energy === undefined) ? 0.0 : track.energy;
                const energyOffset = 100 - (energyVal * 100);
                const valenceOffset = 100 - ((track.valence || 0) * 100);

                const isPlayingThis = (activeCardId === track.id);
                const playIconClass = isPlayingThis ? 'fa-pause' : 'fa-play';
                const cardPlayingClass = isPlayingThis ? 'playing-audio' : '';

                const previewBtnHtml = track.preview_url
                    ? `<button class="preview-btn" onclick="toggleAudio('${track.id}', '${track.preview_url.replace(/'/g, "\\'")}', '${(track.name || '').replace(/'/g, "\\'")}', '${(track.artist || '').replace(/'/g, "\\'")}', '${track.album_art}')"><i class="fas ${playIconClass}" id="btn-${track.id}"></i></button>`
                    : '';

                const vibeLabels = {
                    'Party': '🔥 Танцевальный',
                    'Energetic': '⚡ Драйв',
                    'Chill': '🌌 Чилл',
                    'Melancholic': '🎭 Меланхолия',
                    'Happy': '☀️ Радость',
                    'Focus': '🚀 Фокус',
                    'Balanced': '⚖️ Баланс'
                };
                const vibeLabel = vibeLabels[track.vibe] || track.vibe;

                let albumArtHtml = '';
                if (track.album_art && track.album_art !== 'N/A' && !track.album_art.includes('placeholder')) {
                    albumArtHtml = `<img src="${track.album_art}" alt="${track.album}" class="album-art" loading="lazy">`;
                } else {
                    let hash1 = 0;
                    const str1 = track.artist || "";
                    for (let i = 0; i < str1.length; i++) {
                        hash1 = str1.charCodeAt(i) + ((hash1 << 5) - hash1);
                    }
                    let hash2 = 0;
                    const str2 = track.name || "";
                    for (let i = 0; i < str2.length; i++) {
                        hash2 = str2.charCodeAt(i) + ((hash2 << 5) - hash2);
                    }
                    const h1 = Math.abs(hash1) % 360;
                    const h2 = Math.abs(hash2) % 360;
                    const grad = `linear-gradient(135deg, hsl(${h1}, 75%, 45%) 0%, hsl(${h2}, 60%, 20%) 100%)`;
                    const initial = track.artist ? track.artist.charAt(0).toUpperCase() : '🎵';
                    albumArtHtml = `<div class="album-art-placeholder" style="background: ${grad}">${initial}</div>`;
                }

                const genresHtml = track.genres ? `<div class="track-genres" title="${track.genres}">${track.genres}</div>` : '';
                const esc = (str) => (str || '').replace(/"/g, '&quot;');
                const playlistsList = track.playlists || [];
                let playlistsHtml = playlistsList.length > 0 
                    ? playlistsList.map(pl => `<span class="playlist-tag">${pl}</span>`).join(' ')
                    : '<span class="playlist-tag empty">Нет</span>';

                let addedHtml = '';
                if (track.added_at && track.added_at !== 'Неизвестно' && track.added_at !== 'NaT' && track.added_at !== 'NaN' && track.added_at !== 'null') {
                    addedHtml = `<span class="track-added-at"><i class="far fa-calendar-alt"></i> Добавлен: ${track.added_at}</span>`;
                }

                let avgRankHtml = '';
                if (track.avg_rank && track.avg_rank !== 'N/A' && track.avg_rank !== 'NaN' && track.avg_rank !== 'null') {
                    avgRankHtml = `<span class="track-avg-rank"><i class="fas fa-trophy"></i> Ср. Место: ${track.avg_rank}</span>`;
                }

                let appearancesHtml = '';
                const appCount = (track.history_ranks || []).length;
                if (appCount > 0) {
                    appearancesHtml = `<span class="track-appearances" title="Количество попаданий в топ-50 месяца"><i class="fas fa-calendar-check"></i> Топ месяцев: ${appCount}</span>`;
                }

                let trackAchievementsHtml = '';
                if (appCount >= 6) {
                    trackAchievementsHtml += `<span class="badge-achievement absolute-dominator" style="font-size: 11px; padding: 4px 10px; border-radius: 12px; height: 28px; line-height: 20px;" title="Абсолютный Бестселлер: трек удерживался в чартах более 6 месяцев!"><i class="fas fa-fire"></i> Бестселлер</span>`;
                }
                if (track.danceability >= 0.85 && energyVal >= 0.85) {
                    trackAchievementsHtml += `<span class="badge-achievement one-hit" style="font-size: 11px; padding: 4px 10px; border-radius: 12px; height: 28px; line-height: 20px;" title="Танцевальный Ураган: невероятный заряд энергии и танцевального вайба!"><i class="fas fa-bolt"></i> Ураган</span>`;
                }
                if (track.vibe === 'Chill' && track.valence <= 0.3) {
                    trackAchievementsHtml += `<span class="badge-achievement stable-vet" style="font-size: 11px; padding: 4px 10px; border-radius: 12px; height: 28px; line-height: 20px;" title="Абсолютный Дзен: глубочайший меланхоличный чилл-вайб для полного погружения."><i class="fas fa-cloud-moon"></i> Дзен</span>`;
                }

                html += `
                    <div class="track-card ${cardPlayingClass}" id="card-${track.id}" onclick="openDetailsModal(event, '${track.id}')">
                        <button class="favorite-btn active" onclick="toggleFavorite(event, '${track.id}')" title="Удалить из избранного">
                            <i class="fas fa-heart"></i>
                        </button>
                        <button class="copy-gemini-btn" 
                                data-artist="${esc(track.artist)}" 
                                data-name="${esc(track.name)}" 
                                data-album="${esc(track.album)}" 
                                data-bpm="${track.bpm}" 
                                data-key="${track.key}" 
                                data-energy="${track.energy}" 
                                data-genres="${esc(track.genres || '')}"
                                data-playlists="${esc(JSON.stringify(playlistsList))}"
                                data-added="${esc(track.added_at)}"
                                data-avg-rank="${track.avg_rank}"
                                onclick="copyTrackToGemini(this)">
                            <i class="far fa-copy"></i> <span class="btn-text">Gemini</span>
                        </button>
                        <div class="card-top">
                            <div class="album-art-container">
                                ${albumArtHtml}
                                ${previewBtnHtml}
                            </div>
                            <div class="track-meta">
                                <a href="${track.spotify_url}" target="_blank" class="track-title-link" title="Открыть в Spotify">
                                    <span class="track-title">${track.name}</span>
                                </a>
                                <span class="track-artist" title="${track.artist}">${track.artist}</span>
                                <span class="track-album" title="${track.album}">${track.album}</span>
                                <span class="track-playlists"><i class="fas fa-list-ul"></i> В плейлистах: ${playlistsHtml}</span>
                                ${addedHtml}
                                ${avgRankHtml}
                                ${appearancesHtml}
                            </div>
                        </div>

                        <div class="card-badges">
                            <span class="${keyBadgeClass}">${keyIcon} ${track.key}${camelotDisplay}</span>
                            <span class="badge badge-vibe"><i class="fas fa-yin-yang"></i> ${vibeLabel}</span>
                            ${trackAchievementsHtml}
                        </div>
                        ${genresHtml}

                        <div class="card-details">
                            <div class="detail-item">
                                <span class="detail-label">Ритм</span>
                                <div class="dial-container">
                                    <svg class="dial-svg">
                                        <circle class="dial-bg" cx="21" cy="21" r="16"></circle>
                                        <circle class="dial-progress dial-dance" cx="21" cy="21" r="16" stroke-dasharray="100" stroke-dashoffset="${danceOffset}"></circle>
                                    </svg>
                                    <span class="dial-text">${Math.round(track.danceability * 100)}%</span>
                                </div>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Энергия</span>
                                <div class="dial-container">
                                    <svg class="dial-svg">
                                        <circle class="dial-bg" cx="21" cy="21" r="16"></circle>
                                        <circle class="dial-progress dial-energy" cx="21" cy="21" r="16" stroke-dasharray="100" stroke-dashoffset="${energyOffset}"></circle>
                                    </svg>
                                    <span class="dial-text">${track.energy === 'N/A' ? 'N/A' : Math.round(track.energy * 100) + '%'}</span>
                                </div>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Настроение</span>
                                <div class="dial-container">
                                    <svg class="dial-svg">
                                        <circle class="dial-bg" cx="21" cy="21" r="16"></circle>
                                        <circle class="dial-progress dial-valence" cx="21" cy="21" r="16" stroke-dasharray="100" stroke-dashoffset="${valenceOffset}"></circle>
                                    </svg>
                                    <span class="dial-text">${Math.round(track.valence * 100)}%</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">
                            <a href="${track.spotify_url}" target="_blank" class="spotify-link">
                                <i class="fab fa-spotify"></i> Слушать в Spotify
                            </a>
                            <div class="popularity-indicator">
                                <i class="fas fa-fire"></i> ${track.popularity}
                            </div>
                            <div class="waveform" id="wave-${track.id}">
                                <div class="wave-bar"></div>
                                <div class="wave-bar"></div>
                                <div class="wave-bar"></div>
                                <div class="wave-bar"></div>
                            </div>
                        </div>
                    </div>
                `;
            });

            grid.innerHTML = html;
        }

        function filterFavorites() {
            renderFavorites();
        }

        function clearFavorites() {
            if (confirm("Вы уверены, что хотите полностью очистить список избранного?")) {
                favoriteIds = [];
                localStorage.removeItem('spotify_favorite_tracks');
                
                // Reset all heart icons on the page
                const heartBtns = document.querySelectorAll(`button[onclick*="toggleFavorite"]`);
                heartBtns.forEach(btn => {
                    btn.classList.remove('active');
                    btn.title = 'Добавить в избранное';
                    btn.innerHTML = '<i class="far fa-heart"></i>';
                });

                // Update badges
                updateFavoritesBadges();

                renderFavorites();
            }
        }

        function exportFavorites() {
            const favTracks = getFavoritedTracks();
            if (favTracks.length === 0) {
                alert("Список избранного пуст!");
                return;
            }

            let text = "МОЙ ИЗБРАННЫЙ СПИСОК SPOTIFY\n";
            text += "========================================\n\n";
            favTracks.forEach((t, i) => {
                text += `${i + 1}. ${t.artist} - ${t.name}\n`;
                text += `   Альбом: ${t.album || 'N/A'}\n`;
                text += `   Характеристики: BPM: ${t.bpm} | Тональность: ${t.key} | Энергия: ${Math.round(t.energy * 100)}% | Ритм: ${Math.round(t.danceability * 100)}%\n`;
                text += `   Ссылка: ${t.spotify_url}\n`;
                text += "----------------------------------------\n";
            });

            const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'spotify_favorites.txt';
            link.click();
        }

        function getNounDeclension(number, one, two, five) {
            let n = Math.abs(number);
            n %= 100;
            if (n >= 5 && n <= 20) {
                return five;
            }
            n %= 10;
            if (n === 1) {
                return one;
            }
            if (n >= 2 && n <= 4) {
                return two;
            }
            return five;
        }

        // --- NEON AUDIO VISUALIZER LOGIC ---
        let visualizerAnimationId = null;
        let visualizerEnergy = 0.6;
        let visualizerBpm = 120;
        let visualizerValence = 0.5;

        function startVisualizer(energy, bpm, valence) {
            visualizerEnergy = energy || 0.6;
            visualizerBpm = bpm || 120;
            visualizerValence = valence || 0.5;

            const canvas = document.getElementById('neonVisualizer');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;

            // Stop any ongoing animation
            if (visualizerAnimationId) {
                cancelAnimationFrame(visualizerAnimationId);
            }

            let phase = 0;

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                // Parameters based on track traits
                const speed = (visualizerBpm / 60) * 0.08; // scale by BPM
                const amp = Math.max(3, visualizerEnergy * 14); // scale by energy
                const waveCount = 3;

                phase += speed;

                for (let w = 0; w < waveCount; w++) {
                    ctx.beginPath();
                    
                    // Wave colors: Spotify green, neon cyan, and purple/pink
                    let color = 'rgba(29, 185, 84, 0.4)';
                    if (w === 1) color = 'rgba(0, 245, 255, 0.3)';
                    if (w === 2) color = 'rgba(189, 0, 255, 0.2)';

                    ctx.strokeStyle = color;
                    ctx.lineWidth = w === 0 ? 2 : 1.5;
                    ctx.shadowBlur = w === 0 ? 8 : 4;
                    ctx.shadowColor = w === 0 ? '#1DB954' : (w === 1 ? '#00F5FF' : '#BD00FF');

                    const freq = 0.04 + w * 0.015;
                    const shift = w * (Math.PI / 2) + phase;

                    for (let x = 0; x < canvas.width; x++) {
                        const y = (canvas.height / 2) + Math.sin(x * freq + shift) * amp * Math.sin(x * (Math.PI / canvas.width));
                        if (x === 0) {
                            ctx.moveTo(x, y);
                        } else {
                            ctx.lineTo(x, y);
                        }
                    }
                    ctx.stroke();
                }

                // Reset shadow properties
                ctx.shadowBlur = 0;

                visualizerAnimationId = requestAnimationFrame(animate);
            }

            animate();
        }

        function stopVisualizer() {
            if (visualizerAnimationId) {
                cancelAnimationFrame(visualizerAnimationId);
                visualizerAnimationId = null;
            }
            const canvas = document.getElementById('neonVisualizer');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                if (ctx) {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                }
            }
        }

        // --- DYNAMIC MUSICAL ORACLE LOGIC ---
        let oraclePlaying = false;
        
        function playOracleTrack(previewUrl, name, artist, artUrl) {
            if (!previewUrl || previewUrl === 'None' || previewUrl === 'N/A') {
                alert("У этого трека нет аудиопревью в базе данных.");
                return;
            }

            const playBtn = document.getElementById('oracle-play-btn');
            const toast = document.getElementById('audio-toast');
            const toastArt = document.getElementById('toast-art');
            const toastName = document.getElementById('toast-name');
            const toastArtist = document.getElementById('toast-artist');
            const player = document.getElementById('global-player');

            if (oraclePlaying) {
                if (player) player.pause();
                oraclePlaying = false;
                if (playBtn) {
                    playBtn.innerHTML = '<i class="fas fa-play"></i> Слушать превью';
                }
                if (toast) toast.classList.remove('show');
                stopVisualizer();
            } else {
                if (activeCardId) {
                    resetAudioState();
                    activeCardId = null;
                }
                if (player) {
                    player.src = previewUrl;
                    player.play().then(() => {
                        oraclePlaying = true;
                        if (playBtn) {
                            playBtn.innerHTML = '<i class="fas fa-pause"></i> Пауза';
                        }
                        if (toastArt) toastArt.src = artUrl || '';
                        if (toastName) toastName.innerText = name;
                        if (toastArtist) toastArtist.innerText = artist;
                        if (toast) toast.classList.add('show');

                        // Find track details to feed correct characteristics
                        const dbTrack = tracks.find(t => t.name === name && t.artist === artist);
                        const trackEnergy = dbTrack ? parseFloat(dbTrack.energy) : 0.7;
                        const trackBpm = dbTrack ? parseFloat(dbTrack.bpm) : 130;
                        const trackValence = dbTrack ? parseFloat(dbTrack.valence) : 0.6;
                        startVisualizer(trackEnergy, trackBpm, trackValence);
                    }).catch(err => {
                        console.error("Ошибка оракула:", err);
                        alert("Не удалось загрузить аудиопревью для этого трека.");
                    });
                }
            }
        }

        // Keep Oracle play state in sync with global player state
        setTimeout(() => {
            const player = document.getElementById('global-player');
            if (player) {
                player.addEventListener('pause', () => {
                    oraclePlaying = false;
                    const playBtn = document.getElementById('oracle-play-btn');
                    if (playBtn) {
                        playBtn.innerHTML = '<i class="fas fa-play"></i> Слушать превью';
                    }
                });
            }
        }, 200);

        // Chosic Mix Curator Engine
        let lastCuratedTracks = [];

        function updateCuratorBpm(val) {
            document.getElementById('bpm-pulse-value').textContent = val;
            const circle = document.getElementById('bpm-pulse-circle');
            if (circle) {
                const duration = 60 / parseFloat(val);
                circle.style.animation = `pulse ${duration}s infinite ease-in-out`;
            }
        }

        function curateChosicMix() {
            const targetBpm = parseFloat(document.getElementById('curator-bpm-slider').value) || 120;
            const targetVibe = document.getElementById('curator-vibe-select').value;

            if (!tracks || !Array.isArray(tracks) || tracks.length === 0) {
                alert("База данных треков пуста!");
                return;
            }

            // Filter candidates
            let candidates = tracks.filter(t => t && t.name && t.artist);

            // Filter by vibe if not 'All'
            if (targetVibe !== 'All') {
                candidates = candidates.filter(t => t.vibe === targetVibe);
            }

            // Calculate similarity score based on BPM
            const scored = candidates.map(t => {
                const tBpm = parseFloat(t.bpm);
                if (isNaN(tBpm) || tBpm <= 0) return { track: t, score: 0 };
                
                const diff = Math.abs(tBpm - targetBpm);
                const score = Math.max(0, 100 * (1 - (diff / 30)));
                return { track: t, score: score };
            });

            // Filter out 0 scores
            let valid = scored.filter(x => x.score > 0);

            // Sort by score descending and take some candidates, then randomize a bit to keep it a fresh experience!
            valid.sort((a, b) => b.score - a.score);
            
            const pool = valid.slice(0, 30).map(x => x.track);
            if (pool.length === 0) {
                alert(`В вашей медиатеке нет треков с темпом около ${targetBpm} BPM и выбранным вайбом.`);
                return;
            }

            // Shuffle pool and take 10
            const shuffled = pool.sort(() => 0.5 - Math.random());
            const selected = shuffled.slice(0, 10);

            lastCuratedTracks = selected; // Save globally for export

            // Render to vibesMixerResults
            const resultsEl = document.getElementById('vibesMixerResults');
            const countEl = document.getElementById('mixMatchCount');
            const exportTools = document.getElementById('mixerExportTools');

            resultsEl.innerHTML = '';
            
            selected.forEach(t => {
                let artHtml = '';
                if (t.album_art && t.album_art !== 'N/A' && !t.album_art.includes('placeholder')) {
                    artHtml = `<img src="${t.album_art}" alt="${t.name.replace(/"/g, '&quot;')}" style="width: 50px; height: 50px; border-radius: 8px; object-fit: cover; flex-shrink: 0;">`;
                } else {
                    let hash = 0;
                    const str = t.artist || "";
                    for (let i = 0; i < str.length; i++) {
                        hash = str.charCodeAt(i) + ((hash << 5) - hash);
                    }
                    const h = Math.abs(hash) % 360;
                    const grad = `linear-gradient(135deg, hsl(${h}, 70%, 45%) 0%, hsl(${(h+40)%360}, 50%, 20%) 100%)`;
                    const initial = t.artist ? t.artist.charAt(0).toUpperCase() : '🎵';
                    artHtml = `
                        <div style="width: 50px; height: 50px; border-radius: 8px; background: ${grad}; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 800; color: #fff; flex-shrink: 0;">
                            ${initial}
                        </div>
                    `;
                }

                const card = document.createElement('div');
                card.className = 'track-card';
                card.style.display = 'flex';
                card.style.gap = '15px';
                card.style.padding = '12px';
                card.style.alignItems = 'center';
                card.style.background = 'var(--panel-bg)';
                card.style.border = '1px solid var(--panel-border)';
                card.style.borderRadius = '12px';
                card.style.position = 'relative';
                card.style.cursor = 'pointer';
                card.style.minWidth = '0';
                card.onclick = (e) => {
                    if (e.target.closest('.favorite-btn') || e.target.closest('.copy-gemini-btn')) return;
                    openDetailsModal(null, t.id);
                };

                const isMinor = (t.key || '').includes("Минор");
                const keyBadge = t.key ? `<span class="${isMinor ? 'badge-key minor' : 'badge-key'}" style="font-size: 9px; padding: 2px 6px; margin: 0;">${t.key}</span>` : '';

                card.innerHTML = `
                    ${artHtml}
                    <div style="overflow: hidden; flex-grow: 1; text-align: left; min-width: 0;">
                        <div style="font-size: 13.5px; font-weight: 700; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${t.name.replace(/"/g, '&quot;')}">${t.name}</div>
                        <div style="font-size: 11.5px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px;">${t.artist}</div>
                        <div style="display: flex; gap: 8px; align-items: center; margin-top: 6px; flex-wrap: wrap;">
                            ${keyBadge}
                            <span style="font-size: 10px; color: var(--text-muted); font-style: italic;">${t.bpm && t.bpm !== 'N/A' ? t.bpm + ' BPM' : ''}</span>
                        </div>
                    </div>
                    <button class="favorite-btn ${isFavorite(t.id) ? 'active' : ''}" onclick="toggleFavorite(event, '${t.id}')" style="position: static; width: 28px; height: 28px; flex-shrink: 0; margin-left: 8px; font-size: 12px; display: flex; align-items: center; justify-content: center;">
                        <i class="${isFavorite(t.id) ? 'fas' : 'far'} fa-heart"></i>
                    </button>
                `;

                resultsEl.appendChild(card);
            });

            countEl.textContent = `Сгенерирован BPM-Микс: ${selected.length} треков`;
            if (exportTools) exportTools.style.display = 'flex';

            // Scroll results into view
            resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function exportMixList(format) {
            if (lastCuratedTracks.length === 0) return;

            let fileContent = '';
            let fileName = `BPM_Mix_${Math.round(document.getElementById('curator-bpm-slider').value)}BPM`;

            if (format === 'csv') {
                fileName += '.csv';
                fileContent = 'Title;Artist;Album;BPM;Key;Vibe;Popularity\n';
                lastCuratedTracks.forEach(t => {
                    fileContent += `"${t.name.replace(/"/g, '""')}";"${t.artist.replace(/"/g, '""')}";"${t.album.replace(/"/g, '""')}";"${t.bpm}";"${t.key}";"${t.vibe}";"${t.popularity}%"\n`;
                });
            } else {
                fileName += '.txt';
                fileContent = `=== BPM & Vibe Mix (${document.getElementById('curator-bpm-slider').value} BPM, ${document.getElementById('curator-vibe-select').options[document.getElementById('curator-vibe-select').selectedIndex].text}) ===\n\n`;
                lastCuratedTracks.forEach((t, i) => {
                    fileContent += `${i + 1}. ${t.artist} - ${t.name} (Album: ${t.album} | BPM: ${t.bpm} | Key: ${t.key})\n`;
                });
            }

            const blob = new Blob([fileContent], { type: 'text/plain;charset=utf-8;' });
            const link = document.createElement("a");
            if (link.download !== undefined) {
                const url = URL.createObjectURL(blob);
                link.setAttribute("href", url);
                link.setAttribute("download", fileName);
                link.style.visibility = 'hidden';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        }

        function getOracleFallbackMarkup() {
            return `
                <div style="width: 80px; height: 80px; border-radius: 12px; background: linear-gradient(135deg, #BF5FFF 0%, #00F5FF 100%); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.15); flex-shrink: 0;">
                    <i class="fas fa-record-vinyl" style="color: #fff; font-size: 36px; animation: spin-slow 8s linear infinite;"></i>
                </div>
            `;
        }

        function getOracleArtMarkup(imageUrl) {
            if (imageUrl && imageUrl !== 'None' && imageUrl !== 'N/A' && imageUrl.trim() !== '') {
                return `<img src="${imageUrl}" alt="Art" onerror="this.outerHTML=getOracleFallbackMarkup()" style="width: 80px; height: 80px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); border: 1px solid var(--panel-border); flex-shrink: 0;">`;
            }
            return getOracleFallbackMarkup();
        }

        function askMusicalOracle() {
            const ball = document.getElementById('oracle-ball');
            const resultBox = document.getElementById('oracle-result');
            const playBtn = document.getElementById('oracle-play-btn');
            
            if (!tracks || tracks.length === 0) return;

            // Spin & glow animation on the ball
            if (ball) {
                ball.style.transform = 'rotate(720deg) scale(1.12)';
                ball.style.boxShadow = '0 0 50px #BF5FFF, 0 0 100px #00F5FF';
            }

            if (resultBox) {
                resultBox.innerHTML = `
                    <div style="display: flex; align-items: center; justify-content: center; gap: 10px; padding: 20px; color: var(--text-muted);">
                        <i class="fas fa-spinner fa-spin" style="font-size: 24px; color: var(--spotify-green);"></i>
                        <span style="font-size: 14px; font-weight: 600;">Оракул вглядывается в музыкальные звезды...</span>
                    </div>
                `;
            }

            if (playBtn) {
                playBtn.style.display = 'none';
            }

            setTimeout(() => {
                // Restore ball state
                if (ball) {
                    ball.style.transform = 'rotate(0deg) scale(1)';
                    ball.style.boxShadow = '0 0 35px rgba(191, 95, 255, 0.45)';
                }

                // Pick random track that has features
                const validTracks = tracks.filter(t => 
                    t.energy !== undefined && t.energy !== 'N/A' &&
                    t.valence !== undefined && t.valence !== 'N/A'
                );

                const sourceList = validTracks.length > 0 ? validTracks : tracks;
                const track = sourceList[Math.floor(Math.random() * sourceList.length)];

                // Audio features parsing
                const energy = parseFloat(track.energy) || 0.5;
                const valence = parseFloat(track.valence) || 0.5;
                const dance = parseFloat(track.danceability) || 0.5;
                const bpm = parseInt(track.bpm) || 120;

                // 1. Energy prediction
                let energyText = "сбалансированный ритм ⚖️.";
                let energyDetails = "Энергия находится на комфортном уровне для продуктивной работы и концентрации.";
                if (energy > 0.75) {
                    energyText = "взрывной поток энергии ⚡!";
                    energyDetails = "Твоя внутренняя батарейка сегодня заряжена на максимум. Отличное время ломать стены и достигать амбициозных целей.";
                } else if (energy < 0.4) {
                    energyText = "уютный дзен и тепло ☕.";
                    energyDetails = "Идеальное время, чтобы замедлиться, расслабиться под глубокие тона и дать себе заслуженный отдых от суеты.";
                }

                // 2. Valence prediction
                let valenceText = "уверенную внутреннюю гармонию.";
                let valenceDetails = "Эмоциональный фон стабилен и глубок. Отличный день для размышлений и созидания.";
                if (valence > 0.7) {
                    valenceText = "яркую волну позитива и радости ☀️!";
                    valenceDetails = "Твоя улыбка сегодня будет заразительной, а вселенная обязательно подкинет пару приятных сюрпризов.";
                } else if (valence < 0.35) {
                    valenceText = "сладкую меланхолию и ностальгию 🌌.";
                    valenceDetails = "Каждая нота будет резонировать с твоими потаенными мыслями. Позволь себе немного романтичной светлой грусти.";
                }

                // 3. Tempo details
                let tempoText = "классическом городском темпе";
                if (bpm > 130) {
                    tempoText = "бешеном, адреналиновом темпе";
                } else if (bpm < 90) {
                    tempoText = "размеренном, медитативном темпе";
                }

                // Advices
                let advice = "нажми 'Слушать превью' ниже и позволь этой музыке сопровождать тебя!";
                if (energy > 0.7 && valence > 0.6) {
                    advice = "сделай музыку погромче, поймай сумасшедший кураж и иди покорять этот день!";
                } else if (energy > 0.7 && valence < 0.4) {
                    advice = "выплесни всю лишнюю энергию и эмоции под этот мощный напор звуков в наушниках!";
                } else if (energy < 0.45 && valence > 0.6) {
                    advice = "завари чашку любимого напитка, улыбнись новому дню и поделись теплом с близкими.";
                } else if (energy < 0.4 && valence < 0.4) {
                    advice = "закутайся в плед, выключи уведомления и побудь наедине со своей внутренней вселенной.";
                }

                const artMarkup = getOracleArtMarkup(track.image_url);

                // Display result
                if (resultBox) {
                    resultBox.innerHTML = `
                        <div onclick="openDetailsModal(event, '${track.id}')" style="display: flex; gap: 20px; align-items: flex-start; text-align: left; animation: fadeIn 0.5s ease-out; cursor: pointer; padding: 10px; border-radius: 12px; transition: all 0.2s;" onmouseover="this.style.background='var(--panel-bg)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)'" onmouseout="this.style.background='transparent'; this.style.boxShadow='none'">
                            ${artMarkup}
                            <div style="overflow: hidden; width: 100%;">
                                <div style="font-size: 11px; font-weight: 700; color: var(--spotify-green); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; display: flex; align-items: center; gap: 6px;">
                                    <span>Твой Музыкальный Вестник</span>
                                    <i class="fas fa-external-link-alt" style="font-size: 9px; opacity: 0.6;"></i>
                                </div>
                                <div style="font-size: 18px; font-weight: 800; color: var(--text-main); line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${track.name}">${track.name}</div>
                                <div style="font-size: 13px; color: var(--text-muted); margin-top: 2px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${track.artist}">${track.artist}</div>
                                
                                <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px;">
                                    <span style="font-size: 10px; font-weight: 700; background: rgba(255, 107, 107, 0.1); color: #FF6B6B; border: 1px solid rgba(255, 107, 107, 0.2); padding: 4px 8px; border-radius: 20px;">⚡ ${Math.round(energy * 100)}% Энергия</span>
                                    <span style="font-size: 10px; font-weight: 700; background: rgba(0, 245, 255, 0.1); color: var(--accent-cyan); border: 1px solid rgba(0, 245, 255, 0.2); padding: 4px 8px; border-radius: 20px;">🕺 ${Math.round(dance * 100)}% Ритм</span>
                                    <span style="font-size: 10px; font-weight: 700; background: rgba(255, 183, 3, 0.1); color: #ffb703; border: 1px solid rgba(255, 183, 3, 0.2); padding: 4px 8px; border-radius: 20px;">🏃‍♂️ ${bpm} BPM</span>
                                </div>
                            </div>
                        </div>
                        
                        <div style="margin-top: 15px; font-size: 13.5px; color: var(--text-main); line-height: 1.6; border-top: 1px solid var(--panel-border); padding-top: 15px; text-align: left; animation: fadeIn 0.6s ease-out;">
                            🔮 <b>Оракул предсказывает:</b> Твой сегодняшний день пройдет в <b>${tempoText}</b>. Нас ожидает <b>${energyText}</b> Музыкальные звезды сулят <b>${valenceText}</b>
                            <br><br>
                            💡 <b>События дня:</b> ${energyDetails} ${valenceDetails}
                            <br><br>
                            🎯 <b>Совет дня от Оракула:</b> ${advice}
                        </div>
                    `;
                }

                // Show player button if track preview is available
                if (playBtn) {
                    if (track.preview_url && track.preview_url !== 'None' && track.preview_url !== 'N/A') {
                        playBtn.style.display = 'flex';
                        playBtn.innerHTML = '<i class="fas fa-play"></i> Слушать превью';
                        playBtn.onclick = () => {
                            playOracleTrack(track.preview_url, track.name, track.artist, track.image_url);
                        };
                    } else {
                        playBtn.style.display = 'none';
                    }
                }

            }, 800);
        }

        // Tab Switching Logic
        // 🌌 Spatial Canvas Coordinates Map
        const paneCoordinates = {
            'archive': { x: 0, y: 0 },
            'favorites': { x: 0, y: -115 },
            'vibes-mixer': { x: -115, y: 0 },
            'weekly': { x: 115, y: 0 },
            'evolution': { x: 0, y: 115 }
        };

        let canvasX = 0;
        let canvasY = 0;
        let canvasScale = 1;

        function updateCanvasCamera() {
            const canvas = document.getElementById('infinite-canvas');
            if (canvas) {
                // Apply reverse translation so camera focuses on target coordinate
                canvas.style.transform = `translate3d(${-canvasX}%, ${-canvasY}%, 0) scale(${canvasScale})`;
            }
            // Update real-time hud layers
            updateMinimapViewport();
            updateZoomUI();
        }

        function updateZoomUI() {
            const display = document.getElementById('zoomPercentDisplay');
            if (display) {
                display.textContent = Math.round(canvasScale * 100) + '%';
            }
        }

        function updateMinimapViewport() {
            const viewer = document.getElementById('minimapCameraViewer');
            if (!viewer) return;

            // Map canvas coordinates to minimap layout
            // Conversion factor based on 32% node offset for 115 coordinate units
            const conversion = 32 / 115;
            const leftPercent = 50 + (canvasX * conversion);
            const topPercent = 50 + (canvasY * conversion);
            
            // Viewport size is inversely proportional to scale
            const sizePercent = (100 / canvasScale) * conversion;

            viewer.style.left = leftPercent + '%';
            viewer.style.top = topPercent + '%';
            viewer.style.width = sizePercent + '%';
            viewer.style.height = sizePercent + '%';
        }

        function zoomCanvas(delta) {
            canvasScale = Math.max(0.4, Math.min(1.2, canvasScale + delta));
            updateCanvasCamera();
        }

        function resetZoomAndCenter() {
            canvasScale = 1.0;
            // Snap to currently active pane if possible, or fallback to archive
            const activePane = document.querySelector('.tab-pane.active');
            let activeId = 'archive';
            if (activePane) {
                activeId = activePane.id.replace('pane-', '');
            }
            switchTab(activeId);
        }

        function switchTab(tabId) {
            const coords = paneCoordinates[tabId];
            if (!coords) return;

            // Scroll panel to top when focused
            const targetPane = document.getElementById(`pane-${tabId}`);
            if (targetPane) {
                targetPane.scrollTop = 0;
            }

            // Set camera target coordinates
            canvasX = coords.x;
            canvasY = coords.y;
            canvasScale = 1;

            updateCanvasCamera();

            // Set active class on target pane
            const panes = document.querySelectorAll('.tab-pane');
            panes.forEach(pane => pane.classList.remove('active'));

            if (targetPane) {
                targetPane.classList.add('active');
            }

            // Deactivate all tab buttons
            const buttons = document.querySelectorAll('.nav-tab-btn');
            buttons.forEach(btn => btn.classList.remove('active'));

            // Activate target button
            buttons.forEach(btn => {
                if (btn.getAttribute('onclick') && btn.getAttribute('onclick').includes(tabId)) {
                    btn.classList.add('active');
                }
            });

            // Update sidebar navigation active state
            const sideButtons = document.querySelectorAll('.side-nav-btn');
            sideButtons.forEach(btn => {
                btn.classList.remove('active');
                if (btn.getAttribute('onclick') && btn.getAttribute('onclick').includes(tabId)) {
                    btn.classList.add('active');
                }
            });

            // Update minimap nodes active status
            const nodes = document.querySelectorAll('.minimap-island-node');
            nodes.forEach(node => node.classList.remove('active'));
            const targetNode = document.getElementById(`mm-node-${tabId}`);
            if (targetNode) targetNode.classList.add('active');

            if (tabId === 'vibes-mixer') {
                autoMixVibe();
            } else if (tabId === 'favorites') {
                renderFavorites();
            }
        }

        // 🔮 Вайб-Коктейль & Генератор Настроения Logic
        function autoMixVibe() {
            const danceVal = parseFloat(document.getElementById('sliderMixDance').value) / 100;
            const energyVal = parseFloat(document.getElementById('sliderMixEnergy').value) / 100;
            const valenceVal = parseFloat(document.getElementById('sliderMixValence').value) / 100;
            const acousticVal = parseFloat(document.getElementById('sliderMixAcoustic').value) / 100;

            const resultsDiv = document.getElementById('vibesMixerResults');
            if (!resultsDiv) return;
            resultsDiv.innerHTML = '';

            const scoredTracks = [];
            tracks.forEach(t => {
                const energy = t.energy === 'N/A' ? 0.5 : parseFloat(t.energy);
                const dance = parseFloat(t.danceability);
                const valence = parseFloat(t.valence);
                const acoustic = parseFloat(t.acousticness);

                const d = Math.sqrt(
                    Math.pow(dance - danceVal, 2) +
                    Math.pow(energy - energyVal, 2) +
                    Math.pow(valence - valenceVal, 2) +
                    Math.pow(acoustic - acousticVal, 2)
                );

                const matchScore = Math.max(0, Math.round((1 - d / 2) * 100));

                scoredTracks.push({
                    track: t,
                    score: matchScore
                });
            });

            scoredTracks.sort((a, b) => b.score - a.score);
            const topTracks = scoredTracks.slice(0, 6);

            document.getElementById('mixMatchCount').textContent = `Смикшировано 6 лучших треков (Рецепт: ${Math.round(danceVal * 100)}%/${Math.round(energyVal * 100)}%/${Math.round(valenceVal * 100)}%/${Math.round(acousticVal * 100)}%)`;

            let html = '';
            topTracks.forEach(item => {
                const t = item.track;
                const score = item.score;

                let glowColor = 'rgba(0, 245, 255, 0.4)';
                let textColor = '#00F5FF';
                if (score >= 90) {
                    glowColor = 'rgba(29, 185, 84, 0.4)';
                    textColor = 'var(--spotify-green)';
                } else if (score >= 75) {
                    glowColor = 'rgba(255, 179, 0, 0.4)';
                    textColor = '#FFB300';
                }

                const bpmText = t.bpm === 'N/A' || !t.bpm ? 'N/A' : Math.round(t.bpm);

                html += `
                    <div class="track-card" onclick="openDetailsModal(event, '${t.id}')" style="cursor: pointer; transition: all 0.3s; position: relative; overflow: hidden; border: 1px solid var(--panel-border); background: var(--card-bg); padding: 16px; border-radius: 12px; display: flex; flex-direction: column; justify-content: space-between;">
                        <div style="position: absolute; top: 12px; right: 12px; font-size: 11px; font-weight: 800; padding: 4px 8px; border-radius: 12px; background: rgba(0, 0, 0, 0.6); border: 1px solid ${textColor}; color: ${textColor}; box-shadow: 0 0 10px ${glowColor}; font-family: 'Outfit', sans-serif; display: flex; align-items: center; gap: 4px;">
                            <i class="fas fa-heartbeat"></i> ${score}% совпадение
                        </div>
                        
                        <div style="display: flex; gap: 15px; align-items: center; margin-bottom: 15px;">
                            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #282828 0%, #121212 100%); border-radius: 8px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--panel-border); flex-shrink: 0; box-shadow: 0 4px 10px rgba(0,0,0,0.3);">
                                <i class="fas fa-music" style="color: rgba(255, 255, 255, 0.3); font-size: 20px;"></i>
                            </div>
                            <div style="overflow: hidden; flex-grow: 1; padding-right: 90px;">
                                <h4 style="margin: 0; font-size: 14px; color: var(--text-main); font-weight: 700; font-family: 'Outfit', sans-serif; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${t.name}</h4>
                                <p style="margin: 4px 0 0 0; font-size: 13px; color: var(--text-muted); font-family: 'Outfit', sans-serif; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${t.artist}</p>
                            </div>
                        </div>
                        
                        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; background: var(--panel-bg); border: 1px solid var(--panel-border); padding: 8px; border-radius: 8px; font-size: 11px; text-align: center; font-family: 'Outfit', sans-serif;">
                            <div>
                                <div style="color: var(--text-muted); font-size: 9px; font-weight: 600; text-transform: uppercase; margin-bottom: 2px;">🕺 Ритм</div>
                                <div style="color: var(--text-main); font-weight: 700;">${Math.round(t.danceability * 100)}%</div>
                            </div>
                            <div>
                                <div style="color: var(--text-muted); font-size: 9px; font-weight: 600; text-transform: uppercase; margin-bottom: 2px;">⚡ Энергия</div>
                                <div style="color: var(--text-main); font-weight: 700;">${t.energy === 'N/A' ? 'N/A' : Math.round(t.energy * 100) + '%'}</div>
                            </div>
                            <div>
                                <div style="color: var(--text-muted); font-size: 9px; font-weight: 600; text-transform: uppercase; margin-bottom: 2px;">☀️ Позитив</div>
                                <div style="color: var(--text-main); font-weight: 700;">${Math.round(t.valence * 100)}%</div>
                            </div>
                        </div>
                        
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px; font-family: 'Outfit', sans-serif;">
                            <span style="font-size: 11px; color: var(--accent-cyan); font-weight: 700; background: rgba(0, 245, 255, 0.05); padding: 2px 8px; border-radius: 10px; border: 1px solid rgba(0, 245, 255, 0.15);">
                                🔑 ${t.key_signature} (${t.camelot_key})
                            </span>
                            <span style="font-size: 11px; color: var(--text-muted); font-weight: 600;">
                                ⏱️ ${bpmText} BPM
                            </span>
                        </div>
                    </div>
                `;
            });
            resultsDiv.innerHTML = html;
        }

        function applyPresetRecipe(dance, energy, valence, acoustic) {
            document.getElementById('sliderMixDance').value = dance;
            document.getElementById('valMixDance').textContent = dance + '%';

            document.getElementById('sliderMixEnergy').value = energy;
            document.getElementById('valMixEnergy').textContent = energy + '%';

            document.getElementById('sliderMixValence').value = valence;
            document.getElementById('valMixValence').textContent = valence + '%';

            document.getElementById('sliderMixAcoustic').value = acoustic;
            document.getElementById('valMixAcoustic').textContent = acoustic + '%';

            autoMixVibe();
        }

        function spinVibeRoulette() {
            if (tracks.length === 0) return;

            const canvas = document.createElement('canvas');
            canvas.style.position = 'fixed';
            canvas.style.top = '0';
            canvas.style.left = '0';
            canvas.style.width = '100vw';
            canvas.style.height = '100vh';
            canvas.style.pointerEvents = 'none';
            canvas.style.zIndex = '99999';
            document.body.appendChild(canvas);

            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            const particles = [];
            const colors = ['#1DB954', '#00F5FF', '#BF5FFF', '#FFB300', '#FF5722', '#E040FB'];
            const startX = canvas.width / 2;
            const startY = canvas.height / 2;

            for (let i = 0; i < 50; i++) {
                const angle = Math.random() * Math.PI * 2;
                const speed = 2 + Math.random() * 8;
                particles.push({
                    x: startX,
                    y: startY,
                    vx: Math.cos(angle) * speed,
                    vy: Math.sin(angle) * speed,
                    radius: 2 + Math.random() * 4,
                    color: colors[Math.floor(Math.random() * colors.length)],
                    alpha: 1.0,
                    decay: 0.02 + Math.random() * 0.02
                });
            }

            function animateParticles() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                let alive = false;

                particles.forEach(p => {
                    if (p.alpha <= 0) return;
                    alive = true;

                    p.x += p.vx;
                    p.y += p.vy;
                    p.vy += 0.04; // smooth gravity
                    p.alpha -= p.decay;

                    ctx.beginPath();
                    ctx.fillStyle = p.color;
                    ctx.globalAlpha = p.alpha;
                    ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    ctx.fill();
                });

                // reset alpha for next operations
                ctx.globalAlpha = 1.0;

                if (alive) {
                    requestAnimationFrame(animateParticles);
                } else {
                    document.body.removeChild(canvas);
                }
            }

            animateParticles();

            const randomTrack = tracks[Math.floor(Math.random() * tracks.length)];

            setTimeout(() => {
                openDetailsModal(null, randomTrack.id);
            }, 300);
        }

        // Scroll to specific section smoothly with smart tab auto-switching
        function scrollToSection(sectionId) {
            // Find active tab pane
            const activePane = document.querySelector('.tab-pane.active');
            if (!activePane) return;

            if (sectionId === 'top') {
                activePane.scrollTo({ top: 0, behavior: 'smooth' });
                return;
            }

            // Switch to pane-archive first if needed
            if (activePane.id !== 'pane-archive') {
                switchTab('archive');
            }

            let elementId = '';
            if (sectionId === 'monthly-tops') {
                elementId = 'section-monthly-tops';
            } else if (sectionId === 'tracks') {
                elementId = 'section-tracks';
            }

            const element = document.getElementById(elementId);
            const archivePane = document.getElementById('pane-archive');
            if (element && archivePane) {
                setTimeout(() => {
                    const paneRect = archivePane.getBoundingClientRect();
                    const elemRect = element.getBoundingClientRect();
                    
                    // Calculate relative offset within the pane with some top padding
                    const relativeTop = elemRect.top - paneRect.top + archivePane.scrollTop - 20;

                    archivePane.scrollTo({
                        top: relativeTop,
                        behavior: 'smooth'
                    });
                }, 100);
            }
        }

        let activeAudio = null;
        let activeCardId = null;

        const globalPlayer = document.getElementById('global-player');
        const toast = document.getElementById('audio-toast');
        const toastArt = document.getElementById('toast-art');
        const toastName = document.getElementById('toast-name');
        const toastArtist = document.getElementById('toast-artist');

        let currentPage = 1;
        const ITEMS_PER_PAGE = 40;
        let allFilteredTracks = [];

        // Musical DNA Profiler
        function updateListenerArchetype(currentTracks) {
            const archBadgeIcon = document.getElementById('arch-badge-icon');
            const archName = document.getElementById('arch-name');
            const archDesc = document.getElementById('arch-desc');
            const archValEnergy = document.getElementById('arch-val-energy');
            const archValDance = document.getElementById('arch-val-dance');
            const archValValence = document.getElementById('arch-val-valence');
            const archValAcoustic = document.getElementById('arch-val-acoustic');
            
            const archBarEnergy = document.getElementById('arch-bar-energy');
            const archBarDance = document.getElementById('arch-bar-dance');
            const archBarValence = document.getElementById('arch-bar-valence');
            const archBarAcoustic = document.getElementById('arch-bar-acoustic');
            
            const archTime = document.getElementById('arch-time');
            const archTemp = document.getElementById('arch-temp');
            const archBpm = document.getElementById('arch-bpm');
            const archCount = document.getElementById('arch-count');

            if (!archBadgeIcon || !archName || !currentTracks) return;

            const trks = currentTracks.filter(t => 
                t.energy !== undefined && t.energy !== 'N/A' && !isNaN(t.energy) &&
                t.danceability !== undefined && t.danceability !== 'N/A' && !isNaN(t.danceability) &&
                t.valence !== undefined && t.valence !== 'N/A' && !isNaN(t.valence) &&
                t.acousticness !== undefined && t.acousticness !== 'N/A' && !isNaN(t.acousticness)
            );

            let avgEnergy = 0.5, avgDance = 0.5, avgValence = 0.5, avgAcoustic = 0.2, avgBpm = 120;
            if (trks.length > 0) {
                let sumEnergy = 0, sumDance = 0, sumValence = 0, sumAcoustic = 0, sumBpm = 0, countBpm = 0;
                trks.forEach(t => {
                    sumEnergy += parseFloat(t.energy);
                    sumDance += parseFloat(t.danceability);
                    sumValence += parseFloat(t.valence);
                    sumAcoustic += parseFloat(t.acousticness);
                    if (t.bpm && t.bpm !== 'N/A' && !isNaN(t.bpm)) {
                        sumBpm += parseFloat(t.bpm);
                        countBpm++;
                    }
                });
                avgEnergy = sumEnergy / trks.length;
                avgDance = sumDance / trks.length;
                avgValence = sumValence / trks.length;
                avgAcoustic = sumAcoustic / trks.length;
                avgBpm = countBpm > 0 ? (sumBpm / countBpm) : 120;
            }

            // Determine Archetype
            let archetype = "Хамелеон Музыки";
            let icon = "fa-sync-alt";
            let color = "var(--spotify-green)";
            let desc = "Вы слушаете всё подряд! У вас идеальный баланс вкусов без явных перекосов в жанры.";
            let bgGlow = "rgba(29, 185, 84, 0.1)";
            let timeOfDay = "Круглые сутки";
            let temperament = "Гибкий и адаптивный";

            if (avgEnergy > 0.75 && avgBpm > 130) {
                archetype = "Ночной Гонщик";
                icon = "fa-bolt";
                color = "#FF6B6B";
                bgGlow = "rgba(255, 107, 107, 0.15)";
                desc = "Максимальный драйв, быстрый темп и сумасшедшая энергетика. Спокойная музыка явно не для вас!";
                timeOfDay = "Поздний вечер / Ночь";
                temperament = "Адреналиновый шторм";
            } else if (avgAcoustic > 0.45 && avgEnergy < 0.45) {
                archetype = "Ламповый Интроверт";
                icon = "fa-guitar";
                color = "#FFD700";
                bgGlow = "rgba(255, 215, 0, 0.15)";
                desc = "Уютные акустические сессии, глубокий вокал и неторопливый теплый вайб. Идеально под плед.";
                timeOfDay = "Раннее туманное утро";
                temperament = "Глубокая рефлексия";
            } else if (avgValence < 0.35 && avgEnergy < 0.5) {
                archetype = "Меланхоличный Поэт";
                icon = "fa-moon";
                color = "#BD00FF";
                bgGlow = "rgba(189, 0, 255, 0.15)";
                desc = "Вы цените грустную, минорную и глубокую атмосферу. Каждая песня — целая личная драма.";
                timeOfDay = "Дождливые сумерки";
                temperament = "Сладкая грусть";
            } else if (avgDance > 0.7 && avgValence > 0.55) {
                archetype = "Король Вечеринок";
                icon = "fa-compact-disc";
                color = "#00F5FF";
                bgGlow = "rgba(0, 245, 255, 0.15)";
                desc = "Ритмичный кач, высокая танцевальность и взрывной позитивный настрой. Ноги сами идут в пляс!";
                timeOfDay = "Разгар субботней тусовки";
                temperament = "Зажигательный и яркий";
            } else if (avgEnergy > 0.7 && avgValence < 0.4) {
                archetype = "Бунтарь-Экстремал";
                icon = "fa-skull";
                color = "#FF3366";
                bgGlow = "rgba(255, 51, 102, 0.15)";
                desc = "Тяжелая музыка, агрессивный напор и мрачная энергия. Вы любите выплеснуть эмоции на полную!";
                timeOfDay = "Суровые будни";
                temperament = "Необузданный гнев";
            }

            archBadgeIcon.innerHTML = `<i class="fas ${icon}"></i>`;
            archBadgeIcon.style.color = color;
            archBadgeIcon.style.background = bgGlow;
            archBadgeIcon.style.boxShadow = `0 0 20px ${color}33`;
            archBadgeIcon.style.border = `1px solid ${color}44`;
            
            archName.textContent = archetype;
            archName.style.color = color;
            archDesc.textContent = desc;
            
            archValEnergy.textContent = Math.round(avgEnergy * 100) + '%';
            archValDance.textContent = Math.round(avgDance * 100) + '%';
            archValValence.textContent = Math.round(avgValence * 100) + '%';
            archValAcoustic.textContent = Math.round(avgAcoustic * 100) + '%';

            archBarEnergy.style.width = Math.round(avgEnergy * 100) + '%';
            archBarDance.style.width = Math.round(avgDance * 100) + '%';
            archBarValence.style.width = Math.round(avgValence * 100) + '%';
            archBarAcoustic.style.width = Math.round(avgAcoustic * 100) + '%';

            archTime.textContent = timeOfDay;
            archTemp.textContent = temperament;
            archBpm.textContent = Math.round(avgBpm) + ' BPM';
            archCount.textContent = currentTracks.length;

            // Let's compute average popularity too!
            let avgPopularity = 50;
            const popularTracks = currentTracks.filter(t => t.popularity !== undefined && t.popularity !== 'N/A' && !isNaN(t.popularity));
            if (popularTracks.length > 0) {
                avgPopularity = popularTracks.reduce((sum, t) => sum + parseInt(t.popularity), 0) / popularTracks.length;
            }

            // Draw SVG Radar Chart!
            drawVibeRadarChart(
                avgEnergy,
                avgDance,
                avgValence,
                avgAcoustic,
                avgPopularity / 100,
                Math.max(0, Math.min(1, (avgBpm - 50) / 150))
            );
        }

        function drawVibeRadarChart(energy, dance, valence, acoustic, popularity, tempo) {
            const svg = document.getElementById('vibeRadarChart');
            if (!svg) return;

            const values = [energy, dance, valence, acoustic, popularity, tempo];
            const labels = ["Энергия", "Ритм", "Позитив", "Акустика", "Поп-ность", "BPM"];
            
            // Outer dimensions and helper coordinates
            const size = 200;
            const center = size / 2;
            const radius = 68; // limit radius to leave room for labels
            
            let html = '';

            // 1. Concentric Hexagons Background
            const gridLevels = [0.25, 0.5, 0.75, 1.0];
            gridLevels.forEach(level => {
                const points = [];
                for (let i = 0; i < 6; i++) {
                    const angle = (i * Math.PI / 3) - (Math.PI / 2);
                    const d = level * radius;
                    const x = center + d * Math.cos(angle);
                    const y = center + d * Math.sin(angle);
                    points.push(`${x},${y}`);
                }
                const opacity = 0.02 + level * 0.03;
                html += `<polygon points="${points.join(' ')}" fill="none" stroke="rgba(255, 255, 255, ${opacity})" stroke-width="1" />`;
            });

            // 2. Axis Spokes
            for (let i = 0; i < 6; i++) {
                const angle = (i * Math.PI / 3) - (Math.PI / 2);
                const x = center + radius * Math.cos(angle);
                const y = center + radius * Math.sin(angle);
                html += `<line x1="${center}" y1="${center}" x2="${x}" y2="${y}" stroke="rgba(255, 255, 255, 0.08)" stroke-width="1" />`;
            }

            // 3. Axis Labels
            labels.forEach((label, i) => {
                const angle = (i * Math.PI / 3) - (Math.PI / 2);
                const textDist = radius + 15;
                const x = center + textDist * Math.cos(angle);
                const y = center + textDist * Math.sin(angle);
                
                let textAnchor = "middle";
                if (Math.cos(angle) > 0.15) textAnchor = "start";
                else if (Math.cos(angle) < -0.15) textAnchor = "end";
                
                let dy = "3px";
                if (Math.sin(angle) > 0.5) dy = "8px";
                else if (Math.sin(angle) < -0.5) dy = "-2px";

                html += `<text x="${x}" y="${y}" fill="var(--text-muted)" font-size="8.5" font-family="'Outfit', sans-serif" font-weight="700" text-anchor="${textAnchor}" dy="${dy}">${label}</text>`;
            });

            // 4. Data Polygon
            const dataPoints = [];
            values.forEach((val, i) => {
                const angle = (i * Math.PI / 3) - (Math.PI / 2);
                // Ensure val is never zero, default to a small radius to avoid a collapsed chart
                const d = Math.max(0.08, val) * radius;
                const x = center + d * Math.cos(angle);
                const y = center + d * Math.sin(angle);
                dataPoints.push(`${x},${y}`);
            });
            
            // Add a neon styling for the filled path
            html += `<polygon points="${dataPoints.join(' ')}" fill="rgba(29, 185, 84, 0.18)" stroke="var(--spotify-green)" stroke-width="2" style="filter: drop-shadow(0 0 5px rgba(29, 185, 84, 0.45));" />`;

            // 5. Glow Circles at Vertices
            values.forEach((val, i) => {
                const angle = (i * Math.PI / 3) - (Math.PI / 2);
                const d = Math.max(0.08, val) * radius;
                const x = center + d * Math.cos(angle);
                const y = center + d * Math.sin(angle);
                html += `<circle cx="${x}" cy="${y}" r="3.5" fill="#ffffff" stroke="var(--spotify-green)" stroke-width="1.5" />`;
            });

            svg.innerHTML = html;
        }

        // Render all tracks with dynamic lazy loading
        function renderTracks(tracksToRender) {
            allFilteredTracks = tracksToRender;
            const grid = document.getElementById('tracksGrid');
            grid.innerHTML = '';
            currentPage = 1;

            if (allFilteredTracks.length === 0) {
                grid.innerHTML = `
                    <div style="grid-column: 1/-1; text-align: center; padding: 50px 0; color: var(--text-muted);">
                        <i class="fas fa-folder-open" style="font-size: 48px; margin-bottom: 15px; display: block; color: rgba(255,255,255,0.1);"></i>
                        Нет треков, соответствующих заданным критериям поиска.
                    </div>
                `;
                return;
            }

            appendTracks(allFilteredTracks.slice(0, ITEMS_PER_PAGE));
        }

        // Append a slice of tracks to the grid
        function appendTracks(tracksToAppend) {
            const grid = document.getElementById('tracksGrid');

            tracksToAppend.forEach((track) => {
                // Determine if key is Minor
                const isMinor = track.key.includes("Минор");
                const keyBadgeClass = isMinor ? 'badge-key minor' : 'badge-key';
                const keyIcon = isMinor ? '<i class="fas fa-violin"></i>' : '<i class="fas fa-sun"></i>';
                const camelotDisplay = track.camelot_key && track.camelot_key !== 'N/A' ? ` [${track.camelot_key}]` : '';

                // SVG circular progress dials
                const danceOffset = 100 - (track.danceability * 100);
                const energyVal = track.energy === 'N/A' ? 0.0 : track.energy;
                const energyOffset = 100 - (energyVal * 100);
                const valenceOffset = 100 - (track.valence * 100);

                // Play / Pause Icon
                const isPlayingThis = (activeCardId === track.id);
                const playIconClass = isPlayingThis ? 'fa-pause' : 'fa-play';
                const cardPlayingClass = isPlayingThis ? 'playing-audio' : '';

                // Hide play button if preview_url is not available
                const previewBtnHtml = track.preview_url
                    ? `<button class="preview-btn" onclick="toggleAudio('${track.id}', '${track.preview_url.replace(/'/g, "\\'")}', '${track.name.replace(/'/g, "\\'")}', '${track.artist.replace(/'/g, "\\'")}', '${track.album_art}')"><i class="fas ${playIconClass}" id="btn-${track.id}"></i></button>`
                    : '';

                const vibeLabels = {
                    'Party': '🔥 Танцевальный',
                    'Energetic': '⚡ Драйв',
                    'Chill': '🌌 Чилл',
                    'Melancholic': '🎭 Меланхолия',
                    'Happy': '☀️ Радость',
                    'Focus': '🚀 Фокус',
                    'Balanced': '⚖️ Баланс'
                };
                const vibeLabel = vibeLabels[track.vibe] || track.vibe;

                // Determine dynamic cover art (use album art if available, otherwise generate beautiful gradient)
                let albumArtHtml = '';
                if (track.album_art && track.album_art !== 'N/A' && !track.album_art.includes('placeholder')) {
                    albumArtHtml = `<img src="${track.album_art}" alt="${track.album}" class="album-art" loading="lazy">`;
                } else {
                    // Generate stunning dynamic premium gradient based on hash of artist & track name
                    let hash1 = 0;
                    const str1 = track.artist || "";
                    for (let i = 0; i < str1.length; i++) {
                        hash1 = str1.charCodeAt(i) + ((hash1 << 5) - hash1);
                    }
                    let hash2 = 0;
                    const str2 = track.name || "";
                    for (let i = 0; i < str2.length; i++) {
                        hash2 = str2.charCodeAt(i) + ((hash2 << 5) - hash2);
                    }
                    const h1 = Math.abs(hash1) % 360;
                    const h2 = Math.abs(hash2) % 360;
                    const grad = `linear-gradient(135deg, hsl(${h1}, 75%, 45%) 0%, hsl(${h2}, 60%, 20%) 100%)`;

                    const initial = track.artist ? track.artist.charAt(0).toUpperCase() : '🎵';
                    albumArtHtml = `
                        <div class="album-art-placeholder" style="background: ${grad}">
                            ${initial}
                        </div>
                    `;
                }

                const genresHtml = track.genres
                    ? `<div class="track-genres" title="${track.genres}">${track.genres}</div>`
                    : '';

                const esc = (str) => (str || '').replace(/"/g, '&quot;');
                const playlistsList = track.playlists || [];
                let playlistsHtml = '';
                if (playlistsList.length > 0) {
                    playlistsHtml = playlistsList.map(pl => `<span class="playlist-tag">${pl}</span>`).join(' ');
                } else {
                    playlistsHtml = '<span class="playlist-tag empty">Нет</span>';
                }

                let addedHtml = '';
                if (track.added_at && track.added_at !== 'Неизвестно' && track.added_at !== 'NaT' && track.added_at !== 'NaN' && track.added_at !== 'null') {
                    addedHtml = `<span class="track-added-at"><i class="far fa-calendar-alt"></i> Добавлен: ${track.added_at}</span>`;
                }

                let avgRankHtml = '';
                if (track.avg_rank && track.avg_rank !== 'N/A' && track.avg_rank !== 'NaN' && track.avg_rank !== 'null') {
                    avgRankHtml = `<span class="track-avg-rank"><i class="fas fa-trophy"></i> Ср. Место: ${track.avg_rank}</span>`;
                }

                let appearancesHtml = '';
                const appCount = (track.history_ranks || []).length;
                if (appCount > 0) {
                    appearancesHtml = `<span class="track-appearances" title="Количество попаданий в топ-50 месяца"><i class="fas fa-calendar-check"></i> Топ месяцев: ${appCount}</span>`;
                }

                // Compute track achievements dynamically
                let trackAchievementsHtml = '';

                // 1. Абсолютный Бестселлер (6+ months)
                if (appCount >= 6) {
                    trackAchievementsHtml += `<span class="badge-achievement absolute-dominator" style="font-size: 11px; padding: 4px 10px; border-radius: 12px; height: 28px; line-height: 20px;" title="Абсолютный Бестселлер: трек удерживался в чартах более 6 месяцев!"><i class="fas fa-fire"></i> Бестселлер</span>`;
                }

                // 2. Танцевальный Ураган (danceability >= 0.85 & energy >= 0.85)
                if (track.danceability >= 0.85 && energyVal >= 0.85) {
                    trackAchievementsHtml += `<span class="badge-achievement one-hit" style="font-size: 11px; padding: 4px 10px; border-radius: 12px; height: 28px; line-height: 20px;" title="Танцевальный Ураган: невероятный заряд энергии и танцевального вайба!"><i class="fas fa-bolt"></i> Ураган</span>`;
                }

                // 3. Абсолютный Дзен (vibe === Chill & valence <= 0.3)
                if (track.vibe === 'Chill' && track.valence <= 0.3) {
                    trackAchievementsHtml += `<span class="badge-achievement stable-vet" style="font-size: 11px; padding: 4px 10px; border-radius: 12px; height: 28px; line-height: 20px;" title="Абсолютный Дзен: глубочайший меланхоличный чилл-вайб для полного погружения."><i class="fas fa-cloud-moon"></i> Дзен</span>`;
                }

                const cardHtml = `
                    <div class="track-card ${cardPlayingClass}" id="card-${track.id}" onclick="openDetailsModal(event, '${track.id}')">
                        <button class="favorite-btn ${isFavorite(track.id) ? 'active' : ''}" 
                                onclick="toggleFavorite(event, '${track.id}')"
                                title="${isFavorite(track.id) ? 'Удалить из избранного' : 'Добавить в избранное'}">
                            <i class="${isFavorite(track.id) ? 'fas' : 'far'} fa-heart"></i>
                        </button>
                        <button class="copy-gemini-btn" 
                                data-artist="${esc(track.artist)}" 
                                data-name="${esc(track.name)}" 
                                data-album="${esc(track.album)}" 
                                data-bpm="${track.bpm}" 
                                data-key="${track.key}" 
                                data-energy="${track.energy}" 
                                data-genres="${esc(track.genres || '')}"
                                data-playlists="${esc(JSON.stringify(playlistsList))}"
                                data-added="${esc(track.added_at)}"
                                data-avg-rank="${track.avg_rank}"
                                onclick="copyTrackToGemini(this)">
                            <i class="far fa-copy"></i> <span class="btn-text">Gemini</span>
                        </button>
                        <div class="card-top">
                            <div class="album-art-container">
                                ${albumArtHtml}
                                ${previewBtnHtml}
                            </div>
                            <div class="track-meta">
                                <a href="${track.spotify_url}" target="_blank" class="track-title-link" title="Открыть в Spotify">
                                    <span class="track-title">${track.name}</span>
                                </a>
                                <span class="track-artist" title="${track.artist}">${track.artist}</span>
                                <span class="track-album" title="${track.album}">${track.album}</span>
                                <span class="track-playlists"><i class="fas fa-list-ul"></i> В плейлистах: ${playlistsHtml}</span>
                                ${addedHtml}
                                ${avgRankHtml}
                                ${appearancesHtml}
                            </div>
                        </div>

                        <div class="card-badges">
                            <span class="${keyBadgeClass}">${keyIcon} ${track.key}${camelotDisplay}</span>
                            <span class="badge badge-vibe"><i class="fas fa-yin-yang"></i> ${vibeLabel}</span>
                            ${trackAchievementsHtml}
                        </div>
                        ${genresHtml}

                        <div class="card-details">
                            <!-- Danceability dial -->
                            <div class="detail-item">
                                <span class="detail-label">Ритм</span>
                                <div class="dial-container">
                                    <svg class="dial-svg">
                                        <circle class="dial-bg" cx="21" cy="21" r="16"></circle>
                                        <circle class="dial-progress dial-dance" cx="21" cy="21" r="16" stroke-dasharray="100" stroke-dashoffset="${danceOffset}"></circle>
                                    </svg>
                                    <span class="dial-text">${Math.round(track.danceability * 100)}%</span>
                                </div>
                            </div>
                            
                            <!-- Energy dial -->
                            <div class="detail-item">
                                <span class="detail-label">Энергия</span>
                                <div class="dial-container">
                                    <svg class="dial-svg">
                                        <circle class="dial-bg" cx="21" cy="21" r="16"></circle>
                                        <circle class="dial-progress dial-energy" cx="21" cy="21" r="16" stroke-dasharray="100" stroke-dashoffset="${energyOffset}"></circle>
                                    </svg>
                                    <span class="dial-text">${track.energy === 'N/A' ? 'N/A' : Math.round(track.energy * 100) + '%'}</span>
                                </div>
                            </div>

                            <!-- Valence dial -->
                            <div class="detail-item">
                                <span class="detail-label">Настроение</span>
                                <div class="dial-container">
                                    <svg class="dial-svg">
                                        <circle class="dial-bg" cx="21" cy="21" r="16"></circle>
                                        <circle class="dial-progress dial-valence" cx="21" cy="21" r="16" stroke-dasharray="100" stroke-dashoffset="${valenceOffset}"></circle>
                                    </svg>
                                    <span class="dial-text">${Math.round(track.valence * 100)}%</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">
                            <a href="${track.spotify_url}" target="_blank" class="spotify-link">
                                <i class="fab fa-spotify"></i> Слушать в Spotify
                            </a>
                            <div class="popularity-indicator">
                                <i class="fas fa-fire"></i> ${track.popularity}
                            </div>
                            
                            <!-- Playing Waveform Indicator -->
                            <div class="waveform" id="wave-${track.id}">
                                <div class="wave-bar"></div>
                                <div class="wave-bar"></div>
                                <div class="wave-bar"></div>
                                <div class="wave-bar"></div>
                            </div>
                        </div>
                    </div>
                `;
                grid.insertAdjacentHTML('beforeend', cardHtml);
            });
        }

        // Lazy load more tracks on scroll
        function loadMoreTracks() {
            const start = currentPage * ITEMS_PER_PAGE;
            if (start >= allFilteredTracks.length) return;

            currentPage++;
            const end = currentPage * ITEMS_PER_PAGE;
            appendTracks(allFilteredTracks.slice(start, end));
        }

        // Infinite scrolling event listener for pane-archive
        const archivePaneEl = document.getElementById('pane-archive');
        if (archivePaneEl) {
            archivePaneEl.addEventListener('scroll', () => {
                const { scrollTop, scrollHeight, clientHeight } = archivePaneEl;
                if (scrollTop + clientHeight >= scrollHeight - 300) {
                    loadMoreTracks();
                }
            });
        }

        // Audio preview play control
        function toggleAudio(trackId, previewUrl, name, artist, artUrl) {
            const card = document.getElementById(`card-${trackId}`);
            const btn = document.getElementById(`btn-${trackId}`);
            const wave = document.getElementById(`wave-${trackId}`);

            if (activeCardId === trackId) {
                // Pause current
                globalPlayer.pause();
                resetAudioState();
            } else {
                // Pause previous
                if (activeCardId) {
                    resetAudioState();
                }

                // Get energy and BPM from database
                const dbTrack = tracks.find(t => t.id === trackId);
                const trackEnergy = dbTrack ? parseFloat(dbTrack.energy) : 0.6;
                const trackBpm = dbTrack ? parseFloat(dbTrack.bpm) : 120;
                const trackValence = dbTrack ? parseFloat(dbTrack.valence) : 0.5;

                // Play new
                globalPlayer.src = previewUrl;
                globalPlayer.play().then(() => {
                    activeCardId = trackId;
                    card.classList.add('playing-audio');
                    btn.classList.remove('fa-play');
                    btn.classList.add('fa-pause');

                    // Show toast
                    toastArt.src = artUrl;
                    toastName.innerText = name;
                    toastArtist.innerText = artist;
                    toast.classList.add('show');

                    // Start neon visualizer
                    startVisualizer(trackEnergy, trackBpm, trackValence);
                }).catch(err => {
                    console.error("Ошибка воспроизведения аудио:", err);
                    alert("Не удалось загрузить аудиопревью этого трека.");
                });
            }
        }

        function resetAudioState() {
            if (activeCardId) {
                const prevCard = document.getElementById(`card-${activeCardId}`);
                const prevBtn = document.getElementById(`btn-${activeCardId}`);

                if (prevCard) prevCard.classList.remove('playing-audio');
                if (prevBtn) {
                    prevBtn.classList.remove('fa-pause');
                    prevBtn.classList.add('fa-play');
                }
            }
            activeCardId = null;
            toast.classList.remove('show');
            stopVisualizer();
        }

        // Event listener for audio completion
        globalPlayer.onended = function () {
            resetAudioState();
            if (oraclePlaying) {
                oraclePlaying = false;
                const playBtn = document.getElementById('oracle-play-btn');
                if (playBtn) playBtn.innerHTML = '<i class="fas fa-play"></i> Слушать превью';
            }
        };
        function copyTrackToGemini(btn) {
            const artist = btn.getAttribute('data-artist') || 'N/A';
            const name = btn.getAttribute('data-name') || btn.getAttribute('data-title') || 'Без названия';
            const album = btn.getAttribute('data-album') || 'N/A';
            const bpm = btn.getAttribute('data-bpm') || 'N/A';
            const key = btn.getAttribute('data-key') || 'N/A';
            const energy = btn.getAttribute('data-energy') || 'N/A';
            const genres = btn.getAttribute('data-genres') || '';
            const addedAt = btn.getAttribute('data-added') || btn.getAttribute('data-date') || 'N/A';
            const avgRank = btn.getAttribute('data-avg-rank') || 'N/A';

            // Format energy as percentage
            let energyStr = 'N/A';
            if (energy !== 'N/A' && !isNaN(energy) && energy !== '') {
                energyStr = Math.round(parseFloat(energy) * 100) + '%';
            }

            // Build features array
            const features = [];
            if (album && album !== 'N/A' && album !== 'Неизвестный альбом') {
                features.push(`Альбом: ${album}`);
            }
            if (bpm && bpm !== 'N/A') {
                features.push(`BPM: ${bpm}`);
            }
            if (key && key !== 'N/A') {
                features.push(`Ключ: ${key}`);
            }
            if (energyStr !== 'N/A') {
                features.push(`Энергия: ${energyStr}`);
            }
            if (avgRank && avgRank !== 'N/A' && avgRank !== 'NaN' && avgRank !== 'null' && avgRank !== '—') {
                features.push(`Ср. Место: ${avgRank}`);
            }
            if (genres && genres !== 'N/A' && genres.trim() !== '') {
                features.push(`Теги: ${genres}`);
            }

            let text = `${artist} — ${name}`;
            if (features.length > 0) {
                text += ` [${features.join(', ')}]`;
            }



            // Add playlists
            try {
                const playlistsAttr = btn.getAttribute('data-playlists');
                if (playlistsAttr) {
                    const playlists = JSON.parse(playlistsAttr);
                    if (Array.isArray(playlists) && playlists.length > 0) {
                        text += ` -> В плейлистах: ${playlists.join(', ')}`;
                    }
                }
            } catch (err) {
                console.error('Error parsing playlists for copy: ', err);
            }

            navigator.clipboard.writeText(text).then(() => {
                const icon = btn.querySelector('i');
                const textSpan = btn.querySelector('.btn-text');

                btn.classList.add('copied');
                if (icon) icon.className = 'fas fa-check';
                if (textSpan) textSpan.textContent = 'Скопировано!';

                setTimeout(() => {
                    btn.classList.remove('copied');
                    if (icon) icon.className = 'far fa-copy';
                    if (textSpan) textSpan.textContent = 'Gemini';
                }, 1500);
            }).catch(err => {
                console.error('Ошибка копирования: ', err);
            });
        }


        function correctLayout(text) {
            const ru = "йцукенгшщзхъфывапролджэячсмитьбю.ЙЦУКЕНГШЩЗХЪФЫВАПРОЛДЖЭЯЧСМИТЬБЮ,";
            const en = 'qwertyuiop[]asdfghjkl;\'zxcvbnm,./QWERTYUIOP{}ASDFGHJKL:"ZXCVBNM<>?';

            let toEn = "";
            let toRu = "";

            for (let i = 0; i < text.length; i++) {
                const char = text[i];
                const ruIdx = ru.indexOf(char);
                const enIdx = en.indexOf(char);

                toEn += ruIdx !== -1 ? en[ruIdx] : char;
                toRu += enIdx !== -1 ? ru[enIdx] : char;
            }
            return { toEn, toRu };
        }

        // Filtering and Sorting logic
        let currentFilter = 'all';
        let searchQuery = '';
        let currentSort = 'saved';

        function filterAndSortTracks() {
            let filtered = [...tracks];

            // Search filter
            if (searchQuery) {
                const q = searchQuery.toLowerCase();
                const layouts = correctLayout(q);
                const qEn = layouts.toEn.toLowerCase();
                const qRu = layouts.toRu.toLowerCase();

                filtered = filtered.filter(t => {
                    const name = t.name.toLowerCase();
                    const artist = t.artist.toLowerCase();
                    const key = t.key.toLowerCase();
                    const album = (t.album || '').toLowerCase();

                    return name.includes(q) || artist.includes(q) || key.includes(q) || album.includes(q) ||
                        name.includes(qEn) || artist.includes(qEn) || key.includes(qEn) || album.includes(qEn) ||
                        name.includes(qRu) || artist.includes(qRu) || key.includes(qRu) || album.includes(qRu);
                });
            }

            // Tag/Category filter
            if (currentFilter !== 'all') {
                if (currentFilter === 'Major') {
                    filtered = filtered.filter(t => t.key.includes("Мажор"));
                } else if (currentFilter === 'Minor') {
                    filtered = filtered.filter(t => t.key.includes("Минор"));
                } else {
                    filtered = filtered.filter(t => t.vibe === currentFilter);
                }
            }

            // Sorting
            if (currentSort === 'saved') {
                filtered.reverse();
            } else if (currentSort === 'saved-asc') {
                // Keep original CSV order (oldest first)
            } else if (currentSort === 'bpm-asc') {
                filtered.sort((a, b) => {
                    const bpmA = a.bpm === 'N/A' ? -1 : a.bpm;
                    const bpmB = b.bpm === 'N/A' ? -1 : b.bpm;
                    return bpmA - bpmB;
                });
            } else if (currentSort === 'bpm-desc') {
                filtered.sort((a, b) => {
                    const bpmA = a.bpm === 'N/A' ? -1 : a.bpm;
                    const bpmB = b.bpm === 'N/A' ? -1 : b.bpm;
                    return bpmB - bpmA;
                });
            } else if (currentSort === 'energy-desc') {
                filtered.sort((a, b) => {
                    const energyA = a.energy === 'N/A' ? -1 : a.energy;
                    const energyB = b.energy === 'N/A' ? -1 : b.energy;
                    return energyB - energyA;
                });
            } else if (currentSort === 'energy-asc') {
                filtered.sort((a, b) => {
                    const energyA = a.energy === 'N/A' ? -1 : a.energy;
                    const energyB = b.energy === 'N/A' ? -1 : b.energy;
                    return energyA - energyB;
                });
            } else if (currentSort === 'popularity-desc') {
                filtered.sort((a, b) => b.popularity - a.popularity);
            } else if (currentSort === 'popularity-asc') {
                filtered.sort((a, b) => a.popularity - b.popularity);
            } else if (currentSort === 'album-asc') {
                const cleanStr = (str) => (str || '').replace(/^[^\p{L}\p{N}]+/gu, '');
                filtered.sort((a, b) => {
                    const albumA = cleanStr(a.album);
                    const albumB = cleanStr(b.album);
                    const cmp = albumA.localeCompare(albumB, undefined, { numeric: true, sensitivity: 'base' });
                    if (cmp !== 0) return cmp;

                    const nameA = a.name || '';
                    const nameB = b.name || '';
                    return nameA.localeCompare(nameB, undefined, { numeric: true, sensitivity: 'base' });
                });
            } else if (currentSort === 'album-desc') {
                const cleanStr = (str) => (str || '').replace(/^[^\p{L}\p{N}]+/gu, '');
                filtered.sort((a, b) => {
                    const albumA = cleanStr(a.album);
                    const albumB = cleanStr(b.album);
                    const cmp = albumB.localeCompare(albumA, undefined, { numeric: true, sensitivity: 'base' });
                    if (cmp !== 0) return cmp;

                    const nameA = a.name || '';
                    const nameB = b.name || '';
                    return nameB.localeCompare(nameA, undefined, { numeric: true, sensitivity: 'base' });
                });
            }

            renderTracks(filtered);
            updateListenerArchetype(filtered);
        }

        // Setup Controls Listeners
        document.getElementById('searchInput').addEventListener('input', (e) => {
            searchQuery = e.target.value;
            filterAndSortTracks();
        });

        document.getElementById('sortSelect').addEventListener('change', (e) => {
            currentSort = e.target.value;
            filterAndSortTracks();
        });

        document.querySelectorAll('.tag-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelector('.tag-btn.active').classList.remove('active');
                e.target.classList.add('active');
                currentFilter = e.target.getAttribute('data-filter');
                filterAndSortTracks();
            });
        });

        // --- CHART JS IMPLEMENTATIONS ---

        // 1. Vibe Distribution Doughnut Chart
        const vibeCanvas = document.getElementById('vibeChart').getContext('2d');

        const vibeCounts = {
            'Energetic': 0,
            'Party': 0,
            'Chill': 0,
            'Melancholic': 0,
            'Happy': 0,
            'Focus': 0,
            'Balanced': 0
        };

        tracks.forEach(t => {
            if (t.vibe && t.vibe in vibeCounts) {
                vibeCounts[t.vibe]++;
            }
        });

        const vibeLabels = ['Драйв ⚡', 'Вечеринка 🎉', 'Чилл ☕', 'Меланхолия 🌧️', 'Радость ☀️', 'Фокус 🧠', 'Баланс ⚖️'];
        const vibeKeys = ['Energetic', 'Party', 'Chill', 'Melancholic', 'Happy', 'Focus', 'Balanced'];
        const vibeData = vibeKeys.map(k => vibeCounts[k]);

        const vibeColors = [
            '#FF4500', // Energetic
            '#FF00FF', // Party
            '#1DB954', // Chill
            '#1E90FF', // Melancholic
            '#FFD700', // Happy
            '#8A2BE2', // Focus
            '#20B2AA'  // Balanced
        ];

        window.myVibeChart = new Chart(vibeCanvas, {
            type: 'doughnut',
            data: {
                labels: vibeLabels,
                datasets: [{
                    data: vibeData,
                    backgroundColor: vibeColors,
                    borderColor: 'rgba(18, 18, 18, 0.6)',
                    borderWidth: 2,
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'right',
                        labels: {
                            color: '#FFFFFF',
                            font: { family: 'Outfit', size: 12, weight: '500' },
                            padding: 15
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                const val = context.raw;
                                const pct = total > 0 ? ((val / total) * 100).toFixed(1) : 0;
                                return ` ${context.label}: ${val} треков (${pct}%)`;
                            }
                        }
                    }
                }
            }
        });

        // 2. Radar Chart (Баланс музыкальных свойств)
        const radarCanvas = document.getElementById('radarChart').getContext('2d');

        // Filter out tracks that have valid audio features
        const tracksWithFeatures = tracks.filter(t =>
            t.energy !== null && t.energy !== 'N/A' &&
            t.danceability !== null && t.danceability !== 'N/A' &&
            t.valence !== null && t.valence !== 'N/A' &&
            t.acousticness !== null && t.acousticness !== 'N/A'
        );

        let avgEnergy = 0, avgDance = 0, avgValence = 0, avgAcoustic = 0, avgInstrumental = 0;

        if (tracksWithFeatures.length > 0) {
            const sumEnergy = tracksWithFeatures.reduce((acc, t) => acc + parseFloat(t.energy), 0);
            const sumDance = tracksWithFeatures.reduce((acc, t) => acc + parseFloat(t.danceability), 0);
            const sumValence = tracksWithFeatures.reduce((acc, t) => acc + parseFloat(t.valence), 0);
            const sumAcoustic = tracksWithFeatures.reduce((acc, t) => acc + parseFloat(t.acousticness), 0);
            const sumInstrumental = tracksWithFeatures.reduce((acc, t) => acc + parseFloat(t.instrumentalness || 0), 0);

            avgEnergy = sumEnergy / tracksWithFeatures.length;
            avgDance = sumDance / tracksWithFeatures.length;
            avgValence = sumValence / tracksWithFeatures.length;
            avgAcoustic = sumAcoustic / tracksWithFeatures.length;
            avgInstrumental = sumInstrumental / tracksWithFeatures.length;
        } else {
            // Fallback averages if no features available
            avgEnergy = 0.6;
            avgDance = 0.5;
            avgValence = 0.5;
            avgAcoustic = 0.2;
            avgInstrumental = 0.1;
        }

        window.myRadarChart = new Chart(radarCanvas, {
            type: 'radar',
            data: {
                labels: ['Энергичность', 'Танцевальность', 'Позитивность', 'Акустичность', 'Инструментальность'],
                datasets: [{
                    label: 'Ваш средний профиль',
                    data: [
                        Math.round(avgEnergy * 100),
                        Math.round(avgDance * 100),
                        Math.round(avgValence * 100),
                        Math.round(avgAcoustic * 100),
                        Math.round(avgInstrumental * 100)
                    ],
                    backgroundColor: 'rgba(29, 185, 84, 0.2)',
                    borderColor: '#1DB954',
                    borderWidth: 2,
                    pointBackgroundColor: '#1DB954',
                    pointBorderColor: '#FFF',
                    pointHoverBackgroundColor: '#FFF',
                    pointHoverBorderColor: '#1DB954'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    r: {
                        angleLines: {
                            color: 'rgba(255, 255, 255, 0.1)'
                        },
                        grid: {
                            color: 'rgba(255, 255, 255, 0.1)'
                        },
                        pointLabels: {
                            color: '#B3B3B3',
                            font: {
                                family: 'Outfit',
                                size: 12
                            }
                        },
                        ticks: {
                            backdropColor: 'transparent',
                            color: '#666',
                            showLabelBackdrop: false,
                            stepSize: 20
                        },
                        suggestedMin: 0,
                        suggestedMax: 100
                    }
                }
            }
        });

        // --- ARTIST EVOLUTION SYSTEM ---
        const artistSelect = document.getElementById('artistSelect');
        const artistSelect2 = document.getElementById('artistSelect2');
        const sortedArtists = Object.keys(artistsHistory).sort();

        if (sortedArtists.length === 0) {
            const opt = document.createElement('option');
            opt.textContent = "Нет данных истории";
            artistSelect.appendChild(opt);
        } else {
            // Option 1: all (renamed to 'Общий график: Места в топе')
            const allOpt = document.createElement('option');
            allOpt.value = 'all';
            allOpt.textContent = '🏆 Общий график: Места в топе';
            artistSelect.appendChild(allOpt);

            // Option 2: cumulative (new mode)
            const cumOpt = document.createElement('option');
            cumOpt.value = 'cumulative';
            cumOpt.textContent = '📈 Общий график: Эволюция среднего балла';
            artistSelect.appendChild(cumOpt);

            // Option 3: avg_place_evolution (new mode)
            const avgPlaceOpt = document.createElement('option');
            avgPlaceOpt.value = 'avg_place_evolution';
            avgPlaceOpt.textContent = '📊 Общий график: Накопительное среднее место';
            artistSelect.appendChild(avgPlaceOpt);

            sortedArtists.forEach(art => {
                const opt = document.createElement('option');
                opt.value = art;
                opt.textContent = `${art} (Ср. Место: ${artistsHistory[art].avg_rank})`;
                artistSelect.appendChild(opt);
            });

            // Populate artistSelect2 for Duel
            if (artistSelect2) {
                sortedArtists.forEach(art => {
                    const opt = document.createElement('option');
                    opt.value = art;
                    opt.textContent = `${art} (Ср. Место: ${artistsHistory[art].avg_rank})`;
                    artistSelect2.appendChild(opt);
                });
            }
        }

        let activeRadarChart = null;
        function updateDuelRadarChart() {
            const art1 = artistSelect ? artistSelect.value : '';
            const art2 = artistSelect2 ? artistSelect2.value : '';
            const canvas = document.getElementById('duelRadarChart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            if (activeRadarChart) {
                activeRadarChart.destroy();
                activeRadarChart = null;
            }

            const labels = ["BPM (Темп)", "Энергия", "Настроение"];
            const datasets = [];

            const getFeatures = (artName) => {
                if (artName && typeof artistFeatures !== 'undefined' && artistFeatures[artName]) {
                    const f = artistFeatures[artName];
                    return [f.bpm, f.energy, f.valence];
                }
                return [0, 0, 0];
            };

            const isArt1Valid = art1 && art1 !== 'all' && art1 !== 'cumulative' && art1 !== 'avg_place_evolution';
            if (isArt1Valid) {
                datasets.push({
                    label: art1,
                    data: getFeatures(art1),
                    borderColor: '#00f5ff',
                    backgroundColor: 'rgba(0, 245, 255, 0.15)',
                    borderWidth: 3,
                    pointBackgroundColor: '#00f5ff',
                    pointBorderColor: '#fff',
                    pointRadius: 4
                });
            }

            const isArt2Valid = art2 && art2 !== '';
            if (isArt2Valid) {
                datasets.push({
                    label: art2,
                    data: getFeatures(art2),
                    borderColor: '#ff007f',
                    backgroundColor: 'rgba(255, 0, 127, 0.15)',
                    borderWidth: 3,
                    pointBackgroundColor: '#ff007f',
                    pointBorderColor: '#fff',
                    pointRadius: 4
                });
            }

            if (datasets.length === 0) {
                datasets.push({
                    label: 'Выберите исполнителя',
                    data: [0, 0, 0],
                    borderColor: 'rgba(255,255,255,0.1)',
                    backgroundColor: 'rgba(255,255,255,0.02)',
                    borderWidth: 1,
                    pointRadius: 0
                });
            }

            activeRadarChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: labels,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            min: 0,
                            max: 100,
                            beginAtZero: true,
                            angleLines: {
                                color: 'rgba(255, 255, 255, 0.1)'
                            },
                            grid: {
                                color: 'rgba(255, 255, 255, 0.1)'
                            },
                            pointLabels: {
                                color: '#B3B3B3',
                                font: {
                                    family: 'Outfit',
                                    size: 11,
                                    weight: 'bold'
                                }
                            },
                            ticks: {
                                backdropColor: 'transparent',
                                color: '#666',
                                showLabelBackdrop: false,
                                stepSize: 20
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom',
                            labels: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 11 }
                            }
                        }
                    }
                }
            });
        }

        /* --- ARTIST HEATMAP JAVASCRIPT LOGIC --- */
        function renderHeatmap() {
            const container = document.getElementById('artist-heatmap');
            if (!container) return;

            container.innerHTML = '';

            const heatmapArtists = sortedArtists.filter(art => {
                const activeMonths = artistsHistory[art].history.filter(h => h.rank !== null && !h.penalty).length;
                return activeMonths >= 3;
            }).sort((a, b) => artistsHistory[a].avg_rank - artistsHistory[b].avg_rank);

            if (heatmapArtists.length === 0) {
                container.innerHTML = '<div style="color: var(--text-muted); font-size: 13px; text-align: center; padding: 20px;">Нет данных для тепловой карты</div>';
                return;
            }

            const table = document.createElement('div');
            table.className = 'heatmap-table';

            const headerRow = document.createElement('div');
            headerRow.className = 'heatmap-header-row';

            const corner = document.createElement('div');
            corner.className = 'heatmap-corner';
            corner.textContent = 'Исполнитель';
            headerRow.appendChild(corner);

            const monthsHeader = document.createElement('div');
            monthsHeader.className = 'heatmap-months-header';

            months.forEach(m => {
                const monthLbl = document.createElement('div');
                monthLbl.className = 'heatmap-month-label';
                const cleanMonthName = m.split(' ')[0] || m;
                const shortName = cleanMonthName.substring(0, 3);
                monthLbl.textContent = shortName;
                monthLbl.title = m;
                monthsHeader.appendChild(monthLbl);
            });
            headerRow.appendChild(monthsHeader);
            table.appendChild(headerRow);

            heatmapArtists.forEach(art => {
                const artObj = artistsHistory[art];
                const row = document.createElement('div');
                row.className = 'heatmap-row';
                row.setAttribute('data-artist-row', art);

                const nameCell = document.createElement('div');
                nameCell.className = 'heatmap-artist-name';
                nameCell.textContent = art;
                nameCell.title = `${art} (Ср. место: ${artObj.avg_rank})`;
                nameCell.style.cursor = 'pointer';
                nameCell.addEventListener('click', () => {
                    if (artistSelect) {
                        if (artistSelect.value === art) {
                            artistSelect.value = 'all';
                        } else {
                            artistSelect.value = art;
                        }
                        artistSelect.dispatchEvent(new Event('change'));
                    }
                });

                row.appendChild(nameCell);

                const cellsContainer = document.createElement('div');
                cellsContainer.className = 'heatmap-cells-container';

                months.forEach((m, idx) => {
                    const h = artObj.history[idx];
                    const cell = document.createElement('div');
                    cell.className = 'heatmap-cell';

                    const rank = (h && h.rank !== null && !h.penalty) ? h.rank : null;

                    let color = '#161b22';
                    let tooltipText = `${art} — ${m}: вне топа`;

                    if (rank !== null) {
                        tooltipText = `${art} — ${m}: #${rank} место`;
                        if (rank >= 1 && rank <= 3) {
                            color = '#39d353';
                        } else if (rank >= 4 && rank <= 15) {
                            color = '#26a641';
                        } else if (rank >= 16 && rank <= 30) {
                            color = '#006d32';
                        } else if (rank >= 31 && rank <= 50) {
                            color = '#0e4429';
                        }
                    }

                    cell.style.backgroundColor = color;
                    cell.title = tooltipText;

                    cell.addEventListener('click', () => {
                        if (artistSelect) {
                            if (artistSelect.value === art) {
                                artistSelect.value = 'all';
                            } else {
                                artistSelect.value = art;
                            }
                            artistSelect.dispatchEvent(new Event('change'));
                        }
                    });

                    cellsContainer.appendChild(cell);
                });

                row.appendChild(cellsContainer);
                table.appendChild(row);
            });

            container.appendChild(table);
        }

        function highlightHeatmapRow(artistName) {
            document.querySelectorAll('.heatmap-row').forEach(row => {
                const rowArt = row.getAttribute('data-artist-row');
                const nameEl = row.querySelector('.heatmap-artist-name');
                const cellsEl = row.querySelector('.heatmap-cells-container');
                if (!nameEl || !cellsEl) return;

                if (!artistName || artistName === 'all' || artistName === 'cumulative' || artistName === 'avg_place_evolution') {
                    nameEl.style.opacity = '1';
                    cellsEl.style.opacity = '1';
                    const isLight = document.body.classList.contains('light-theme');
                    nameEl.style.color = isLight ? '#121212' : '#FFFFFF';
                } else if (rowArt === artistName) {
                    nameEl.style.opacity = '1';
                    cellsEl.style.opacity = '1';
                    nameEl.style.color = 'var(--spotify-green)';
                } else {
                    nameEl.style.opacity = '0.3';
                    cellsEl.style.opacity = '0.3';
                    const isLight = document.body.classList.contains('light-theme');
                    nameEl.style.color = isLight ? '#121212' : '#FFFFFF';
                }
            });
        }

        let activeArtistChart = null;
        let activeArtistTracksChart = null;
        let hoveredDatasetIndex = null;
        let updateDatasetStyles = null;
        function updateArtistEvolution(artistName) {
            const ctx = document.getElementById('artistChart').getContext('2d');
            const ctxTracks = document.getElementById('artistTracksChart').getContext('2d');
            if (activeArtistChart) {
                activeArtistChart.destroy();
            }
            if (activeArtistTracksChart) {
                activeArtistTracksChart.destroy();
            }

            let datasets = [];
            let datasetsTracks = [];

            // Фильтруем новичков (тех, кто был в топе < 3 месяцев) для общих графиков
            const filteredArtistsForGeneral = sortedArtists.filter(art => {
                const activeMonths = artistsHistory[art].history.filter(h => h.rank !== null && !h.penalty).length;
                return activeMonths >= 3;
            });

            if (artistName === 'all' || artistName === 'cumulative' || artistName === 'avg_place_evolution') {
                document.querySelector('.artist-stats-grid').style.display = 'none';
                document.getElementById('stat-avg-rank').textContent = '—';
                document.getElementById('stat-debut').textContent = '—';
                document.getElementById('stat-best-rank').textContent = '—';
                document.getElementById('stat-active-ratio').textContent = '—';

                const badgesContainer = document.getElementById('artist-badges');
                if (badgesContainer) {
                    badgesContainer.style.display = 'none';
                    badgesContainer.innerHTML = '';
                }

                // Сортируем отфильтрованных артистов по среднему месту и берем Топ-20
                const topArtists = [...filteredArtistsForGeneral]
                    .sort((a, b) => artistsHistory[a].avg_rank - artistsHistory[b].avg_rank)
                    .slice(0, 20);

                datasets = topArtists.map((art, index) => {
                    const color = `hsl(${(index * 360) / 20}, 70%, 50%)`;

                    let dataPoints = [];
                    if (artistName === 'cumulative') {
                        let sumScores = 0;
                        for (let m = 0; m < months.length; m++) {
                            const h = artistsHistory[art].history[m];
                            const scoreVal = (h && h.rank !== null && !h.penalty) ? (51 - h.rank) : 0;
                            sumScores += scoreVal;
                            dataPoints.push(sumScores / (m + 1));
                        }
                    } else if (artistName === 'avg_place_evolution') {
                        let sumRanks = 0;
                        let count = 0;
                        for (let m = 0; m < months.length; m++) {
                            const h = artistsHistory[art].history[m];
                            if (h && h.rank !== null) {
                                sumRanks += h.rank;
                                count++;
                                dataPoints.push(sumRanks / count);
                            } else {
                                dataPoints.push(null);
                            }
                        }
                    } else {
                        dataPoints = artistsHistory[art].history.map(h => h.rank);
                    }

                    return {
                        label: art,
                        data: dataPoints,
                        borderColor: color,
                        originalColor: color, // Store the original HSL color
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        pointRadius: 0, // Optimize points
                        pointHoverRadius: 5,
                        pointBackgroundColor: color,
                        pointBorderColor: '#FFF',
                        tension: 0.15,
                        fill: false
                    };
                });

                datasetsTracks = topArtists.map((art, index) => {
                    const color = `hsl(${(index * 360) / 20}, 70%, 50%)`;
                    let dataPoints = [];
                    if (artistName === 'avg_place_evolution') {
                        let sumRanks = 0;
                        let count = 0;
                        const trksAvg = artistsHistory[art].tracks_avg_history || [];
                        for (let m = 0; m < months.length; m++) {
                            const h = trksAvg[m];
                            if (m >= artistsHistory[art].debut_month) {
                                const rankVal = h ? h.rank : 51;
                                sumRanks += rankVal;
                                count++;
                                dataPoints.push(sumRanks / count);
                            } else {
                                dataPoints.push(null);
                            }
                        }
                    } else {
                        dataPoints = (artistsHistory[art].tracks_avg_history || []).map(h => h.rank);
                    }

                    return {
                        label: art,
                        data: dataPoints,
                        borderColor: color,
                        originalColor: color,
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        pointRadius: 0,
                        pointHoverRadius: 5,
                        pointBackgroundColor: color,
                        pointBorderColor: '#FFF',
                        tension: 0.15,
                        fill: false
                    };
                });
            } else {
                document.querySelector('.artist-stats-grid').style.display = 'grid';
                const artObj = artistsHistory[artistName];
                if (!artObj) return;

                // Update stats badges
                document.getElementById('stat-avg-rank').textContent = artObj.avg_rank;

                const debutMonth = months[artObj.debut_month] || 'Неизвестно';
                document.getElementById('stat-debut').textContent = debutMonth;

                let bestRank = Infinity;
                let activeMonthsCount = 0;
                artObj.history.forEach(h => {
                    if (h.rank !== null && !h.penalty) {
                        activeMonthsCount++;
                        if (h.rank < bestRank) {
                            bestRank = h.rank;
                        }
                    }
                });
                document.getElementById('stat-best-rank').textContent = bestRank === Infinity ? 'N/A' : `${bestRank}-е`;
                document.getElementById('stat-active-ratio').textContent = `${activeMonthsCount} из ${months.length}`;

                // Dynamic achievements rendering
                const badgesContainer = document.getElementById('artist-badges');
                if (badgesContainer) {
                    badgesContainer.innerHTML = '';
                    const artistAchievements = achievements[artistName] || [];
                    if (artistAchievements.length > 0) {
                        badgesContainer.style.display = 'flex';
                        artistAchievements.forEach(ach => {
                            let badgeClass = '';
                            let iconClass = '';
                            if (ach === 'Король камбэков') {
                                badgeClass = 'king-comeback';
                                iconClass = 'fas fa-crown';
                            } else if (ach === 'Чудо одного хита') {
                                badgeClass = 'one-hit';
                                iconClass = 'fas fa-bolt';
                            } else if (ach === 'Стабильный ветеран') {
                                badgeClass = 'stable-vet';
                                iconClass = 'fas fa-shield-alt';
                            } else if (ach === 'Абсолютный Доминатор') {
                                badgeClass = 'absolute-dominator';
                                iconClass = 'fas fa-fire';
                            } else if (ach === 'Царь Горы') {
                                badgeClass = 'king-of-hill';
                                iconClass = 'fas fa-mountain';
                            } else if (ach === 'Яркая Комета') {
                                badgeClass = 'comet-artist';
                                iconClass = 'fas fa-meteor';
                            } else if (ach === 'Владыка Недель') {
                                badgeClass = 'lord-of-weeks';
                                iconClass = 'fas fa-fort-awesome';
                            } else if (ach === 'Сверхзвуковой Взлет') {
                                badgeClass = 'rocket-rise';
                                iconClass = 'fas fa-rocket';
                            }

                            const badgeHtml = `
                                <div class="badge-achievement ${badgeClass}" title="${ach}">
                                    <i class="${iconClass}"></i>
                                    <span>${ach}</span>
                                </div>
                            `;
                            badgesContainer.insertAdjacentHTML('beforeend', badgeHtml);
                        });
                    } else {
                        badgesContainer.style.display = 'none';
                    }
                }

                const art2Value = document.getElementById('artistSelect2') ? document.getElementById('artistSelect2').value : '';
                const isDuelActive = art2Value !== '';

                const color = isDuelActive ? '#00F5FF' : '#1DB954';
                datasets = [{
                    label: artistName,
                    data: artObj.history.map(h => h.rank),
                    borderColor: color,
                    originalColor: color,
                    backgroundColor: isDuelActive ? 'rgba(0, 245, 255, 0.01)' : 'rgba(29, 185, 84, 0.05)',
                    borderWidth: isDuelActive ? 5 : 3,
                    pointRadius: isDuelActive ? 4 : 0,
                    pointHoverRadius: 6,
                    pointBackgroundColor: color,
                    pointBorderColor: '#FFF',
                    tension: 0.15,
                    fill: !isDuelActive,
                    segment: {
                        borderDash: ctx => {
                            const p0 = artObj.history[ctx.p0DataIndex];
                            const p1 = artObj.history[ctx.p1DataIndex];
                            return (p0 && p0.penalty) || (p1 && p1.penalty) ? [6, 6] : undefined;
                        },
                        borderColor: ctx => {
                            const p0 = artObj.history[ctx.p0DataIndex];
                            const p1 = artObj.history[ctx.p1DataIndex];
                            return (p0 && p0.penalty) || (p1 && p1.penalty) ? 'rgba(255, 60, 60, 0.4)' : undefined;
                        }
                    }
                }];

                const trackColor = isDuelActive ? '#00F5FF' : '#00F5FF';
                datasetsTracks = [{
                    label: artistName,
                    data: (artObj.tracks_avg_history || []).map(h => h.rank),
                    borderColor: trackColor,
                    originalColor: trackColor,
                    backgroundColor: isDuelActive ? 'rgba(0, 245, 255, 0.01)' : 'rgba(0, 245, 255, 0.05)',
                    borderWidth: isDuelActive ? 5 : 3,
                    pointRadius: isDuelActive ? 4 : 0,
                    pointHoverRadius: 6,
                    pointBackgroundColor: trackColor,
                    pointBorderColor: '#FFF',
                    tension: 0.15,
                    fill: !isDuelActive,
                    segment: {
                        borderDash: ctx => {
                            const p0 = artObj.tracks_avg_history[ctx.p0DataIndex];
                            const p1 = artObj.tracks_avg_history[ctx.p1DataIndex];
                            return (p0 && p0.penalty) || (p1 && p1.penalty) ? [6, 6] : undefined;
                        },
                        borderColor: ctx => {
                            const p0 = artObj.tracks_avg_history[ctx.p0DataIndex];
                            const p1 = artObj.tracks_avg_history[ctx.p1DataIndex];
                            return (p0 && p0.penalty) || (p1 && p1.penalty) ? 'rgba(255, 60, 60, 0.4)' : undefined;
                        }
                    }
                }];

                if (isDuelActive && artistsHistory[art2Value]) {
                    const art2Obj = artistsHistory[art2Value];
                    const color2 = '#ff007f';

                    datasets.push({
                        label: art2Value,
                        data: art2Obj.history.map(h => h.rank),
                        borderColor: color2,
                        originalColor: color2,
                        backgroundColor: 'rgba(255, 0, 127, 0.01)',
                        borderWidth: 5,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        pointBackgroundColor: color2,
                        pointBorderColor: '#FFF',
                        tension: 0.15,
                        fill: false,
                        segment: {
                            borderDash: ctx => {
                                const p0 = art2Obj.history[ctx.p0DataIndex];
                                const p1 = art2Obj.history[ctx.p1DataIndex];
                                return (p0 && p0.penalty) || (p1 && p1.penalty) ? [6, 6] : undefined;
                            },
                            borderColor: ctx => {
                                const p0 = art2Obj.history[ctx.p0DataIndex];
                                const p1 = art2Obj.history[ctx.p1DataIndex];
                                return (p0 && p0.penalty) || (p1 && p1.penalty) ? 'rgba(255, 60, 60, 0.4)' : undefined;
                            }
                        }
                    });

                    datasetsTracks.push({
                        label: art2Value,
                        data: (art2Obj.tracks_avg_history || []).map(h => h.rank),
                        borderColor: color2,
                        originalColor: color2,
                        backgroundColor: 'rgba(255, 0, 127, 0.01)',
                        borderWidth: 5,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        pointBackgroundColor: color2,
                        pointBorderColor: '#FFF',
                        tension: 0.15,
                        fill: false,
                        segment: {
                            borderDash: ctx => {
                                const p0 = art2Obj.tracks_avg_history[ctx.p0DataIndex];
                                const p1 = art2Obj.tracks_avg_history[ctx.p1DataIndex];
                                return (p0 && p0.penalty) || (p1 && p1.penalty) ? [6, 6] : undefined;
                            },
                            borderColor: ctx => {
                                const p0 = art2Obj.tracks_avg_history[ctx.p0DataIndex];
                                const p1 = art2Obj.tracks_avg_history[ctx.p1DataIndex];
                                return (p0 && p0.penalty) || (p1 && p1.penalty) ? 'rgba(255, 60, 60, 0.4)' : undefined;
                            }
                        }
                    });
                }
            }

            // Remove highlight classes from sidebar
            document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('highlighted', 'active'));

            const art2Value = document.getElementById('artistSelect2') ? document.getElementById('artistSelect2').value : '';
            const isGeneralMode = artistName === 'all' || artistName === 'cumulative' || artistName === 'avg_place_evolution';

            updateDatasetStyles = function (chart, hoveredIndex) {
                if (!chart) return;

                const hasDuelOpponent = art2Value !== '';

                chart.data.datasets.forEach((dataset, index) => {
                    const isArt1 = dataset.label === artistName || (isGeneralMode && hoveredIndex !== null && index === hoveredIndex);
                    const isArt2 = hasDuelOpponent && dataset.label === art2Value;

                    if (isArt1 || isArt2) {
                        dataset.borderWidth = 5;
                        dataset.pointRadius = 4;
                        dataset.borderColor = isArt2 ? '#ff007f' : (dataset.originalColor || dataset.borderColor);
                        dataset.hidden = false;

                        const artName = dataset.label;
                        const itemEl = document.querySelector(`.sidebar-item[data-artist="${artName}"]`);
                        if (itemEl) {
                            itemEl.classList.add('highlighted', 'active');
                            if (isArt1) scrollSidebarToElement(itemEl);
                        }
                    } else {
                        if (hasDuelOpponent || hoveredIndex !== null) {
                            dataset.hidden = true;
                        } else {
                            dataset.hidden = false;
                            dataset.borderWidth = isGeneralMode ? 2 : 3;
                            dataset.pointRadius = 0;
                            dataset.borderColor = dataset.originalColor || dataset.borderColor;
                        }
                    }
                });
                chart.update('none');
            };

            activeArtistChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: months,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    spanGaps: true, // Optimize span gaps
                    animation: {
                        duration: 800 // Animate on initial load only
                    },
                    elements: {
                        point: {
                            radius: 0, // No points rendered normally
                            hitRadius: 10,
                            hoverRadius: 5 // Point appears only on hover over the line
                        }
                    },
                    hover: {
                        mode: 'dataset',
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            display: artistName === 'all' || artistName === 'cumulative' || artistName === 'avg_place_evolution',
                            position: 'bottom',
                            onHover: null,
                            onLeave: null,
                            labels: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 10 },
                                boxWidth: 12
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const curArtist = (artistName === 'all' || artistName === 'cumulative' || artistName === 'avg_place_evolution') ? context.dataset.label : artistName;
                                    const monthName = context.label;
                                    const rank = context.raw;

                                    let isPenalty = false;
                                    if (artistName !== 'all' && artistName !== 'cumulative' && artistName !== 'avg_place_evolution') {
                                        const artObj = artistsHistory[artistName];
                                        const p = artObj.history[context.dataIndex];
                                        if (p && p.penalty) {
                                            isPenalty = true;
                                        }
                                    } else {
                                        if (rank === 51) {
                                            isPenalty = true;
                                        }
                                    }

                                    if (isPenalty) {
                                        return `${curArtist}: вылетел из топа (Штрафное место: ${rank})`;
                                    }

                                    const tracksList = (historyTracksMap[curArtist] && historyTracksMap[curArtist][monthName]) ? historyTracksMap[curArtist][monthName] : [];

                                    if (artistName === 'cumulative') {
                                        let baseMsg = `${curArtist}: ср. балл ${rank.toFixed(2)}`;
                                        if (tracksList.length > 0) {
                                            return `${baseMsg} (Треки: ${tracksList.join(', ')})`;
                                        }
                                        return baseMsg;
                                    } else if (artistName === 'avg_place_evolution') {
                                        let baseMsg = `${curArtist}: нак. ср. место ${rank.toFixed(2)}`;
                                        if (tracksList.length > 0) {
                                            return `${baseMsg} (Треки: ${tracksList.join(', ')})`;
                                        }
                                        return baseMsg;
                                    } else {
                                        if (tracksList.length > 0) {
                                            return `${curArtist}: ${rank} место (Треки: ${tracksList.join(', ')})`;
                                        }
                                        return `${curArtist}: ${rank} место`;
                                    }
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#B3B3B3', font: { family: 'Outfit', size: 11 } },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        },
                        y: {
                            reverse: artistName !== 'cumulative',
                            ticks: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit' },
                                stepSize: 1
                            },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        }
                    }
                }
            });

            activeArtistTracksChart = new Chart(ctxTracks, {
                type: 'line',
                data: {
                    labels: months,
                    datasets: datasetsTracks
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    spanGaps: true,
                    animation: {
                        duration: 800
                    },
                    elements: {
                        point: {
                            radius: 0,
                            hitRadius: 10,
                            hoverRadius: 5
                        }
                    },
                    hover: {
                        mode: 'dataset',
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            display: artistName === 'all' || artistName === 'cumulative' || artistName === 'avg_place_evolution',
                            position: 'bottom',
                            onHover: null,
                            onLeave: null,
                            labels: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 10 },
                                boxWidth: 12
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const curArtist = (artistName === 'all' || artistName === 'cumulative' || artistName === 'avg_place_evolution') ? context.dataset.label : artistName;
                                    const monthName = context.label;
                                    const rank = context.raw;

                                    let isPenalty = false;
                                    if (artistName !== 'all' && artistName !== 'cumulative' && artistName !== 'avg_place_evolution') {
                                        const artObj = artistsHistory[artistName];
                                        const p = artObj.tracks_avg_history[context.dataIndex];
                                        if (p && p.penalty) {
                                            isPenalty = true;
                                        }
                                    } else {
                                        if (rank === 51) {
                                            isPenalty = true;
                                        }
                                    }

                                    if (isPenalty) {
                                        return `${curArtist}: нет треков в топе (Штрафное место: ${rank})`;
                                    }

                                    const tracksList = (historyTracksMap[curArtist] && historyTracksMap[curArtist][monthName]) ? historyTracksMap[curArtist][monthName] : [];

                                    if (artistName === 'avg_place_evolution') {
                                        let baseMsg = `${curArtist}: нак. ср. место треков ${rank.toFixed(2)}`;
                                        if (tracksList.length > 0) {
                                            return `${baseMsg} (Треки: ${tracksList.join(', ')})`;
                                        }
                                        return baseMsg;
                                    } else {
                                        let baseMsg = `${curArtist}: ср. место треков ${typeof rank === 'number' ? rank.toFixed(1) : rank}`;
                                        if (tracksList.length > 0) {
                                            return `${baseMsg} (Треки: ${tracksList.join(', ')})`;
                                        }
                                        return baseMsg;
                                    }
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#B3B3B3', font: { family: 'Outfit', size: 11 } },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        },
                        y: {
                            reverse: true,
                            ticks: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit' },
                                stepSize: 1
                            },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        }
                    }
                }
            });

            // Immediately set duration to 0 so all subsequent updates are instant and lag-free!
            activeArtistChart.options.animation.duration = 0;
            activeArtistTracksChart.options.animation.duration = 0;
        }

        // Helper function to scroll only the sidebar container without moving the browser window
        function scrollSidebarToElement(el) {
            const container = document.getElementById('sidebarArtistList');
            if (!container || !el) return;

            const containerTop = container.getBoundingClientRect().top;
            const containerBottom = container.getBoundingClientRect().bottom;
            const elemTop = el.getBoundingClientRect().top;
            const elemBottom = el.getBoundingClientRect().bottom;

            // Check if element is already fully visible inside container
            if (elemTop >= containerTop && elemBottom <= containerBottom) {
                return; // Already in view
            }

            // Calculate new scrollTop
            const relativeTop = el.offsetTop - container.offsetTop;
            container.scrollTo({
                top: relativeTop - (container.clientHeight / 2) + (el.clientHeight / 2),
                behavior: 'smooth'
            });
        }

        let sidebarSortMode = 'rank'; // 'rank' or 'alpha'

        function renderSidebarArtists() {
            const listEl = document.getElementById('sidebarArtistList');
            if (!listEl) return;
            listEl.innerHTML = '';

            // Get original order by rank first to determine rank index for each artist
            const artistsByRank = Object.keys(artistsHistory)
                .sort((a, b) => artistsHistory[a].avg_rank - artistsHistory[b].avg_rank);

            // Map each artist to its rank (1-indexed) so it stays constant regardless of current sort order
            const artistRanks = {};
            artistsByRank.forEach((art, index) => {
                artistRanks[art] = index + 1;
            });

            let sortedAllArtists = [...artistsByRank];
            if (sidebarSortMode === 'alpha') {
                sortedAllArtists.sort((a, b) => a.localeCompare(b, 'ru', { sensitivity: 'base' }));
            }

            sortedAllArtists.forEach((art) => {
                const artObj = artistsHistory[art];
                const rankValue = artistRanks[art];

                const itemEl = document.createElement('div');
                itemEl.className = 'sidebar-item';
                if (artistSelect && artistSelect.value === art) {
                    itemEl.className = 'sidebar-item highlighted';
                }
                itemEl.setAttribute('data-artist', art);

                itemEl.innerHTML = `
                    <div class="sidebar-item-left">
                        <span class="sidebar-item-rank">${rankValue}</span>
                        <span class="sidebar-item-name" title="${art}">${art}</span>
                    </div>
                    <span class="sidebar-item-score">${artObj.avg_rank}</span>
                `;

                itemEl.addEventListener('click', (e) => {
                    e.preventDefault();

                    if (activeArtistChart && (artistSelect.value === 'all' || artistSelect.value === 'cumulative' || artistSelect.value === 'avg_place_evolution')) {
                        const datasetIdx = activeArtistChart.data.datasets.findIndex(ds => ds.label === art);
                        if (datasetIdx !== -1) {
                            if (hoveredDatasetIndex === datasetIdx) {
                                // Repeat click: remove focus
                                hoveredDatasetIndex = null;
                                updateDatasetStyles(activeArtistChart, null);
                                updateDatasetStyles(activeArtistTracksChart, null);
                                document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('highlighted', 'active'));
                            } else {
                                // New selection: focus this artist
                                hoveredDatasetIndex = datasetIdx;
                                updateDatasetStyles(activeArtistChart, datasetIdx);
                                updateDatasetStyles(activeArtistTracksChart, datasetIdx);
                                document.querySelectorAll('.sidebar-item').forEach(el => {
                                    if (el.getAttribute('data-artist') === art) {
                                        el.classList.add('highlighted', 'active');
                                    } else {
                                        el.classList.remove('highlighted', 'active');
                                    }
                                });
                            }
                        }
                    } else {
                        // Fallback behavior if single artist mode is active
                        if (artistSelect) {
                            artistSelect.value = art;
                            artistSelect.dispatchEvent(new Event('change'));
                        }
                    }
                });

                listEl.appendChild(itemEl);
            });
        }

        function renderSidebarTracks() {
            const listEl = document.getElementById('sidebarTrackList');
            if (!listEl) return;
            listEl.innerHTML = '';

            if (!topTracksHistory || topTracksHistory.length === 0) {
                listEl.innerHTML = `
                    <div style="text-align: center; padding: 30px 10px; color: var(--text-muted); font-size: 13px;">
                        Нет треков с 3+ попаданиями
                    </div>
                `;
                return;
            }

            topTracksHistory.forEach((t, idx) => {
                const itemEl = document.createElement('div');
                itemEl.className = 'sidebar-item';
                itemEl.style.cursor = 'pointer';
                itemEl.style.padding = '8px 10px';
                itemEl.style.gap = '8px';

                itemEl.innerHTML = `
                    <div class="sidebar-item-left" style="display: flex; align-items: center; gap: 10px; overflow: hidden; width: calc(100% - 70px);">
                        <span class="sidebar-item-rank">${idx + 1}</span>
                        <div style="display: flex; flex-direction: column; overflow: hidden;">
                            <span class="sidebar-item-name" style="font-weight: 600; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${t.name}">${t.name}</span>
                            <span class="sidebar-item-artist" style="font-size: 11px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${t.artist}</span>
                        </div>
                    </div>
                    <div class="sidebar-item-score" style="display: flex; flex-direction: column; align-items: flex-end; justify-content: center; flex-shrink: 0; min-width: 60px;">
                        <span style="font-size: 11px; font-weight: 700; color: var(--spotify-green);">${t.appearances_count} мес.</span>
                        <span style="font-size: 9px; color: var(--text-muted); font-weight: 500;">Ср: ${t.avg_rank}</span>
                    </div>
                `;

                itemEl.addEventListener('click', (event) => {
                    openDetailsModal(event, t.id);
                });

                listEl.appendChild(itemEl);
            });
        }

        // Event listener for artistSelect change
        artistSelect.addEventListener('change', (e) => {
            hoveredDatasetIndex = null; // Reset highlights when dropdown changes
            updateArtistEvolution(e.target.value);
            updateDuelRadarChart();
            highlightHeatmapRow(e.target.value);
            // Highlight selected artist item in sidebar
            document.querySelectorAll('.sidebar-item').forEach(el => {
                if (el.getAttribute('data-artist') === e.target.value) {
                    el.classList.add('highlighted', 'active');
                    scrollSidebarToElement(el);
                } else {
                    el.classList.remove('highlighted', 'active');
                }
            });
        });

        // Event listener for artistSelect2 change
        if (artistSelect2) {
            artistSelect2.addEventListener('change', () => {
                const art1Val = artistSelect.value;
                const isGeneral = art1Val === 'all' || art1Val === 'cumulative' || art1Val === 'avg_place_evolution';

                if (isGeneral && artistSelect2.value !== '') {
                    // Auto-pair with first available artist that is not the selected opponent
                    const defaultArt = sortedArtists.find(art => art !== artistSelect2.value) || sortedArtists[0];
                    if (defaultArt) {
                        artistSelect.value = defaultArt;
                    }
                }

                updateArtistEvolution(artistSelect.value);
                updateDuelRadarChart();
                highlightHeatmapRow(artistSelect.value);
            });
        }

        // Setup Sidebar Sort Listeners
        const sortByRankBtn = document.getElementById('sort-by-rank');
        const sortByAlphaBtn = document.getElementById('sort-by-alpha');

        if (sortByRankBtn && sortByAlphaBtn) {
            sortByRankBtn.addEventListener('click', (e) => {
                e.preventDefault();
                if (sidebarSortMode !== 'rank') {
                    sidebarSortMode = 'rank';
                    sortByRankBtn.classList.add('active');
                    sortByAlphaBtn.classList.remove('active');
                    renderSidebarArtists();
                }
            });

            sortByAlphaBtn.addEventListener('click', (e) => {
                e.preventDefault();
                if (sidebarSortMode !== 'alpha') {
                    sidebarSortMode = 'alpha';
                    sortByAlphaBtn.classList.add('active');
                    sortByRankBtn.classList.remove('active');
                    renderSidebarArtists();
                }
            });
        }

        let activeVibeDnaChart = null;
        function initVibeDnaChart() {
            const canvasEl = document.getElementById('vibeDnaChart');
            if (!canvasEl) return;
            const ctx = canvasEl.getContext('2d');
            if (activeVibeDnaChart) {
                activeVibeDnaChart.destroy();
            }

            activeVibeDnaChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: months,
                    datasets: [
                        {
                            label: '🎵 BPM (Темп)',
                            data: vibeBpm,
                            borderColor: '#00F5FF',
                            backgroundColor: 'transparent',
                            borderWidth: 3,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            pointBackgroundColor: '#00F5FF',
                            pointBorderColor: '#FFF',
                            yAxisID: 'yBPM',
                            tension: 0.4,
                            fill: false
                        },
                        {
                            label: '⚡ Энергия',
                            data: vibeEnergy,
                            borderColor: '#A020F0',
                            backgroundColor: 'transparent',
                            borderWidth: 3,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            pointBackgroundColor: '#A020F0',
                            pointBorderColor: '#FFF',
                            yAxisID: 'yPercentage',
                            tension: 0.4,
                            fill: false
                        },
                        {
                            label: '☀️ Настроение (Позитив)',
                            data: vibeValence,
                            borderColor: '#FFD700',
                            backgroundColor: 'transparent',
                            borderWidth: 3,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            pointBackgroundColor: '#FFD700',
                            pointBorderColor: '#FFF',
                            yAxisID: 'yPercentage',
                            tension: 0.4,
                            fill: false
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    spanGaps: true,
                    animation: {
                        duration: 800
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom',
                            labels: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 11, weight: '500' },
                                boxWidth: 12
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const val = context.raw;
                                    if (context.datasetIndex === 0) {
                                        return `${context.dataset.label}: ${val} ударов/мин`;
                                    } else {
                                        return `${context.dataset.label}: ${Math.round(val * 100)}%`;
                                    }
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#B3B3B3', font: { family: 'Outfit', size: 11 } },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        },
                        yBPM: {
                            type: 'linear',
                            position: 'left',
                            min: 60,
                            max: 180,
                            ticks: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 10 }
                            },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            title: {
                                display: true,
                                text: 'Темп (BPM)',
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 11, weight: '600' }
                            }
                        },
                        yPercentage: {
                            type: 'linear',
                            position: 'right',
                            min: 0,
                            max: 1,
                            ticks: {
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 10 },
                                callback: function (value) {
                                    return Math.round(value * 100) + '%';
                                }
                            },
                            grid: {
                                drawOnChartArea: false
                            },
                            title: {
                                display: true,
                                text: 'Характеристики (0% - 100%)',
                                color: '#B3B3B3',
                                font: { family: 'Outfit', size: 11, weight: '600' }
                            }
                        }
                    }
                }
            });
        }

        if (sortedArtists.length > 0) {
            artistSelect.value = 'all';
            updateArtistEvolution('all');
            renderSidebarArtists();
            updateDuelRadarChart();
            renderHeatmap();
        }
        renderSidebarTracks();
        initVibeDnaChart();

        // Chart Width Scaling Slider
        const chartWidthSlider = document.getElementById('chartWidthSlider');
        const widthValueDisplay = document.getElementById('widthValue');
        const chartScrollWrapper = document.getElementById('chartScrollWrapper');
        const chartTracksScrollWrapper = document.getElementById('chartTracksScrollWrapper');
        const chartVibeDnaScrollWrapper = document.getElementById('chartVibeDnaScrollWrapper');

        if (chartWidthSlider && widthValueDisplay && chartScrollWrapper) {
            chartWidthSlider.addEventListener('input', (e) => {
                const widthPercent = e.target.value;
                widthValueDisplay.textContent = `${widthPercent}%`;
                chartScrollWrapper.style.width = `${widthPercent}%`;
                if (chartTracksScrollWrapper) {
                    chartTracksScrollWrapper.style.width = `${widthPercent}%`;
                }
                if (chartVibeDnaScrollWrapper) {
                    chartVibeDnaScrollWrapper.style.width = `${widthPercent}%`;
                }
                if (activeArtistChart) {
                    activeArtistChart.resize();
                }
                if (activeArtistTracksChart) {
                    activeArtistTracksChart.resize();
                }
                if (activeVibeDnaChart) {
                    activeVibeDnaChart.resize();
                }
            });
        }

        function openDetailsByNameAndArtist(name, artist) {
            if (!name || name === '—') return;
            
            // Clean playcount suffixes like "SHINOBI - 3"
            let cleanName = name.replace(/\s*-\s*\d+$/, '').trim().toLowerCase();
            let cleanArtist = (artist || '').trim().toLowerCase();
            
            let track = tracks.find(t => {
                const tName = t.name.toLowerCase();
                const tArtist = t.artist.toLowerCase();
                if (cleanArtist) {
                    return tName === cleanName && (tArtist.includes(cleanArtist) || cleanArtist.includes(tArtist));
                }
                return tName === cleanName || tName.includes(cleanName) || cleanName.includes(tName);
            });
            
            // Fallback: search anywhere in track name / artist combination
            if (!track) {
                track = tracks.find(t => {
                    const combined = (t.artist + ' - ' + t.name).toLowerCase();
                    return combined.includes(cleanName);
                });
            }
            
            if (track) {
                openDetailsModal(null, track.id);
            } else {
                console.warn(`Track details not found for: ${name} by ${artist}`);
                alert(`Сведения о треке "${name}" не найдены в основном архиве.`);
            }
        }

        function getSimilarTracks(currentTrack, count = 3) {
            if (!currentTrack || !tracks || !Array.isArray(tracks)) return [];
            
            const currentVibe = currentTrack.vibe || 'Unknown';
            const currentBpm = parseFloat(currentTrack.bpm) || 120;
            const currentEnergy = (currentTrack.energy === 'N/A' || currentTrack.energy === null || currentTrack.energy === undefined) ? 0.5 : parseFloat(currentTrack.energy);
            const currentValence = (currentTrack.valence === 'N/A' || currentTrack.valence === null || currentTrack.valence === undefined) ? 0.5 : parseFloat(currentTrack.valence);
            const currentDanceability = (currentTrack.danceability === 'N/A' || currentTrack.danceability === null || currentTrack.danceability === undefined) ? 0.5 : parseFloat(currentTrack.danceability);

            // Filter out the current track itself and any tracks with invalid name/artist
            const candidates = tracks.filter(t => t && t.id && t.id !== currentTrack.id && t.name && t.artist);

            // Calculate score for each candidate track
            const scored = candidates.map(t => {
                let score = 0;

                // Vibe match (30% weight)
                if (t.vibe === currentVibe) {
                    score += 30;
                }

                // Energy similarity (20% weight)
                const energyVal = (t.energy === 'N/A' || t.energy === null || t.energy === undefined) ? 0.5 : parseFloat(t.energy);
                const energyDiff = Math.abs(energyVal - currentEnergy);
                score += Math.max(0, 20 * (1 - energyDiff));

                // Valence similarity (20% weight)
                const valenceVal = (t.valence === 'N/A' || t.valence === null || t.valence === undefined) ? 0.5 : parseFloat(t.valence);
                const valenceDiff = Math.abs(valenceVal - currentValence);
                score += Math.max(0, 20 * (1 - valenceDiff));

                // BPM similarity (15% weight)
                const tBpm = parseFloat(t.bpm) || 120;
                const bpmDiff = Math.abs(tBpm - currentBpm);
                // Normalize: a difference of 30+ BPM yields 0 score
                score += Math.max(0, 15 * (1 - (bpmDiff / 30)));

                // Danceability similarity (15% weight)
                const danceVal = (t.danceability === 'N/A' || t.danceability === null || t.danceability === undefined) ? 0.5 : parseFloat(t.danceability);
                const danceDiff = Math.abs(danceVal - currentDanceability);
                score += Math.max(0, 15 * (1 - danceDiff));

                // Artist matching - boost slightly to keep recommendations diverse!
                if (t.artist === currentTrack.artist) {
                    score += 10;
                }

                return { track: t, score: score };
            });

            // Sort by score descending and take the top ones
            scored.sort((a, b) => b.score - a.score);
            return scored.slice(0, count).map(x => x.track);
        }

        function openDetailsModal(event, trackId) {
            if (event && event.target) {
                const target = event.target;
                if (target.closest('.copy-gemini-btn') || target.closest('.preview-btn') || target.closest('.track-title-link')) {
                    return;
                }
            }

            const track = tracks.find(t => t.id === trackId);
            if (!track) return;

            const modal = document.getElementById('detailsModal');
            const content = document.getElementById('modalContent');

            // Generate HSL placeholder or cover image
            let albumArtHtml = '';
            if (track.album_art && track.album_art !== 'N/A' && !track.album_art.includes('placeholder')) {
                albumArtHtml = `<img src="${track.album_art}" alt="${track.album}">`;
            } else {
                let hash1 = 0;
                const str1 = track.artist || "";
                for (let i = 0; i < str1.length; i++) {
                    hash1 = str1.charCodeAt(i) + ((hash1 << 5) - hash1);
                }
                let hash2 = 0;
                const str2 = track.name || "";
                for (let i = 0; i < str2.length; i++) {
                    hash2 = str2.charCodeAt(i) + ((hash2 << 5) - hash2);
                }
                const h1 = Math.abs(hash1) % 360;
                const h2 = Math.abs(hash2) % 360;
                const grad = `linear-gradient(135deg, hsl(${h1}, 75%, 45%) 0%, hsl(${h2}, 60%, 20%) 100%)`;
                const initial = track.artist ? track.artist.charAt(0).toUpperCase() : '🎵';
                albumArtHtml = `
                    <div class="modal-cover-placeholder" style="background: ${grad}">
                        ${initial}
                    </div>
                `;
            }

            // Mapped playlists
            const playlistsList = track.playlists || [];
            let playlistsHtml = '';
            if (playlistsList.length > 0) {
                playlistsHtml = playlistsList.map(pl => `<span class="playlist-tag">${pl}</span>`).join(' ');
            } else {
                playlistsHtml = '<span class="playlist-tag empty">Нет</span>';
            }

            const vibeIcons = {
                'Party': '🔥 Танцевальный',
                'Chill': '🌌 Расслабляющий',
                'Melancholic': '🎭 Грустный',
                'Focus': '🚀 Фокус',
                'Dark': '🖤 Темный',
                'Unknown': '🎵 Неизвестно'
            };
            const vibeLabel = vibeIcons[track.vibe] || track.vibe || '🎵 Неизвестно';

            let addedAtHtml = '';
            if (track.added_at && track.added_at !== 'Неизвестно' && track.added_at !== 'NaT' && track.added_at !== 'NaN' && track.added_at !== 'null') {
                addedAtHtml = `<span><i class="far fa-calendar-alt"></i> <b>Добавлен:</b> ${track.added_at}</span>`;
            }

            let avgRankModalHtml = '';
            if (track.avg_rank && track.avg_rank !== 'N/A' && track.avg_rank !== 'NaN' && track.avg_rank !== 'null') {
                avgRankModalHtml = `<span><i class="fas fa-trophy"></i> <b>Ср. Место:</b> ${track.avg_rank}</span>`;
            }

            let appearancesModalHtml = '';
            const appCount = (track.history_ranks || []).length;
            if (appCount > 0) {
                appearancesModalHtml = `<span><i class="fas fa-calendar-check"></i> <b>Топ месяцев:</b> ${appCount}</span>`;
            }

            // Compute track achievements dynamically for details modal
            let trackAchievementsHtml = '';

            // 1. Абсолютный Бестселлер (6+ months)
            if (appCount >= 6) {
                trackAchievementsHtml += `<span class="badge-achievement absolute-dominator" style="font-size: 12px; padding: 4px 12px; border-radius: 12px; height: auto;" title="Абсолютный Бестселлер: трек удерживался в чартах более 6 месяцев!"><i class="fas fa-fire"></i> Бестселлер</span>`;
            }

            // 2. Танцевальный Ураган (danceability >= 0.85 & energy >= 0.85)
            const energyVal = track.energy === 'N/A' ? 0.0 : track.energy;
            if (track.danceability >= 0.85 && energyVal >= 0.85) {
                trackAchievementsHtml += `<span class="badge-achievement one-hit" style="font-size: 12px; padding: 4px 12px; border-radius: 12px; height: auto;" title="Танцевальный Ураган: невероятный заряд энергии и танцевального вайба!"><i class="fas fa-bolt"></i> Ураган</span>`;
            }

            // 3. Абсолютный Дзен (vibe === Chill & valence <= 0.3)
            if (track.vibe === 'Chill' && track.valence <= 0.3) {
                trackAchievementsHtml += `<span class="badge-achievement stable-vet" style="font-size: 12px; padding: 4px 12px; border-radius: 12px; height: auto;" title="Абсолютный Дзен: глубочайший меланхоличный чилл-вайб для полного погружения."><i class="fas fa-cloud-moon"></i> Дзен</span>`;
            }

            // Compute similar tracks (Chosic style)
            const similarTracks = getSimilarTracks(track, 3);
            let similarTracksHtml = '';
            if (similarTracks.length > 0) {
                const similarCardsHtml = similarTracks.map(t => {
                    let miniArtHtml = '';
                    if (t.album_art && t.album_art !== 'N/A' && !t.album_art.includes('placeholder')) {
                        miniArtHtml = `<img src="${t.album_art}" alt="${t.name.replace(/"/g, '&quot;')}" style="width: 36px; height: 36px; border-radius: 6px; object-fit: cover; flex-shrink: 0;">`;
                    } else {
                        let hash = 0;
                        const str = t.artist || "";
                        for (let i = 0; i < str.length; i++) {
                            hash = str.charCodeAt(i) + ((hash << 5) - hash);
                        }
                        const h = Math.abs(hash) % 360;
                        const grad = `linear-gradient(135deg, hsl(${h}, 70%, 40%) 0%, hsl(${(h+40)%360}, 50%, 15%) 100%)`;
                        const initial = t.artist ? t.artist.charAt(0).toUpperCase() : '🎵';
                        miniArtHtml = `
                            <div style="width: 36px; height: 36px; border-radius: 6px; background: ${grad}; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; color: #fff; flex-shrink: 0;">
                                ${initial}
                            </div>
                        `;
                    }

                    const isMinor = (t.key || '').includes("Минор");
                    const keyDisplay = t.key ? `<span style="font-size: 9.5px; color: ${isMinor ? '#FF6B6B' : 'var(--spotify-green)'}; font-weight: 700;">${t.key}</span>` : '';

                    return `
                        <div onclick="openDetailsModal(null, '${t.id}')" class="mini-recommend-card" style="display: flex; gap: 8px; align-items: center; background: rgba(255,255,255,0.02); border: 1px solid var(--panel-border); padding: 6px 8px; border-radius: 8px; cursor: pointer; transition: all 0.2s; min-width: 0;" onmouseover="this.style.background='var(--panel-bg)'; this.style.borderColor='var(--spotify-green)';" onmouseout="this.style.background='rgba(255,255,255,0.02)'; this.style.borderColor='var(--panel-border)';">
                            ${miniArtHtml}
                            <div style="overflow: hidden; flex-grow: 1; min-width: 0;">
                                <div style="font-size: 11.5px; font-weight: 700; color: var(--text-light); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: left;" title="${t.name.replace(/"/g, '&quot;')}">${t.name}</div>
                                <div style="font-size: 10px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 1px; text-align: left;">${t.artist}</div>
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2px;">
                                    ${keyDisplay}
                                    <span style="font-size: 9px; color: var(--text-muted); font-style: italic;">${t.bpm && t.bpm !== 'N/A' ? t.bpm + ' BPM' : ''}</span>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');

                similarTracksHtml = `
                    <div class="modal-similar-section" style="margin-top: 15px; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 12px; width: 100%;">
                        <div style="font-size: 11px; font-weight: 700; color: var(--spotify-green); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                            <i class="fas fa-magic" style="color: var(--spotify-green); filter: drop-shadow(0 0 5px rgba(29, 185, 84, 0.4));"></i> 🔮 Рекомендации Chosic: Похожие треки по вайбу
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; width: 100%;">
                            ${similarCardsHtml}
                        </div>
                    </div>
                `;
            }

            // Modal Body HTML construction
            content.innerHTML = `
                <div class="modal-body">
                    <div class="modal-left">
                        <div class="modal-cover">
                            ${albumArtHtml}
                        </div>
                        <div class="card-badges" style="justify-content: center; margin-top: 15px; flex-wrap: wrap; gap: 8px;">
                            <span class="${track.key.includes('Минор') ? 'badge-key minor' : 'badge-key'}">
                                ${track.key.includes('Минор') ? '<i class="fas fa-violin"></i>' : '<i class="fas fa-sun"></i>'} 
                                ${track.key} ${track.camelot_key && track.camelot_key !== 'N/A' ? '[' + track.camelot_key + ']' : ''}
                            </span>
                            <span class="badge badge-vibe" style="font-size: 12px; padding: 4px 12px; border-radius: 12px; display: inline-flex; align-items: center; gap: 6px;"><i class="fas fa-yin-yang"></i> ${vibeLabel}</span>
                            ${trackAchievementsHtml}
                        </div>
                    </div>
                    <div class="modal-right">
                        <div style="display: flex; align-items: center; gap: 12px; width: 100%; flex-wrap: wrap; margin-bottom: 2px;">
                            <h2 class="modal-title" style="margin: 0; line-height: 1.2;">${track.name}</h2>
                            <button class="favorite-btn ${isFavorite(track.id) ? 'active' : ''}" 
                                    onclick="toggleFavorite(event, '${track.id}')"
                                    title="${isFavorite(track.id) ? 'Удалить из избранного' : 'Добавить в избранное'}"
                                    style="position: static; width: 32px; height: 32px; font-size: 14px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-top: 2px;">
                                <i class="${isFavorite(track.id) ? 'fas' : 'far'} fa-heart"></i>
                            </button>
                        </div>
                        <div class="modal-artist">${track.artist}</div>
                        <div class="modal-album"><i class="fas fa-compact-disc"></i> Альбом: ${track.album}</div>
                        
                        <div style="font-size: 14px; color: var(--text-muted); margin-top: 5px; display: flex; gap: 15px; flex-wrap: wrap;">
                            <span><i class="fas fa-tachometer-alt"></i> <b>BPM:</b> ${track.bpm}</span>
                            <span><i class="fas fa-fire"></i> <b>Популярность:</b> ${track.popularity}%</span>
                            <span><i class="fas fa-yin-yang"></i> <b>Вайб:</b> ${vibeLabel}</span>
                            ${addedAtHtml}
                            ${avgRankModalHtml}
                            ${appearancesModalHtml}
                        </div>

                        <div class="modal-playlists-section">
                            <div class="modal-playlists-title">
                                <i class="fas fa-list-ul"></i> В плейлистах:
                            </div>
                            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                                ${playlistsHtml}
                            </div>
                        </div>

                        <div class="modal-features">
                            <!-- Danceability -->
                            <div class="feature-row">
                                <span class="feature-name">🕺 Ритмичность</span>
                                <div class="feature-bar-wrapper">
                                    <div class="feature-bar-fill fill-dance" id="bar-dance"></div>
                                </div>
                                <span class="feature-val">${Math.round(track.danceability * 100)}%</span>
                            </div>
                            <!-- Energy -->
                            <div class="feature-row">
                                <span class="feature-name">⚡ Энергия</span>
                                <div class="feature-bar-wrapper">
                                    <div class="feature-bar-fill fill-energy" id="bar-energy"></div>
                                </div>
                                <span class="feature-val">${track.energy === 'N/A' ? 'N/A' : Math.round(track.energy * 100) + '%'}</span>
                            </div>
                            <!-- Valence -->
                            <div class="feature-row">
                                <span class="feature-name">☀️ Позитив</span>
                                <div class="feature-bar-wrapper">
                                    <div class="feature-bar-fill fill-valence" id="bar-valence"></div>
                                </div>
                                <span class="feature-val">${Math.round(track.valence * 100)}%</span>
                            </div>
                            <!-- Acousticness -->
                            <div class="feature-row">
                                <span class="feature-name">🎻 Акустичность</span>
                                <div class="feature-bar-wrapper">
                                    <div class="feature-bar-fill fill-acoustic" id="bar-acoustic"></div>
                                </div>
                                <span class="feature-val">${Math.round(track.acousticness * 100)}%</span>
                            </div>
                            <!-- Instrumentalness -->
                            <div class="feature-row">
                                <span class="feature-name">🎹 Инструментал</span>
                                <div class="feature-bar-wrapper">
                                    <div class="feature-bar-fill fill-instrumental" id="bar-instrumental"></div>
                                </div>
                                <span class="feature-val">${Math.round(track.instrumentalness * 100)}%</span>
                            </div>
                        </div>
                        ${similarTracksHtml}
                    </div>
                </div>
            `;

            modal.classList.add('active');
            document.body.classList.add('modal-active');

            // Animate bar fills in the next paint frame
            setTimeout(() => {
                const barDance = document.getElementById('bar-dance');
                const barEnergy = document.getElementById('bar-energy');
                const barValence = document.getElementById('bar-valence');
                const barAcoustic = document.getElementById('bar-acoustic');
                const barInstrumental = document.getElementById('bar-instrumental');

                if (barDance) barDance.style.width = `${Math.round(track.danceability * 100)}%`;
                if (barEnergy) barEnergy.style.width = track.energy === 'N/A' ? '0%' : `${Math.round(track.energy * 100)}%`;
                if (barValence) barValence.style.width = `${Math.round(track.valence * 100)}%`;
                if (barAcoustic) barAcoustic.style.width = `${Math.round(track.acousticness * 100)}%`;
                if (barInstrumental) barInstrumental.style.width = `${Math.round(track.instrumentalness * 100)}%`;
            }, 50);
        }

        function closeDetailsModal(event) {
            document.getElementById('detailsModal').classList.remove('active');
            document.body.classList.remove('modal-active');
        }

        let activeAchievementsTab = 'artists';

        function switchAchievementsTab(tab) {
            activeAchievementsTab = tab;

            const btnArtists = document.getElementById('achTabArtists');
            const btnSongs = document.getElementById('achTabSongs');
            if (btnArtists && btnSongs) {
                if (tab === 'artists') {
                    btnArtists.style.background = 'var(--spotify-green)';
                    btnArtists.style.color = '#000';
                    btnArtists.style.border = 'none';

                    btnSongs.style.background = 'rgba(255,255,255,0.05)';
                    btnSongs.style.color = '#fff';
                    btnSongs.style.border = '1px solid rgba(255,255,255,0.1)';
                } else {
                    btnSongs.style.background = 'var(--spotify-green)';
                    btnSongs.style.color = '#000';
                    btnSongs.style.border = 'none';

                    btnArtists.style.background = 'rgba(255,255,255,0.05)';
                    btnArtists.style.color = '#fff';
                    btnArtists.style.border = '1px solid rgba(255,255,255,0.1)';
                }
            }

            renderAchievementsBody();
        }

        function renderAchievementsBody() {
            const body = document.getElementById('achievementsModalBody');
            if (!body) return;
            body.innerHTML = '';

            if (activeAchievementsTab === 'artists') {
                if (Object.keys(achievementsDetailed).length === 0) {
                    body.innerHTML = `<div style="text-align: center; color: var(--text-muted); padding: 40px; font-family: 'Outfit', sans-serif;">К сожалению, пока никто из артистов не заработал особых наград.</div>`;
                    return;
                }

                let html = '';
                Object.keys(achievementsDetailed).sort().forEach(artist => {
                    const list = achievementsDetailed[artist] || [];
                    if (list.length === 0) return;

                    html += `
                        <div class="artist-achievement-row" style="margin-bottom: 20px; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); padding: 16px; border-radius: 12px;">
                            <h3 style="margin: 0 0 12px 0; font-size: 16px; color: var(--spotify-green); display: flex; align-items: center; gap: 8px; font-weight: 700; font-family: 'Outfit', sans-serif;">
                                <i class="fas fa-users"></i> ${artist}
                            </h3>
                            <div style="display: flex; flex-direction: column; gap: 10px;">
                    `;

                    list.forEach(ach => {
                        let borderCol = '#00F5FF';
                        let iconColor = '#00F5FF';
                        if (ach.class === 'king-comeback') {
                            borderCol = '#FFD700';
                            iconColor = '#FFD700';
                        } else if (ach.class === 'one-hit') {
                            borderCol = '#BF5FFF';
                            iconColor = '#BF5FFF';
                        } else if (ach.class === 'absolute-dominator') {
                            borderCol = '#FF5722';
                            iconColor = '#FF5722';
                        } else if (ach.class === 'king-of-hill') {
                            borderCol = '#FFB300';
                            iconColor = '#FFB300';
                        } else if (ach.class === 'comet-artist') {
                            borderCol = '#FF9100';
                            iconColor = '#FF9100';
                        } else if (ach.class === 'lord-of-weeks') {
                            borderCol = '#00E676';
                            iconColor = '#00E676';
                        } else if (ach.class === 'rocket-rise') {
                            borderCol = '#E040FB';
                            iconColor = '#E040FB';
                        }

                        html += `
                            <div style="display: flex; gap: 12px; background: rgba(0, 0, 0, 0.2); padding: 12px; border-radius: 8px; border-left: 4px solid ${borderCol};">
                                <div style="font-size: 16px; color: ${iconColor}; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; background: rgba(255,255,255,0.03); border-radius: 50%; flex-shrink: 0;">
                                    <i class="${ach.icon}"></i>
                                </div>
                                <div style="flex-grow: 1;">
                                    <h4 style="margin: 0; font-size: 14px; color: #fff; font-weight: 700; font-family: 'Outfit', sans-serif;">${ach.title}</h4>
                                    <p style="margin: 4px 0; font-size: 13px; color: var(--text-muted); line-height: 1.4; font-family: 'Outfit', sans-serif;">${ach.description}</p>
                                    <div style="margin-top: 6px; font-size: 12px; color: ${iconColor}; font-weight: 600; display: flex; align-items: center; gap: 6px; font-family: 'Outfit', sans-serif;">
                                        <i class="far fa-calendar-alt"></i>
                                        <span>${ach.details}</span>
                                    </div>
                                </div>
                            </div>
                        `;
                    });

                    html += `
                            </div>
                        </div>
                    `;
                });

                body.innerHTML = html;
            } else {
                const achievementsSongs = [];

                tracks.forEach(track => {
                    const songAchs = [];
                    const appCount = (track.history_ranks || []).length;
                    const energyVal = track.energy === 'N/A' ? 0.0 : track.energy;

                    // 1. Бестселлер
                    if (appCount >= 6) {
                        songAchs.push({
                            title: 'Бестселлер',
                            icon: 'fas fa-fire',
                            class: 'absolute-dominator',
                            description: 'Абсолютный Бестселлер: трек удерживался в Топ-50 рейтинга более 6 месяцев!',
                            details: `Провел в чартах месяцев: ${appCount}.`
                        });
                    }

                    // 2. Ураган
                    if (track.danceability >= 0.85 && energyVal >= 0.85) {
                        songAchs.push({
                            title: 'Ураган',
                            icon: 'fas fa-bolt',
                            class: 'one-hit',
                            description: 'Танцевальный Ураган: невероятно мощный заряд энергии и танцевального вайба!',
                            details: `Ритмичность: ${Math.round(track.danceability * 100)}%, Энергия: ${Math.round(energyVal * 100)}%.`
                        });
                    }

                    // 3. Дзен
                    if (track.vibe === 'Chill' && track.valence <= 0.3) {
                        songAchs.push({
                            title: 'Дзен',
                            icon: 'fas fa-cloud-moon',
                            class: 'stable-vet',
                            description: 'Абсолютный Дзен: глубочайший меланхоличный чилл-вайб для медитативного погружения.',
                            details: `Стиль: Расслабляющий, Позитивность (Valence): ${Math.round(track.valence * 100)}%.`
                        });
                    }

                    if (songAchs.length > 0) {
                        achievementsSongs.push({
                            track: track,
                            list: songAchs
                        });
                    }
                });

                if (achievementsSongs.length === 0) {
                    body.innerHTML = `<div style="text-align: center; color: var(--text-muted); padding: 40px; font-family: 'Outfit', sans-serif;">К сожалению, пока ни один трек не заработал звания легендарного.</div>`;
                    return;
                }

                achievementsSongs.sort((a, b) => a.track.name.localeCompare(b.track.name));

                let html = '';
                achievementsSongs.forEach(item => {
                    const t = item.track;

                    html += `
                        <div class="song-achievement-row" style="margin-bottom: 20px; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); padding: 16px; border-radius: 12px;">
                            <h3 style="margin: 0 0 12px 0; font-size: 15px; color: #fff; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; font-weight: 700; font-family: 'Outfit', sans-serif;">
                                <span style="cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--spotify-green)'" onmouseout="this.style.color='#fff'" onclick="closeAchievementsModal(); openDetailsModal(event, '${t.id}');">
                                    <i class="fas fa-music" style="color: var(--spotify-green); margin-right: 6px;"></i> ${t.name} <span style="font-weight: 400; color: var(--text-muted); font-size: 13px;">— ${t.artist}</span>
                                </span>
                                <span style="font-size: 11px; font-weight: 400; color: var(--text-muted); font-style: italic;">Альбом: ${t.album}</span>
                            </h3>
                            <div style="display: flex; flex-direction: column; gap: 10px;">
                    `;

                    item.list.forEach(ach => {
                        let borderCol = '#00F5FF';
                        let iconColor = '#00F5FF';
                        if (ach.class === 'king-comeback') {
                            borderCol = '#FFD700';
                            iconColor = '#FFD700';
                        } else if (ach.class === 'one-hit') {
                            borderCol = '#BF5FFF';
                            iconColor = '#BF5FFF';
                        } else if (ach.class === 'absolute-dominator') {
                            borderCol = '#FF5722';
                            iconColor = '#FF5722';
                        } else if (ach.class === 'king-of-hill') {
                            borderCol = '#FFB300';
                            iconColor = '#FFB300';
                        } else if (ach.class === 'comet-artist') {
                            borderCol = '#FF9100';
                            iconColor = '#FF9100';
                        } else if (ach.class === 'stable-vet') {
                            borderCol = '#00F5FF';
                            iconColor = '#00F5FF';
                        }

                        html += `
                            <div style="display: flex; gap: 12px; background: rgba(0, 0, 0, 0.2); padding: 12px; border-radius: 8px; border-left: 4px solid ${borderCol};">
                                <div style="font-size: 16px; color: ${iconColor}; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; background: rgba(255,255,255,0.03); border-radius: 50%; flex-shrink: 0;">
                                    <i class="${ach.icon}"></i>
                                </div>
                                <div style="flex-grow: 1;">
                                    <h4 style="margin: 0; font-size: 13px; color: #fff; font-weight: 700; font-family: 'Outfit', sans-serif;">${ach.title}</h4>
                                    <p style="margin: 4px 0; font-size: 12px; color: var(--text-muted); line-height: 1.4; font-family: 'Outfit', sans-serif;">${ach.description}</p>
                                    <div style="margin-top: 6px; font-size: 11px; color: ${iconColor}; font-weight: 600; display: flex; align-items: center; gap: 6px; font-family: 'Outfit', sans-serif;">
                                        <i class="fas fa-info-circle"></i>
                                        <span>${ach.details}</span>
                                    </div>
                                </div>
                            </div>
                        `;
                    });

                    html += `
                            </div>
                        </div>
                    `;
                });

                body.innerHTML = html;
            }
        }

        function openAchievementsModal() {
            const modal = document.getElementById('achievementsModal');
            if (!modal) return;

            modal.classList.add('active');
            document.body.classList.add('modal-active');

            switchAchievementsTab('artists');
        }

        function closeAchievementsModal() {
            const modal = document.getElementById('achievementsModal');
            if (modal) modal.classList.remove('active');
            document.body.classList.remove('modal-active');
        }

        function updateChartsTheme() {
            const body = document.body;
            const isLight = body.classList.contains('light-theme');
            const isGray = body.classList.contains('gray-theme');
            
            // Dynamic text and grid colors based on theme
            let textMain = '#FFFFFF';
            let textMuted = '#B3B3B3';
            let gridColor = 'rgba(255, 255, 255, 0.05)';
            let gridRadar = 'rgba(255, 255, 255, 0.1)';
            let tooltipBg = 'rgba(20, 20, 20, 0.95)';
            let tooltipText = '#FFFFFF';

            if (isLight) {
                textMain = '#121212';
                textMuted = '#666666';
                gridColor = 'rgba(0, 0, 0, 0.08)';
                gridRadar = 'rgba(0, 0, 0, 0.08)';
                tooltipBg = 'rgba(255, 255, 255, 0.95)';
                tooltipText = '#121212';
            } else if (isGray) {
                textMain = '#F5F6F8';
                textMuted = '#A0A5B5';
                gridColor = 'rgba(255, 255, 255, 0.06)';
                gridRadar = 'rgba(255, 255, 255, 0.12)';
                tooltipBg = 'rgba(30, 32, 40, 0.96)';
                tooltipText = '#F5F6F8';
            }

            // Update Vibe Chart
            if (window.myVibeChart) {
                window.myVibeChart.options.plugins.legend.labels.color = textMain;
                window.myVibeChart.data.datasets[0].borderColor = isLight ? 'rgba(255, 255, 255, 0.8)' : 'rgba(18, 18, 18, 0.6)';
                window.myVibeChart.update();
            }

            // Update Radar Chart
            if (window.myRadarChart) {
                window.myRadarChart.options.scales.r.angleLines.color = gridRadar;
                window.myRadarChart.options.scales.r.grid.color = gridRadar;
                window.myRadarChart.options.scales.r.pointLabels.color = textMuted;
                window.myRadarChart.update();
            }

            // Update activeRadarChart (in details modal)
            if (window.activeRadarChart) {
                window.activeRadarChart.options.scales.r.angleLines.color = gridRadar;
                window.activeRadarChart.options.scales.r.grid.color = gridRadar;
                window.activeRadarChart.options.scales.r.pointLabels.color = textMuted;
                window.activeRadarChart.update();
            }

            // Update Artist Evolution Chart
            if (window.activeArtistChart) {
                if (window.activeArtistChart.options.plugins.legend) {
                    window.activeArtistChart.options.plugins.legend.labels.color = textMuted;
                }
                window.activeArtistChart.options.scales.x.ticks.color = textMuted;
                window.activeArtistChart.options.scales.x.grid.color = gridColor;
                window.activeArtistChart.options.scales.y.ticks.color = textMuted;
                window.activeArtistChart.options.scales.y.grid.color = gridColor;
                window.activeArtistChart.update();
            }

            // Update Artist Tracks Chart
            if (window.activeArtistTracksChart) {
                if (window.activeArtistTracksChart.options.plugins.legend) {
                    window.activeArtistTracksChart.options.plugins.legend.labels.color = textMuted;
                }
                window.activeArtistTracksChart.options.scales.x.ticks.color = textMuted;
                window.activeArtistTracksChart.options.scales.x.grid.color = gridColor;
                window.activeArtistTracksChart.options.scales.y.ticks.color = textMuted;
                window.activeArtistTracksChart.options.scales.y.grid.color = gridColor;
                window.activeArtistTracksChart.update();
            }

            // Update activeVibeDnaChart
            if (window.activeVibeDnaChart) {
                if (window.activeVibeDnaChart.options.plugins.legend) {
                    window.activeVibeDnaChart.options.plugins.legend.labels.color = textMuted;
                }
                window.activeVibeDnaChart.options.scales.x.ticks.color = textMuted;
                window.activeVibeDnaChart.options.scales.x.grid.color = gridColor;
                window.activeVibeDnaChart.options.scales.y.ticks.color = textMuted;
                window.activeVibeDnaChart.options.scales.y.grid.color = gridColor;
                window.activeVibeDnaChart.update();
            }

            // Update weeklyStatsChartInstance
            if (window.weeklyStatsChartInstance) {
                if (window.weeklyStatsChartInstance.options.scales.x) {
                    window.weeklyStatsChartInstance.options.scales.x.ticks.color = textMuted;
                    window.weeklyStatsChartInstance.options.scales.x.grid.color = gridColor;
                }
                if (window.weeklyStatsChartInstance.options.scales.y) {
                    window.weeklyStatsChartInstance.options.scales.y.ticks.color = textMain;
                    window.weeklyStatsChartInstance.options.scales.y.grid.color = gridColor;
                }
                if (window.weeklyStatsChartInstance.options.plugins.tooltip) {
                    window.weeklyStatsChartInstance.options.plugins.tooltip.backgroundColor = tooltipBg;
                    window.weeklyStatsChartInstance.options.plugins.tooltip.titleColor = tooltipText;
                    window.weeklyStatsChartInstance.options.plugins.tooltip.bodyColor = tooltipText;
                }
                window.weeklyStatsChartInstance.update();
            }
        }

        function toggleTheme() {
            const body = document.body;
            const themeIcon = document.getElementById('theme-icon');
            
            // Cycle: dark -> light -> gray -> dark
            let currentTheme = 'dark';
            if (body.classList.contains('light-theme')) {
                currentTheme = 'light';
            } else if (body.classList.contains('gray-theme')) {
                currentTheme = 'gray';
            }

            // Remove all theme classes
            body.classList.remove('light-theme', 'gray-theme');
            
            // Set next theme
            if (currentTheme === 'dark') {
                body.classList.add('light-theme');
                if (themeIcon) {
                    themeIcon.className = 'fas fa-sun';
                }
                localStorage.setItem('spotify-theme', 'light');
                updateChartsTheme();
            } else if (currentTheme === 'light') {
                body.classList.add('gray-theme');
                if (themeIcon) {
                    themeIcon.className = 'fas fa-adjust';
                }
                localStorage.setItem('spotify-theme', 'gray');
                updateChartsTheme();
            } else {
                if (themeIcon) {
                    themeIcon.className = 'fas fa-moon';
                }
                localStorage.setItem('spotify-theme', 'dark');
                updateChartsTheme();
            }
        }

        // Theme initialization
        const savedTheme = localStorage.getItem('spotify-theme') || 'dark';
        const themeIcon = document.getElementById('theme-icon');
        
        document.body.classList.remove('light-theme', 'gray-theme');
        
        if (savedTheme === 'light') {
            document.body.classList.add('light-theme');
            if (themeIcon) {
                themeIcon.className = 'fas fa-sun';
            }
            setTimeout(() => updateChartsTheme(), 150);
        } else if (savedTheme === 'gray') {
            document.body.classList.add('gray-theme');
            if (themeIcon) {
                themeIcon.className = 'fas fa-adjust';
            }
            setTimeout(() => updateChartsTheme(), 150);
        } else {
            if (themeIcon) {
                themeIcon.className = 'fas fa-moon';
            }
            setTimeout(() => updateChartsTheme(), 150);
        }

        // Close modal on Escape key press
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const modal = document.getElementById('detailsModal');
                if (modal && modal.classList.contains('active')) {
                    closeDetailsModal();
                }
                const modalAch = document.getElementById('achievementsModal');
                if (modalAch && modalAch.classList.contains('active')) {
                    closeAchievementsModal();
                }
            }
        });

        // Initial track rendering
        renderTracks(tracks);

        // --- MONTHLY TOPS IMPLEMENTATION ---
        function initMonthlyTops() {
            const container = document.getElementById('monthlyTabsBar');
            const tableBody = document.getElementById('monthlyTopBody');
            if (!container || !tableBody || typeof monthlyTops === 'undefined') return;

            const monthNames = Object.keys(monthlyTops);
            if (monthNames.length === 0) {
                const section = document.querySelector('.monthly-tops-section');
                if (section) section.style.display = 'none';
                return;
            }

            container.innerHTML = '';
            monthNames.forEach((month, idx) => {
                const btn = document.createElement('button');
                btn.className = `month-tab-btn ${idx === 0 ? 'active' : ''}`;
                btn.innerText = month;
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    container.querySelectorAll('.month-tab-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    renderMonthTable(month);
                });
                container.appendChild(btn);
            });

            renderMonthTable(monthNames[0]);
        }

        function renderMonthTable(monthName) {
            const tableBody = document.getElementById('monthlyTopBody');
            if (!tableBody || typeof monthlyTops === 'undefined') return;

            const data = monthlyTops[monthName] || [];
            tableBody.innerHTML = '';

            if (data.length === 0) {
                tableBody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 24px;">Нет данных для этого месяца</td></tr>`;
                return;
            }

            data.forEach((row, idx) => {
                const tr = document.createElement('tr');
                tr.className = 'clickable-row-item';
                tr.style.cursor = 'pointer';
                tr.onclick = () => openDetailsByNameAndArtist(row.track, row.artist);
                tr.innerHTML = `
                    <td><span class="rank-badge">${idx + 1}</span></td>
                    <td style="font-weight: 600; color: var(--text-light);">${row.track}</td>
                    <td style="color: var(--spotify-green); font-weight: 500;">${row.artist}</td>
                    <td style="color: var(--text-muted); font-size: 13px;">${row.genre}</td>
                `;
                tableBody.appendChild(tr);
            });
        }

        // Render Music Impulse Widget
        function renderMusicImpulse() {
            const rocketsList = document.getElementById('rockets-list');
            const starsList = document.getElementById('stars-list');

            if (!rocketsList || !starsList) return;

            rocketsList.innerHTML = '';
            starsList.innerHTML = '';

            const rocketsData = (typeof musicImpulse !== 'undefined') ? (musicImpulse.rockets || []) : [];
            const starsData = (typeof musicImpulse !== 'undefined') ? (musicImpulse.stars || []) : [];

            if (rocketsData.length === 0) {
                rocketsList.innerHTML = '<div style="color: #888; font-size: 13px; font-style: italic; padding: 5px;">Нет данных о взлетах за этот месяц</div>';
            } else {
                rocketsData.forEach(([artist, delta]) => {
                    const item = document.createElement('div');
                    item.className = 'impulse-item';
                    item.onclick = () => selectArtistFromWidget(artist);
                    item.innerHTML = `
                        <div class="impulse-artist-info">
                            <span class="impulse-artist-name">${artist}</span>
                        </div>
                        <span class="impulse-badge badge-rocket">
                            <i class="fas fa-arrow-trend-up"></i> +${delta}
                        </span>
                    `;
                    rocketsList.appendChild(item);
                });
            }

            if (starsData.length === 0) {
                starsList.innerHTML = '<div style="color: #888; font-size: 13px; font-style: italic; padding: 5px;">Нет данных о падениях за этот месяц</div>';
            } else {
                starsData.forEach(([artist, delta]) => {
                    const item = document.createElement('div');
                    item.className = 'impulse-item';
                    item.onclick = () => selectArtistFromWidget(artist);
                    item.innerHTML = `
                        <div class="impulse-artist-info">
                            <span class="impulse-artist-name">${artist}</span>
                        </div>
                        <span class="impulse-badge badge-star">
                            <i class="fas fa-arrow-trend-down"></i> ${delta}
                        </span>
                    `;
                    starsList.appendChild(item);
                });
            }
        }

        function selectArtistFromWidget(artistName) {
            const selectEl = document.getElementById('artistSelect');
            if (!selectEl) return;

            let found = false;
            for (let i = 0; i < selectEl.options.length; i++) {
                if (selectEl.options[i].value === artistName) {
                    selectEl.selectedIndex = i;
                    found = true;
                    break;
                }
            }

            if (found) {
                const event = new Event('change');
                selectEl.dispatchEvent(event);

                switchTab('evolution');
            }
        }

        // Initialize monthly top tables
        initMonthlyTops();

        // Initialize music impulse trends widget
        renderMusicImpulse();

        // --- CUMULATIVE WEEKLY STATISTICS FUNCTIONS ---
        let weeklyStatsChartInstance = null;
        let weeklyStatsData = null;
        
        function getWeeklyVibeEvolution() {
            if (!weeklyTop) return [];
            const weeks = Object.keys(weeklyTop);
            const evolution = [];
            weeks.forEach(week => {
                const data = weeklyTop[week];
                const weekTracks = data.tracks || [];
                let sumBpm = 0, countBpm = 0;
                let sumEnergy = 0, countEnergy = 0;
                let sumValence = 0, countValence = 0;
                let sumDance = 0, countDance = 0;
                weekTracks.forEach(trackName => {
                    if (!trackName || trackName === '—') return;
                    let cleanTrack = trackName.trim().replace(/\s*-\s*\d+$/, '').trim();
                    const dbTrack = (tracks || []).find(t => t.name.toLowerCase() === cleanTrack.toLowerCase());
                    if (dbTrack) {
                        if (dbTrack.bpm && dbTrack.bpm !== 'N/A' && !isNaN(dbTrack.bpm)) {
                            sumBpm += parseFloat(dbTrack.bpm);
                            countBpm++;
                        }
                        if (dbTrack.energy !== undefined && dbTrack.energy !== 'N/A' && !isNaN(dbTrack.energy)) {
                            sumEnergy += parseFloat(dbTrack.energy);
                            countEnergy++;
                        }
                        if (dbTrack.valence !== undefined && dbTrack.valence !== 'N/A' && !isNaN(dbTrack.valence)) {
                            sumValence += parseFloat(dbTrack.valence);
                            countValence++;
                        }
                        if (dbTrack.danceability !== undefined && dbTrack.danceability !== 'N/A' && !isNaN(dbTrack.danceability)) {
                            sumDance += parseFloat(dbTrack.danceability);
                            countDance++;
                        }
                    }
                });
                let shortWeek = week;
                const match = week.match(/^(\d+)\s+([а-яёA-Za-z]+)/i);
                if (match) {
                    const monthMap = {
                        'октября': 'окт', 'ноября': 'ноя', 'декабря': 'дек',
                        'января': 'янв', 'февраля': 'фев', 'марта': 'мар',
                        'апреля': 'апр', 'мая': 'мая', 'июня': 'июн',
                        'июля': 'июл', 'августа': 'авг', 'сентября': 'сен'
                    };
                    const m = match[2].toLowerCase();
                    const shortM = monthMap[m] || m.slice(0, 3);
                    shortWeek = `${match[1]} ${shortM}`;
                }
                evolution.push({
                    week: shortWeek,
                    fullWeek: week,
                    bpm: countBpm > 0 ? Math.round(sumBpm / countBpm) : null,
                    energy: countEnergy > 0 ? Math.round((sumEnergy / countEnergy) * 100) : null,
                    valence: countValence > 0 ? Math.round((sumValence / countValence) * 100) : null,
                    dance: countDance > 0 ? Math.round((sumDance / countDance) * 100) : null
                });
            });
            return evolution;
        }
        
        function getWeeklyVibeMilestones() {
            const evolution = getWeeklyVibeEvolution();
            if (evolution.length === 0) {
                return {
                    maxEnergy: { week: '—', value: 0 },
                    minEnergy: { week: '—', value: 0 },
                    maxDance: { week: '—', value: 0 },
                    maxValence: { week: '—', value: 0 }
                };
            }
            const validEnergy = evolution.filter(e => e.energy !== null);
            const validDance = evolution.filter(e => e.dance !== null);
            const validValence = evolution.filter(e => e.valence !== null);
            const maxEnergy = validEnergy.length > 0 ? validEnergy.reduce((max, e) => e.energy > max.energy ? e : max, validEnergy[0]) : null;
            const minEnergy = validEnergy.length > 0 ? validEnergy.reduce((min, e) => e.energy < min.energy ? e : min, validEnergy[0]) : null;
            const maxDance = validDance.length > 0 ? validDance.reduce((max, e) => e.dance > max.dance ? e : max, validDance[0]) : null;
            const maxValence = validValence.length > 0 ? validValence.reduce((max, e) => e.valence > max.valence ? e : max, validValence[0]) : null;
            return {
                maxEnergy: maxEnergy ? { week: maxEnergy.fullWeek, value: maxEnergy.energy } : { week: '—', value: 0 },
                minEnergy: minEnergy ? { week: minEnergy.fullWeek, value: minEnergy.energy } : { week: '—', value: 0 },
                maxDance: maxDance ? { week: maxDance.fullWeek, value: maxDance.dance } : { week: '—', value: 0 },
                maxValence: maxValence ? { week: maxValence.fullWeek, value: maxValence.valence } : { week: '—', value: 0 }
            };
        }
        
        function renderWeeklyVibeJourney() {
            const tableWrap = document.querySelector('.weekly-stats-table-wrap');
            if (tableWrap) {
                const milestones = getWeeklyVibeMilestones();
                tableWrap.innerHTML = `
                    <div class="vibe-milestones-summary" style="display: flex; flex-direction: column; gap: 12px; color: var(--text-main);">
                        <div style="font-size: 16px; font-weight: 700; color: var(--spotify-green); border-bottom: 2px solid var(--panel-border); padding-bottom: 8px; margin-bottom: 5px;">
                            <i class="fas fa-medal"></i> Рекорды Вашего Вайба
                        </div>
                        
                        <div class="vibe-milestone-card" style="background: rgba(255, 255, 255, 0.03); padding: 10px 12px; border-radius: 12px; border: 1px solid var(--panel-border); display: flex; align-items: center; gap: 12px;">
                            <div style="font-size: 22px; color: #FF6B6B; width: 30px; text-align: center;"><i class="fas fa-fire"></i></div>
                            <div>
                                <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">Самая Энергичная Неделя</div>
                                <div style="font-weight: 600; font-size: 13px; color: var(--text-main);">${milestones.maxEnergy.week}</div>
                                <div style="font-size: 12px; color: var(--text-muted);">Средняя энергия: <strong style="color: #FF6B6B;">${milestones.maxEnergy.value}%</strong></div>
                            </div>
                        </div>
                        
                        <div class="vibe-milestone-card" style="background: rgba(255, 255, 255, 0.03); padding: 10px 12px; border-radius: 12px; border: 1px solid var(--panel-border); display: flex; align-items: center; gap: 12px;">
                            <div style="font-size: 22px; color: #00F5FF; width: 30px; text-align: center;"><i class="fas fa-running"></i></div>
                            <div>
                                <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">Самая Танцевальная Неделя</div>
                                <div style="font-weight: 600; font-size: 13px; color: var(--text-main);">${milestones.maxDance.week}</div>
                                <div style="font-size: 12px; color: var(--text-muted);">Средняя танцевальность: <strong style="color: #00F5FF;">${milestones.maxDance.value}%</strong></div>
                            </div>
                        </div>
                        
                        <div class="vibe-milestone-card" style="background: rgba(255, 255, 255, 0.03); padding: 10px 12px; border-radius: 12px; border: 1px solid var(--panel-border); display: flex; align-items: center; gap: 12px;">
                            <div style="font-size: 22px; color: #FFD700; width: 30px; text-align: center;"><i class="fas fa-smile"></i></div>
                            <div>
                                <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">Самая Позитивная Неделя</div>
                                <div style="font-weight: 600; font-size: 13px; color: var(--text-main);">${milestones.maxValence.week}</div>
                                <div style="font-size: 12px; color: var(--text-muted);">Среднее настроение: <strong style="color: #FFD700;">${milestones.maxValence.value}%</strong></div>
                            </div>
                        </div>
                        
                        <div class="vibe-milestone-card" style="background: rgba(255, 255, 255, 0.03); padding: 10px 12px; border-radius: 12px; border: 1px solid var(--panel-border); display: flex; align-items: center; gap: 12px;">
                            <div style="font-size: 22px; color: #8A2BE2; width: 30px; text-align: center;"><i class="fas fa-moon"></i></div>
                            <div>
                                <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">Самая Спокойная Неделя</div>
                                <div style="font-weight: 600; font-size: 13px; color: var(--text-main);">${milestones.minEnergy.week}</div>
                                <div style="font-size: 12px; color: var(--text-muted);">Средняя энергия: <strong style="color: #8A2BE2;">${milestones.minEnergy.value}%</strong></div>
                            </div>
                        </div>
                    </div>
                `;
            }
            const canvasEl = document.getElementById('weeklyStatsChart');
            if (!canvasEl) return;
            const ctx = canvasEl.getContext('2d');
            canvasEl.style.height = '350px';
            canvasEl.style.maxHeight = '350px';
            const wrapEl = canvasEl.closest('.weekly-stats-chart-wrap');
            if (wrapEl) {
                wrapEl.style.height = '390px';
                wrapEl.style.maxHeight = '390px';
            }
            if (weeklyStatsChartInstance) {
                weeklyStatsChartInstance.destroy();
            }
            const evolution = getWeeklyVibeEvolution();
            const chartLabels = evolution.map(e => e.week);
            const isDark = !document.body.classList.contains('light-theme');
            const gridColor = isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';
            const textColor = isDark ? '#B3B3B3' : '#666666';
            weeklyStatsChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartLabels,
                    datasets: [
                        {
                            label: 'Энергия',
                            data: evolution.map(e => e.energy),
                            borderColor: '#FF6B6B',
                            backgroundColor: 'rgba(255, 107, 107, 0.05)',
                            borderWidth: 3,
                            pointBackgroundColor: '#FF6B6B',
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            tension: 0.35,
                            fill: true
                        },
                        {
                            label: 'Танцевальность',
                            data: evolution.map(e => e.dance),
                            borderColor: '#00F5FF',
                            backgroundColor: 'rgba(0, 245, 255, 0.05)',
                            borderWidth: 3,
                            pointBackgroundColor: '#00F5FF',
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            tension: 0.35,
                            fill: true
                        },
                        {
                            label: 'Позитив',
                            data: evolution.map(e => e.valence),
                            borderColor: '#FFD700',
                            backgroundColor: 'rgba(255, 215, 0, 0.05)',
                            borderWidth: 3,
                            pointBackgroundColor: '#FFD700',
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            tension: 0.35,
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            labels: {
                                color: textColor,
                                font: { family: 'Outfit', size: 11, weight: 'bold' }
                            }
                        },
                        tooltip: {
                            backgroundColor: isDark ? 'rgba(20, 20, 20, 0.95)' : 'rgba(255, 255, 255, 0.95)',
                            titleColor: isDark ? '#FFF' : '#000',
                            bodyColor: isDark ? '#FFF' : '#000',
                            cornerRadius: 8,
                            padding: 12,
                            callbacks: {
                                label: function(context) {
                                    return ` ${context.dataset.label}: ${context.raw}%`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: gridColor, drawBorder: false },
                            ticks: { color: textColor, font: { family: 'Outfit', size: 9 }, maxRotation: 45, minRotation: 45 }
                        },
                        y: {
                            grid: { color: gridColor, drawBorder: false },
                            ticks: { color: textColor, font: { family: 'Outfit', size: 10 } },
                            min: 0,
                            max: 100
                        }
                    }
                }
            });
        }

        function getWeeklyTopStats() {
            if (!weeklyTop) return { artists: [], songs: [] };
            
            const artistCounts = {};
            const songCounts = {};
            const weeks = Object.keys(weeklyTop);
            const totalWeeks = weeks.length;
            
            weeks.forEach(week => {
                const data = weeklyTop[week];
                const artists = data.artists || [];
                const weekTracks = data.tracks || [];
                
                // Count artists (independently of tracks)
                artists.forEach((art) => {
                    if (!art || art === '—') return;
                    let cleanArt = art.trim();
                    // Clean playcount suffix like " - 2" or " - 1" from end of name if present
                    cleanArt = cleanArt.replace(/\s*-\s*\d+$/, '').trim();
                    if (!cleanArt) return;
                    
                    // Special normalization for KSB
                    if (cleanArt.toLowerCase().startsWith('ksb ')) {
                        cleanArt = 'KSB Music';
                    }
                    
                    // Match to canonical name from artistsHistory if available (case-insensitive)
                    const canonicalName = Object.keys(artistsHistory).find(k => k.toLowerCase() === cleanArt.toLowerCase()) || cleanArt;
                    
                    artistCounts[canonicalName] = (artistCounts[canonicalName] || 0) + 1;
                });
                
                // Count songs (independently of artists)
                weekTracks.forEach((track) => {
                    if (!track || track === '—') return;
                    let cleanTrack = track.trim();
                    // Clean playcount suffix from end of name if present
                    cleanTrack = cleanTrack.replace(/\s*-\s*\d+$/, '').trim();
                    if (!cleanTrack) return;
                    
                    // Exclude SHINOBI from top stats
                    if (cleanTrack.toLowerCase() === 'shinobi') return;
                    
                    // Match to canonical track name from global tracks database if available (case-insensitive) to normalize casing
                    const canonicalTrack = (tracks || []).find(t => t.name.toLowerCase() === cleanTrack.toLowerCase())?.name || cleanTrack;
                    
                    songCounts[canonicalTrack] = (songCounts[canonicalTrack] || 0) + 1;
                });
            });
            
            // Convert to sorted arrays
            const sortedArtists = Object.entries(artistCounts)
                .map(([name, count]) => ({
                    name,
                    count,
                    percentage: ((count / totalWeeks) * 100).toFixed(1) + '%'
                }))
                .sort((a, b) => b.count - a.count);
                
            // For songs, look up their correct artist from the global tracks database!
            const sortedSongs = Object.entries(songCounts)
                .map(([name, count]) => {
                    // Look up the artist for this track!
                    let matchedArtist = '—';
                    if (tracks && tracks.length > 0) {
                        // 1. Exact match
                        const exactMatch = tracks.find(t => t.name.toLowerCase() === name.toLowerCase());
                        if (exactMatch) {
                            matchedArtist = exactMatch.artist;
                        } else {
                            // 2. Partial match
                            const partialMatch = tracks.find(t => t.name.toLowerCase().includes(name.toLowerCase()) || name.toLowerCase().includes(t.name.toLowerCase()));
                            if (partialMatch) {
                                matchedArtist = partialMatch.artist;
                            }
                        }
                    }
                    
                    // Combined display name for graph (Track Title — Artist Name)
                    const displayName = matchedArtist !== '—' ? `${name} — ${matchedArtist}` : name;
                    
                    return {
                        name: displayName,
                        count,
                        percentage: ((count / totalWeeks) * 100).toFixed(1) + '%',
                        trackName: name,
                        artistName: matchedArtist
                    };
                })
                .sort((a, b) => b.count - a.count);
                
            return {
                artists: sortedArtists,
                songs: sortedSongs,
                totalWeeks
            };
        }
        
        function switchWeeklyStatsTab(type) {
            const artistsBtn = document.getElementById('weeklyStatsTabArtists');
            const songsBtn = document.getElementById('weeklyStatsTabSongs');
            const vibeBtn = document.getElementById('weeklyStatsTabVibe');
            
            if (artistsBtn) artistsBtn.classList.remove('active');
            if (songsBtn) songsBtn.classList.remove('active');
            if (vibeBtn) vibeBtn.classList.remove('active');
            
            if (type === 'artists' && artistsBtn) {
                artistsBtn.classList.add('active');
            } else if (type === 'songs' && songsBtn) {
                songsBtn.classList.add('active');
            } else if (type === 'vibe' && vibeBtn) {
                vibeBtn.classList.add('active');
            }
            
            renderWeeklyStats(type);
        }
        
        function renderWeeklyStats(type = 'artists') {
            if (!weeklyStatsData) {
                weeklyStatsData = getWeeklyTopStats();
            }
            
            if (type === 'vibe') {
                renderWeeklyVibeJourney();
                return;
            }
            
            // Restore original table structure if returning from Vibe tab
            const tableWrap = document.querySelector('.weekly-stats-table-wrap');
            if (tableWrap && !document.getElementById('weekly-stats-table-body')) {
                tableWrap.innerHTML = `
                    <table class="premium-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14px;">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--panel-border); color: var(--text-muted); font-weight: 600;">
                                <th style="padding: 12px 10px; width: 60px;">Место</th>
                                <th id="weekly-table-header-name" style="padding: 12px 10px;">Исполнитель</th>
                                <th style="padding: 12px 10px; text-align: center; width: 150px;">Попаданий в Топ-5</th>
                                <th style="padding: 12px 10px; text-align: center; width: 100px;">Доля недель</th>
                            </tr>
                        </thead>
                        <tbody id="weekly-stats-table-body">
                        </tbody>
                    </table>
                `;
            }
            
            const list = type === 'artists' ? weeklyStatsData.artists : weeklyStatsData.songs;
            const headerNameEl = document.getElementById('weekly-table-header-name');
            if (headerNameEl) {
                headerNameEl.textContent = type === 'artists' ? 'Исполнитель' : 'Песня / Исполнитель';
            }
            
            // Render Table (Top 10 for artists, Top 20 for songs)
            const displayLimit = type === 'artists' ? 10 : 20;
            const topItems = list.slice(0, displayLimit);
            const tbody = document.getElementById('weekly-stats-table-body');
            if (tbody) {
                tbody.innerHTML = '';
                if (topItems.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 30px;">Нет данных для отображения</td></tr>`;
                } else {
                    topItems.forEach((item, idx) => {
                        const rankClass = idx === 0 ? 'table-rank-1' : (idx === 1 ? 'table-rank-2' : (idx === 2 ? 'table-rank-3' : 'table-rank-other'));
                        
                        let displayNameHtml = '';
                        if (type === 'artists') {
                            const canonicalName = Object.keys(artistsHistory).find(k => k.toLowerCase() === item.name.toLowerCase()) || item.name;
                            const isCanonical = Object.keys(artistsHistory).some(k => k.toLowerCase() === item.name.toLowerCase());
                            if (isCanonical) {
                                displayNameHtml = `<span onclick="focusArtistFromWeekly('${canonicalName}')" style="cursor: pointer; color: var(--spotify-green); font-weight: 600; text-decoration: underline;">${item.name}</span>`;
                            } else {
                                displayNameHtml = `<span>${item.name}</span>`;
                            }
                        } else {
                            const trackTitle = item.trackName;
                            const songArtist = item.artistName;
                            
                            if (songArtist !== '—') {
                                const canonicalName = Object.keys(artistsHistory).find(k => k.toLowerCase() === songArtist.toLowerCase()) || songArtist;
                                const isCanonical = Object.keys(artistsHistory).some(k => k.toLowerCase() === songArtist.toLowerCase());
                                
                                if (isCanonical) {
                                    displayNameHtml = `<span>${trackTitle}</span> <span onclick="focusArtistFromWeekly('${canonicalName}')" style="cursor: pointer; color: var(--text-muted); font-size: 12px; margin-left: 5px;">(${songArtist})</span>`;
                                } else {
                                    displayNameHtml = `<span>${trackTitle} <span style="color: var(--text-muted); font-size: 12px;">(${songArtist})</span></span>`;
                                }
                            } else {
                                displayNameHtml = `<span>${trackTitle}</span>`;
                            }
                        }
                        
                        const rowHtml = `
                            <tr>
                                <td style="padding: 12px 10px;"><span class="table-rank-badge ${rankClass}">${idx + 1}</span></td>
                                <td style="padding: 12px 10px; font-weight: 500; color: var(--text-main);">${displayNameHtml}</td>
                                <td style="padding: 12px 10px; text-align: center; font-weight: 700; color: var(--spotify-green);">${item.count}</td>
                                <td style="padding: 12px 10px; text-align: center; color: var(--text-muted); font-weight: 500;">${item.percentage}</td>
                            </tr>
                        `;
                        tbody.insertAdjacentHTML('beforeend', rowHtml);
                    });
                }
            }
            
            // Render Chart
            const canvasEl = document.getElementById('weeklyStatsChart');
            if (!canvasEl) return;
            const ctx = canvasEl.getContext('2d');
            
            // Dynamically adjust height of canvas and parent wrapper to look beautiful with more items
            canvasEl.style.height = `${topItems.length * 28 + 60}px`;
            canvasEl.style.maxHeight = '650px';
            
            const wrapEl = canvasEl.closest('.weekly-stats-chart-wrap');
            if (wrapEl) {
                wrapEl.style.height = `${topItems.length * 28 + 60 + 40}px`;
                wrapEl.style.maxHeight = '700px';
            }
            
            if (weeklyStatsChartInstance) {
                weeklyStatsChartInstance.destroy();
            }
            
            const chartData = topItems.map(item => item.count);
            const chartLabels = topItems.map(item => {
                const label = item.name;
                if (label.length > 25) {
                    return label.slice(0, 23) + '...';
                }
                return label;
            });
            
            const isLight = document.body.classList.contains('light-theme');
            const isGray = document.body.classList.contains('gray-theme');
            
            let gridColor = 'rgba(255, 255, 255, 0.05)';
            let textColor = '#B3B3B3';
            let labelColor = '#FFFFFF';
            let tooltipBg = 'rgba(20, 20, 20, 0.95)';
            let tooltipText = '#FFFFFF';

            if (isLight) {
                gridColor = 'rgba(0, 0, 0, 0.05)';
                textColor = '#666666';
                labelColor = '#121212';
                tooltipBg = 'rgba(255, 255, 255, 0.95)';
                tooltipText = '#121212';
            } else if (isGray) {
                gridColor = 'rgba(255, 255, 255, 0.06)';
                textColor = '#A0A5B5';
                labelColor = '#F5F6F8';
                tooltipBg = 'rgba(30, 32, 40, 0.96)';
                tooltipText = '#F5F6F8';
            }
            
            const gradient = ctx.createLinearGradient(0, 0, 400, 0);
            if (type === 'artists') {
                gradient.addColorStop(0, '#1DB954');
                gradient.addColorStop(1, '#00F5FF');
            } else {
                gradient.addColorStop(0, '#8A2BE2');
                gradient.addColorStop(1, '#FF6B6B');
            }
            
            weeklyStatsChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartLabels,
                    datasets: [{
                        data: chartData,
                        backgroundColor: gradient,
                        hoverBackgroundColor: type === 'artists' ? '#00F5FF' : '#FF6B6B',
                        borderRadius: 6,
                        borderSkipped: false,
                        barPercentage: 0.5,
                        categoryPercentage: 0.8,
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: tooltipBg,
                            titleColor: tooltipText,
                            bodyColor: tooltipText,
                            borderColor: type === 'artists' ? '#1DB954' : '#8A2BE2',
                            borderWidth: 1,
                            cornerRadius: 8,
                            padding: 12,
                            callbacks: {
                                label: function(context) {
                                    const val = context.raw;
                                    const percent = ((val / weeklyStatsData.totalWeeks) * 100).toFixed(1);
                                    return ` Попаданий: ${val} (${percent}% от всех недель)`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: {
                                color: gridColor,
                                drawBorder: false
                            },
                            ticks: {
                                color: textColor,
                                font: {
                                    family: 'Outfit',
                                    size: 11
                                },
                                stepSize: 1
                            },
                            suggestedMax: Math.max(...chartData, 5) + 1
                        },
                        y: {
                            grid: {
                                display: false,
                                drawBorder: false
                            },
                            ticks: {
                                autoSkip: false,
                                color: labelColor,
                                font: {
                                    family: 'Outfit',
                                    size: 11,
                                    weight: 'bold'
                                }
                            }
                        }
                    }
                }
            });
        }

        function getWeeklyAchievements() {
            if (!weeklyTop) return { dominator: { artist: '—', count: 0, percentage: '0%' }, streak: { artist: '—', streak: 0 }, bpm: { bpm: 0, week: '—' }, acoustic: { acoustic: 0, week: '—' } };
            if (typeof weeklyStatsData === 'undefined' || !weeklyStatsData) {
                weeklyStatsData = getWeeklyTopStats();
            }
            const weeks = Object.keys(weeklyTop);
            let maxDominatorCount = 0, dominatorArtist = '', dominatorWeek = '';
            let maxStreak = 0, streakArtist = '';
            let maxBpm = 0, maxBpmWeek = '';
            let maxAcoustic = 0, maxAcousticWeek = '';
            weeks.forEach((week, wIdx) => {
                const data = weeklyTop[week];
                const weekArtists = (data.artists || []).map(a => {
                    if (!a || a === '—') return null;
                    let clean = a.trim().replace(/\s*-\s*\d+$/, '').trim();
                    if (clean.toLowerCase().startsWith('ksb ')) return 'KSB Music';
                    return clean;
                }).filter(Boolean);
                const weekTracks = (data.tracks || []).map(t => {
                    if (!t || t === '—') return null;
                    return t.trim().replace(/\s*-\s*\d+$/, '').trim();
                }).filter(Boolean);
                const artistCounts = {};
                weekArtists.forEach(art => { artistCounts[art] = (artistCounts[art] || 0) + 1; });
                Object.entries(artistCounts).forEach(([art, count]) => {
                    if (count > maxDominatorCount) {
                        maxDominatorCount = count;
                        dominatorArtist = art;
                        dominatorWeek = week;
                    }
                });
                let sumBpm = 0, countBpm = 0;
                let sumAcoustic = 0, countAcoustic = 0;
                weekTracks.forEach(trackName => {
                    const dbTrack = (tracks || []).find(t => t.name.toLowerCase() === trackName.toLowerCase());
                    if (dbTrack) {
                        if (dbTrack.bpm && dbTrack.bpm !== 'N/A' && !isNaN(dbTrack.bpm)) {
                            sumBpm += parseFloat(dbTrack.bpm);
                            countBpm++;
                        }
                        if (dbTrack.acousticness !== undefined && dbTrack.acousticness !== 'N/A' && !isNaN(dbTrack.acousticness)) {
                            sumAcoustic += parseFloat(dbTrack.acousticness);
                            countAcoustic++;
                        }
                    }
                });
                if (countBpm > 0) {
                    const avgBpm = sumBpm / countBpm;
                    if (avgBpm > maxBpm) { maxBpm = avgBpm; maxBpmWeek = week; }
                }
                if (countAcoustic > 0) {
                    const avgAcoustic = sumAcoustic / countAcoustic;
                    if (avgAcoustic > maxAcoustic) { maxAcoustic = avgAcoustic; maxAcousticWeek = week; }
                }
            });
            const artistWeeklyPresence = {};
            weeks.forEach((week, wIdx) => {
                const data = weeklyTop[week];
                const weekArtists = (data.artists || []).map(a => {
                    if (!a || a === '—') return null;
                    let clean = a.trim().replace(/\s*-\s*\d+$/, '').trim();
                    if (clean.toLowerCase().startsWith('ksb ')) return 'KSB Music';
                    return clean;
                }).filter(Boolean);
                const uniqueWeekArtists = [...new Set(weekArtists)];
                uniqueWeekArtists.forEach(art => {
                    if (!artistWeeklyPresence[art]) artistWeeklyPresence[art] = [];
                    artistWeeklyPresence[art].push(wIdx);
                });
            });
            Object.entries(artistWeeklyPresence).forEach(([art, indices]) => {
                let currentStreak = 1, maxArtStreak = 1;
                for (let i = 1; i < indices.length; i++) {
                    if (indices[i] === indices[i - 1] + 1) { currentStreak++; }
                    else { maxArtStreak = Math.max(maxArtStreak, currentStreak); currentStreak = 1; }
                }
                maxArtStreak = Math.max(maxArtStreak, currentStreak);
                if (maxArtStreak > maxStreak) { maxStreak = maxArtStreak; streakArtist = art; }
            });
            // Dominator is the artist with the most total weekly top positions across all weeks
            const topArtist = weeklyStatsData && weeklyStatsData.artists && weeklyStatsData.artists.length > 0 ? weeklyStatsData.artists[0] : null;
            const dominator = topArtist ? { artist: topArtist.name, count: topArtist.count, percentage: topArtist.percentage } : { artist: '—', count: 0, percentage: '0%' };
            
            return {
                dominator: dominator,
                streak: { artist: streakArtist, streak: maxStreak },
                bpm: { bpm: Math.round(maxBpm), week: maxBpmWeek },
                acoustic: { acoustic: Math.round(maxAcoustic * 100), week: maxAcousticWeek }
            };
        }

        function renderWeeklyAchievements() {
            const grid = document.getElementById('weekly-achievements-grid');
            if (!grid) return;
            const ach = getWeeklyAchievements();
            grid.innerHTML = `
