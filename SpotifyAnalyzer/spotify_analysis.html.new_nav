                            </h4>
                            
                            <div style="display: flex; align-items: flex-end; justify-content: center; gap: 20px; height: 220px; width: 100%; max-width: 400px; padding-bottom: 10px;">
                                
                                <!-- 2nd Place (Silver) -->
                                <div style="display: flex; flex-direction: column; align-items: center; width: 90px;">
                                    <div id="podium-track-2-name" style="font-size: 11px; font-weight: 700; text-align: center; margin-bottom: 10px; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 85px;">—</div>
                                    <div style="width: 42px; height: 42px; border-radius: 50%; background: var(--panel-bg); border: 2px solid #c0c0c0; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; box-shadow: 0 0 10px rgba(192, 192, 192, 0.2);">
                                        <i class="fas fa-compact-disc" style="color: #c0c0c0; font-size: 18px;"></i>
                                    </div>
                                    <div style="width: 75px; height: 80px; background: linear-gradient(180deg, rgba(192, 192, 192, 0.2) 0%, rgba(192, 192, 192, 0.03) 100%); border: 1px solid rgba(192, 192, 192, 0.3); border-top-left-radius: 12px; border-top-right-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                        <span style="font-size: 22px; font-weight: 900; color: #c0c0c0; text-shadow: 0 0 8px rgba(192, 192, 192, 0.4);">2</span>
                                        <span id="podium-track-2-score" style="font-size: 9px; color: var(--text-muted); font-weight: 600; margin-top: 4px;">—</span>
                                    </div>
                                </div>
                                
                                <!-- 1st Place (Gold) -->
                                <div style="display: flex; flex-direction: column; align-items: center; width: 100px;">
                                    <i class="fas fa-crown" style="color: #ffd700; font-size: 14px; margin-bottom: 4px; filter: drop-shadow(0 0 5px rgba(255, 215, 0, 0.5)); animation: float-crown 2s infinite ease-in-out;"></i>
                                    <div id="podium-track-1-name" style="font-size: 12px; font-weight: 800; text-align: center; margin-bottom: 10px; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 95px;">—</div>
                                    <div style="width: 50px; height: 50px; border-radius: 50%; background: var(--panel-bg); border: 2px solid #ffd700; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; box-shadow: 0 0 15px rgba(255, 215, 0, 0.3);">
