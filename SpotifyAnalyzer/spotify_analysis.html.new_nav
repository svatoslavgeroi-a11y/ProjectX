                                <!-- 3rd Place (Bronze) -->
                                <div style="display: flex; flex-direction: column; align-items: center; width: 90px;">
                                    <div id="podium-track-3-name" style="font-size: 11px; font-weight: 700; text-align: center; margin-bottom: 10px; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 85px;">—</div>
                                    <div style="width: 42px; height: 42px; border-radius: 50%; background: var(--panel-bg); border: 2px solid #cd7f32; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; box-shadow: 0 0 10px rgba(205, 127, 50, 0.2);">
                                        <i class="fas fa-headphones" style="color: #cd7f32; font-size: 16px;"></i>
                                    </div>
                                    <div style="width: 75px; height: 60px; background: linear-gradient(180deg, rgba(205, 127, 50, 0.2) 0%, rgba(205, 127, 50, 0.03) 100%); border: 1px solid rgba(205, 127, 50, 0.3); border-top-left-radius: 12px; border-top-right-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                        <span style="font-size: 18px; font-weight: 900; color: #cd7f32; text-shadow: 0 0 6px rgba(205, 127, 50, 0.3);">3</span>
                                        <span id="podium-track-3-score" style="font-size: 9px; color: var(--text-muted); font-weight: 600; margin-top: 4px;">—</span>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </section>

                <div class="evolution-header">
                    <div class="evolution-title"
                        style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-chart-line"></i>
                            <span>Эволюция Артистов в Топ-Чартах</span>
                        </div>
                        <button id="btn-show-achievements" class="achievements-summary-btn"
                            onclick="openAchievementsModal()">
                            <i class="fas fa-medal"></i> 🏆 Зал Музыкальной Славы
                        </button>
                    </div>
                    <div class="artist-select-container"
                        style="display: flex; flex-wrap: wrap; gap: 15px; align-items: center;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span class="artist-select-label">Артист 1:</span>
                            <select id="artistSelect" class="artist-select" style="min-width: 180px;">
                                <!-- Dynamic select options -->
                            </select>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span class="artist-select-label" style="color: #ff007f;"><i class="fas fa-crosshairs"></i>
                                Оппонент (Дуэль):</span>
                            <select id="artistSelect2" class="artist-select"
                                style="min-width: 180px; border-color: rgba(255, 0, 127, 0.3) !important;">
                                <option value="">Не выбран</option>
                                <!-- Dynamic select options -->
                            </select>
                        </div>
                        <div class="chart-width-control">
                            <span class="chart-width-label">Ширина графика: <span id="widthValue">100%</span></span>
                            <input type="range" id="chartWidthSlider" min="100" max="300" value="100"
                                class="chart-width-slider">
                        </div>
                    </div>
                </div>

                <!-- Music Impulse Widget -->
                <div class="music-impulse-widget">
                    <div class="impulse-title">
                        <i class="fas fa-bolt" style="color: #ffb703;"></i>
                        <span>Музыкальный Импульс: Тренды и Взлеты Месяца</span>
                    </div>
                    <div class="impulse-columns">
                        <!-- Column 1: Rockets -->
                        <div class="impulse-col rockets-col">
                            <div class="col-header">
                                <i class="fas fa-rocket" style="color: #2ecc71;"></i>
                                <span>🚀 Ракеты месяца (Взлеты)</span>
                            </div>
                            <div class="col-body" id="rockets-list">
                                <!-- Dynamic JS render -->
                            </div>
                        </div>
                        <!-- Column 2: Stars -->
                        <div class="impulse-col stars-col">
                            <div class="col-header">
                                <i class="fas fa-meteor" style="color: #e74c3c;"></i>
                                <span>☄️ Падающие звезды (Падения)</span>
                            </div>
                            <div class="col-body" id="stars-list">
                                <!-- Dynamic JS render -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Artist Stats Overview -->
                <div class="artist-stats-grid">
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-trophy"></i></div>
                        <div class="metric-title">Среднее Место</div>
                        <div id="stat-avg-rank" class="metric-value stat-badge-rank">-</div>
                        <div class="metric-sub"><i class="fas fa-star"></i> За всё время в топах</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-baby"></i></div>
                        <div class="metric-title">Дебютный месяц</div>
                        <div id="stat-debut" class="metric-value"
                            style="font-size: 20px; font-weight: 700; color: var(--text-main); margin-top: 10px;">-
                        </div>
                        <div class="metric-sub"><i class="fas fa-history"></i> Первое появление в топе</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-award"></i></div>
                        <div class="metric-title">Лучший Результат</div>
                        <div id="stat-best-rank" class="metric-value"
                            style="font-size: 24px; font-weight: 800; color: var(--spotify-green); margin-top: 10px;">-
                        </div>
                        <div class="metric-sub"><i class="fas fa-crown"></i> Пиковая позиция</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-clock"></i></div>
                        <div class="metric-title">Месяцев в Топе</div>
                        <div id="stat-active-ratio" class="metric-value"
                            style="font-size: 22px; font-weight: 700; color: var(--accent-cyan); margin-top: 10px;">-
                        </div>
                        <div class="metric-sub"><i class="fas fa-calendar-alt"></i> Удержание популярности</div>
                    </div>
                </div>

                <!-- Achievements badges container -->
                <div id="artist-badges" class="badges-container"
                    style="display: none; margin-bottom: 25px; margin-top: 5px; gap: 15px; flex-wrap: wrap; width: 100%;">
                </div>

                <!-- Evolution Main Layout with Sidebar -->
                <div class="evolution-main-layout">
                    <!-- Left column for all artist charts -->
                    <div class="charts-column" style="width: 100%; display: flex; flex-direction: column; gap: 20px;">

                        <div style="display: flex; gap: 20px; flex-wrap: wrap; width: 100%;">
                            <!-- Chart 1: Places in Top -->
                            <div class="chart-box" style="height: 450px; flex: 2 1 600px; min-width: 320px;">
                                <div class="chart-title">
                                    <i class="fas fa-chart-area"></i>
                                    <span>История исполнителей (Гонка по местам в топе: 1-50 место)</span>
                                </div>
                                <div class="chart-container"
                                    style="height: calc(100% - 40px); position: relative; overflow-x: auto; overflow-y: hidden;">
                                    <div id="chartScrollWrapper" style="width: 100%; height: 100%; min-width: 100%;">
                                        <canvas id="artistChart"></canvas>
                                    </div>
                                </div>
                            </div>

                            <!-- Chart 1.5: Duel Radar Chart -->
                            <div class="chart-box" style="height: 450px; flex: 1 1 350px; min-width: 300px;">
                                <div class="chart-title">
                                    <i class="fas fa-crosshairs" style="color: #ff007f;"></i>
                                    <span>📊 Радар музыкального вайба (Дуэль)</span>
                                </div>
                                <div class="chart-container"
                                    style="height: calc(100% - 40px); position: relative; padding: 10px; display: flex; align-items: center; justify-content: center;">
                                    <canvas id="duelRadarChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Chart 2: Average Places of Tracks -->
                        <div class="chart-box" style="height: 450px; width: 100%;">
                            <div class="chart-title">
                                <i class="fas fa-music"></i>
                                <span>История исполнителей (Среднее место треков по месяцам: 1-50 место)</span>
                            </div>
                            <div class="chart-container"
                                style="height: calc(100% - 40px); position: relative; overflow-x: auto; overflow-y: hidden;">
                                <div id="chartTracksScrollWrapper" style="width: 100%; height: 100%; min-width: 100%;">
                                    <canvas id="artistTracksChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Chart 3: Vibe DNA (Vibe Timeline) -->
                        <div class="chart-box" style="height: 450px; width: 100%;">
                            <div class="chart-title">
                                <i class="fas fa-dna"></i>
                                <span>📊 Музыкальное ДНК (Вайб-таймлайн)</span>
                            </div>
                            <div class="chart-container"
                                style="height: calc(100% - 40px); position: relative; overflow-x: auto; overflow-y: hidden;">
                                <div id="chartVibeDnaScrollWrapper" style="width: 100%; height: 100%; min-width: 100%;">
                                    <canvas id="vibeDnaChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Heatmap widget: Artist domination heatmap -->
                        <div class="chart-box" style="height: auto; width: 100%; min-height: 250px;">
                            <div class="chart-title"
                                style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <i class="fas fa-th" style="color: var(--spotify-green);"></i>
                                    <span>🔥 Тепловая карта доминирования артистов (GitHub Style)</span>
                                </div>
                                <div class="heatmap-legend"
                                    style="display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--text-muted);">
                                    <span>Вне топа</span>
                                    <div style="width: 10px; height: 10px; background-color: #161b22; border-radius: 2px;"
                                        title="Вылетел/Нет в топе"></div>
                                    <div style="width: 10px; height: 10px; background-color: #0e4429; border-radius: 2px;"
                                        title="31-50 место"></div>
                                    <div style="width: 10px; height: 10px; background-color: #006d32; border-radius: 2px;"
                                        title="16-30 место"></div>
                                    <div style="width: 10px; height: 10px; background-color: #26a641; border-radius: 2px;"
                                        title="4-15 место"></div>
                                    <div style="width: 10px; height: 10px; background-color: #39d353; border-radius: 2px;"
                                        title="1-3 место"></div>
                                    <span>Топ-1</span>
                                </div>
                            </div>
                            <div class="chart-container" style="height: auto; overflow: visible; padding: 10px 0;">
                                <div id="artist-heatmap" class="heatmap-wrapper"></div>
                            </div>
                        </div>

                    </div>

                    <!-- Sidebar Artist List Widget -->
                    <div class="artist-sidebar-widget" id="sidebarWidget">
                        <div class="sidebar-title">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <i class="fas fa-list-ol"></i>
                                <span>Рейтинг по среднему месту</span>
                            </div>
                            <div class="sidebar-sort-controls">
                                <button id="sort-by-rank" class="sidebar-sort-btn active"
                                    title="Сортировать по рейтингу">
                                    <i class="fas fa-sort-numeric-down"></i>
                                </button>
                                <button id="sort-by-alpha" class="sidebar-sort-btn" title="Сортировать по алфавиту">
                                    <i class="fas fa-sort-alpha-down"></i>
                                </button>
                            </div>
                        </div>
                        <div class="sidebar-list" id="sidebarArtistList">
                            <!-- Dynamic list of artists will be injected here -->
                        </div>
                    </div>

                    <!-- Sidebar Track List Widget -->
                    <div class="artist-sidebar-widget" id="sidebarTrackWidget">
                        <div class="sidebar-title">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <i class="fas fa-music"></i>
                                <span>Топовые треки (3+ мес. в Топе)</span>
                            </div>
                        </div>
                        <div class="sidebar-list" id="sidebarTrackList">
                            <!-- Dynamic list of tracks will be injected here -->
                        </div>
                    </div>
                </div>
            </div>
        </div> <!-- End of pane-evolution -->

        <!-- Weekly Charts Tab Pane -->
        <div id="pane-weekly" class="tab-pane">
            <div class="weekly-charts-container">
                <div class="weekly-header">
                    <div class="weekly-title-wrap">
                        <i class="fas fa-calendar-alt" style="color: var(--spotify-green); font-size: 24px;"></i>
                        <span class="weekly-title">Недельные Чарты</span>
                    </div>
                    <div class="weekly-select-container">
                        <span class="weekly-select-label">Выберите неделю:</span>
                        <select id="weeklySelect" class="weekly-select" onchange="updateWeeklyCharts(this.value)">
                            <!-- Dynamic select options -->
                        </select>
                    </div>
                </div>

                <div class="weekly-grid">
                    <!-- Column 1: Top 5 Artists -->
                    <div class="weekly-card">
                        <div class="weekly-card-header">
                            <i class="fas fa-trophy" style="color: #ffb703;"></i>
                            <span>🏆 Топ-5 Исполнителей Недели</span>
                        </div>
                        <div class="weekly-card-body">
                            <ul class="weekly-list" id="weekly-artists-list">
                                <!-- Dynamic JS render -->
                            </ul>
                        </div>
                    </div>

                    <!-- Column 2: Top 5 Tracks -->
                    <div class="weekly-card">
                        <div class="weekly-card-header">
                            <i class="fas fa-music" style="color: var(--accent-cyan);"></i>
                            <span>🎵 Топ-5 Треков Недели</span>
                        </div>
                        <div class="weekly-card-body">
                            <ul class="weekly-list" id="weekly-tracks-list">
                                <!-- Dynamic JS render -->
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Weekly Detective Card -->
                <div class="weekly-card" style="margin-top: 25px; width: 100%;">
                    <div class="weekly-card-header"
                        style="justify-content: space-between; flex-wrap: wrap; gap: 15px; border-bottom: 1px solid var(--panel-border); padding-bottom: 18px; margin-bottom: 20px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <i class="fas fa-search" style="color: var(--spotify-green); font-size: 20px;"></i>
                            <span style="font-size: 18px; font-weight: 700;">🔍 Недельный Детектив: Трекер Артистов по
                                Неделям</span>
                        </div>
                        <div class="weekly-select-container">
                            <span class="weekly-select-label">Артист:</span>
                            <select id="detectiveArtistSelect" class="weekly-select"
                                onchange="updateArtistTimeline(this.value)">
                                <!-- Dynamic options -->
                            </select>
                        </div>
                    </div>
                    <div class="weekly-card-body" style="display: flex; flex-direction: column; gap: 20px;">
                        <!-- Summary Stats Row -->
                        <div class="detective-stats-grid"
                            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                            <div class="detective-stat-card"
                                style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 15px; text-align: center;">
                                <div style="color: var(--text-muted); font-size: 13px; font-weight: 500;">Всего недель в
                                    Топ-5</div>
                                <div id="det-weeks-count"
                                    style="font-size: 28px; font-weight: 800; color: var(--spotify-green); margin-top: 5px;">
                                    0</div>
                            </div>
                            <div class="detective-stat-card"
                                style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 15px; text-align: center;">
                                <div style="color: var(--text-muted); font-size: 13px; font-weight: 500;">Лучшая позиция
                                </div>
                                <div id="det-best-rank"
                                    style="font-size: 28px; font-weight: 800; color: #ffb703; margin-top: 5px;">—</div>
                            </div>
                            <div class="detective-stat-card"
                                style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 15px; text-align: center;">
                                <div style="color: var(--text-muted); font-size: 13px; font-weight: 500;">Главный хит
                                    недели</div>
                                <div id="det-frequent-track"
                                    style="font-size: 16px; font-weight: 700; color: var(--accent-cyan); margin-top: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: center;">
                                    —</div>
                            </div>
                        </div>

                        <!-- Timeline Scrollable Track -->
                        <div class="detective-timeline-container"
                            style="overflow-x: auto; padding: 20px 10px; background: rgba(0, 0, 0, 0.2); border-radius: 16px; border: 1px solid var(--panel-border); margin-top: 10px;">
                            <div id="detective-timeline"
                                style="display: flex; gap: 20px; min-width: max-content; align-items: flex-start; padding-bottom: 5px;">
                                <!-- Timeline nodes injected by JS -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Weekly Showdown Card -->
                <div class="weekly-card" style="margin-top: 25px; width: 100%;">
                    <div class="weekly-card-header" style="justify-content: space-between; flex-wrap: wrap; gap: 15px; border-bottom: 1px solid var(--panel-border); padding-bottom: 18px; margin-bottom: 20px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <i class="fas fa-bolt" style="color: #ffb703; font-size: 20px;"></i>
                            <span style="font-size: 18px; font-weight: 700;">⚡ Битва Недель: Музыкальный Баттл</span>
                        </div>
                        <div style="display: flex; gap: 15px; align-items: center; flex-wrap: wrap;">
                            <div class="weekly-select-container">
                                <span class="weekly-select-label">Неделя A:</span>
                                <select id="showdownWeekA" class="weekly-select" onchange="updateWeeklyShowdown()">
                                    <!-- Options -->
                                </select>
                            </div>
                            <div style="font-weight: 800; color: var(--text-muted); font-size: 14px;">VS</div>
                            <div class="weekly-select-container">
                                <span class="weekly-select-label">Неделя B:</span>
                                <select id="showdownWeekB" class="weekly-select" onchange="updateWeeklyShowdown()">
                                    <!-- Options -->
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="weekly-card-body" style="display: flex; flex-direction: column; gap: 20px;">
                        <!-- Side-by-Side Vibe Comparison Bars -->
                        <div style="display: flex; flex-direction: column; gap: 16px;">
                            <!-- Energy Showdown -->
                            <div>
                                <div style="display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; margin-bottom: 6px;">
                                    <span id="showdown-energy-val-a" style="color: #FF6B6B;">50%</span>
                                    <span>💥 Энергия (Energy)</span>
                                    <span id="showdown-energy-val-b" style="color: #00F5FF;">50%</span>
                                </div>
                                <div style="display: flex; height: 8px; border-radius: 4px; overflow: hidden; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.03);">
                                    <div id="showdown-energy-bar-a" style="width: 50%; background: linear-gradient(90deg, #FF6B6B, #ff8787); transition: width 0.4s ease;"></div>
                                    <div style="width: 2px; background: rgba(0, 0, 0, 0.3);"></div>
                                    <div id="showdown-energy-bar-b" style="width: 50%; background: linear-gradient(270deg, #00F5FF, #33f8ff); margin-left: auto; transition: width 0.4s ease;"></div>
                                </div>
                            </div>
                            
                            <!-- Danceability Showdown -->
                            <div>
                                <div style="display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; margin-bottom: 6px;">
                                    <span id="showdown-dance-val-a" style="color: #FF6B6B;">50%</span>
                                    <span>🕺 Танцевальность (Danceability)</span>
                                    <span id="showdown-dance-val-b" style="color: #00F5FF;">50%</span>
                                </div>
                                <div style="display: flex; height: 8px; border-radius: 4px; overflow: hidden; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.03);">
                                    <div id="showdown-dance-bar-a" style="width: 50%; background: linear-gradient(90deg, #FF6B6B, #ff8787); transition: width 0.4s ease;"></div>
                                    <div style="width: 2px; background: rgba(0, 0, 0, 0.3);"></div>
                                    <div id="showdown-dance-bar-b" style="width: 50%; background: linear-gradient(270deg, #00F5FF, #33f8ff); margin-left: auto; transition: width 0.4s ease;"></div>
                                </div>
                            </div>
                            
                            <!-- Valence Showdown -->
                            <div>
                                <div style="display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; margin-bottom: 6px;">
                                    <span id="showdown-valence-val-a" style="color: #FF6B6B;">50%</span>
                                    <span>☀️ Позитив (Valence)</span>
                                    <span id="showdown-valence-val-b" style="color: #00F5FF;">50%</span>
                                </div>
                                <div style="display: flex; height: 8px; border-radius: 4px; overflow: hidden; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.03);">
                                    <div id="showdown-valence-bar-a" style="width: 50%; background: linear-gradient(90deg, #FF6B6B, #ff8787); transition: width 0.4s ease;"></div>
                                    <div style="width: 2px; background: rgba(0, 0, 0, 0.3);"></div>
                                    <div id="showdown-valence-bar-b" style="width: 50%; background: linear-gradient(270deg, #00F5FF, #33f8ff); margin-left: auto; transition: width 0.4s ease;"></div>
                                </div>
                            </div>
                            
                            <!-- BPM Showdown -->
                            <div>
                                <div style="display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; margin-bottom: 6px;">
                                    <span id="showdown-bpm-val-a" style="color: #FF6B6B;">120 BPM</span>
                                    <span>⚡ Средний темп (BPM)</span>
                                    <span id="showdown-bpm-val-b" style="color: #00F5FF;">120 BPM</span>
                                </div>
                                <div style="display: flex; height: 8px; border-radius: 4px; overflow: hidden; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.03);">
                                    <div id="showdown-bpm-bar-a" style="width: 50%; background: linear-gradient(90deg, #FF6B6B, #ff8787); transition: width 0.4s ease;"></div>
                                    <div style="width: 2px; background: rgba(0, 0, 0, 0.3);"></div>
                                    <div id="showdown-bpm-bar-b" style="width: 50%; background: linear-gradient(270deg, #00F5FF, #33f8ff); margin-left: auto; transition: width 0.4s ease;"></div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Common Ground and Verdict Box -->
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 10px;">
                            <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 18px;">
                                <div style="font-weight: 700; font-size: 14px; margin-bottom: 10px; color: var(--spotify-green); display: flex; align-items: center; gap: 8px;">
                                    <i class="fas fa-handshake"></i> Точки пересечения
                                </div>
                                <div id="showdown-common-ground">
                                    <!-- Injected by JS -->
                                </div>
                            </div>
                            <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 18px;">
                                <div style="font-weight: 700; font-size: 14px; margin-bottom: 10px; color: #ffb703; display: flex; align-items: center; gap: 8px;">
                                    <i class="fas fa-gavel"></i> Музыкальный вердикт
                                </div>
                                <div id="showdown-verdict" style="font-size: 13px; line-height: 1.5; color: var(--text-main);">
                                    <!-- Injected by JS -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Weekly Cumulative Statistics Card (Chart & Table) -->
                <div class="weekly-card" style="margin-top: 25px; width: 100%;">
                    <div class="weekly-card-header"
                        style="justify-content: space-between; flex-wrap: wrap; gap: 15px; border-bottom: 1px solid var(--panel-border); padding-bottom: 18px; margin-bottom: 20px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <i class="fas fa-chart-bar" style="color: var(--spotify-green); font-size: 20px;"></i>
                            <span style="font-size: 18px; font-weight: 700;">📊 Лидеры Недельных Топов (Сводная
                                Статистика)</span>
                        </div>
                        <div style="display: flex; gap: 8px;">
                            <button id="weeklyStatsTabArtists" onclick="switchWeeklyStatsTab('artists')"
                                class="tag-btn active" style="font-size: 12px; padding: 6px 14px;">
                                <i class="fas fa-users"></i> Артисты
                            </button>
                            <button id="weeklyStatsTabSongs" onclick="switchWeeklyStatsTab('songs')" class="tag-btn"
                                style="font-size: 12px; padding: 6px 14px;">
                                <i class="fas fa-music"></i> Песни
                            </button>
                            <button id="weeklyStatsTabVibe" onclick="switchWeeklyStatsTab('vibe')" class="tag-btn"
                                style="font-size: 12px; padding: 6px 14px;">
                                <i class="fas fa-brain"></i> Эволюция Вайба
                            </button>
                        </div>
                    </div>
                    <div class="weekly-card-body">
                        <div class="weekly-stats-layout">
                            <!-- Left Side: Chart -->
                            <div class="weekly-stats-chart-wrap"
                                style="background: rgba(0, 0, 0, 0.15); padding: 20px; border-radius: 16px; border: 1px solid var(--panel-border); position: relative; min-height: 380px; display: flex; align-items: center; justify-content: center;">
                                <canvas id="weeklyStatsChart" style="max-height: 350px; width: 100%;"></canvas>
                            </div>

                            <!-- Right Side: Table -->
                            <div class="weekly-stats-table-wrap"
                                style="overflow-x: auto; background: rgba(0, 0, 0, 0.15); border-radius: 16px; border: 1px solid var(--panel-border); padding: 15px;">
                                <table class="premium-table"
                                    style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14px;">
                                    <thead>
                                        <tr
                                            style="border-bottom: 2px solid var(--panel-border); color: var(--text-muted); font-weight: 600;">
                                            <th style="padding: 12px 10px; width: 60px;">Место</th>
                                            <th id="weekly-table-header-name" style="padding: 12px 10px;">Исполнитель
                                            </th>
                                            <th style="padding: 12px 10px; text-align: center; width: 150px;">Попаданий
                                                в Топ-5</th>
                                            <th style="padding: 12px 10px; text-align: center; width: 100px;">Доля
                                                недель</th>
                                        </tr>
                                    </thead>
                                    <tbody id="weekly-stats-table-body">
                                        <!-- Injected dynamically by JS -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Weekly Achievements Card -->
                <div class="weekly-card" style="margin-top: 25px; width: 100%;">
                    <div class="weekly-card-header" style="border-bottom: 1px solid var(--panel-border); padding-bottom: 18px; margin-bottom: 20px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <i class="fas fa-trophy" style="color: #FFD700; font-size: 20px;"></i>
                            <span style="font-size: 18px; font-weight: 700;">🏆 Зал Музыкальной Славы (Достижения Чартов)</span>
                        </div>
                    </div>
                    <div class="weekly-card-body">
                        <div id="weekly-achievements-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
                            <!-- Injected dynamically by JS -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pane: Vibes Mixer -->
        <div id="pane-vibes-mixer" class="tab-pane">
            <div class="evolution-wrapper">
                <div class="evolution-header" style="margin-bottom: 25px;">
                    <div class="evolution-title">
                        <i class="fas fa-blender" style="color: var(--spotify-green);"></i>
                        <span>🔮 Вайб-Коктейль & Генератор Настроения</span>
                    </div>
                    <p
                        style="color: var(--text-muted); font-size: 14px; margin: 5px 0 0 0; font-family: 'Outfit', sans-serif;">
                        Настройте слайдеры ритма, энергии и позитива, чтобы смикшировать идеальный плейлист из вашей
                        медиатеки!
                    </p>
                </div>

                <div
                    style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 30px;">
                    <!-- Left Column: Mixer Controls -->
                    <div
                        style="background: var(--card-bg); border: 1px solid var(--panel-border); padding: 25px; border-radius: 16px; display: flex; flex-direction: column; gap: 20px; box-shadow: var(--card-shadow);">
                        <h3
                            style="margin: 0; color: var(--text-main); font-size: 18px; font-family: 'Outfit', sans-serif; border-bottom: 1px solid var(--panel-border); padding-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-sliders-h" style="color: var(--spotify-green);"></i> Настройки Вайба
                        </h3>

                        <!-- Control: Rhythm (Danceability) -->
                        <div>
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-family: 'Outfit', sans-serif;">
                                <span
                                    style="font-weight: 600; color: var(--text-main); display: flex; align-items: center; gap: 6px;"><i
                                        class="fas fa-walking" style="color: #00F5FF;"></i> Ритмичность (Dance)</span>
                                <span id="valMixDance" style="color: #00F5FF; font-weight: 700;">60%</span>
                            </div>
                            <input type="range" id="sliderMixDance" min="0" max="100" value="60"
                                oninput="document.getElementById('valMixDance').textContent = this.value + '%'; autoMixVibe();"
                                style="width: 100%; accent-color: #00F5FF; background: var(--panel-border); border-radius: 4px; height: 6px; outline: none; transition: background 0.3s;">
                        </div>

                        <!-- Control: Energy -->
                        <div>
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-family: 'Outfit', sans-serif;">
                                <span
                                    style="font-weight: 600; color: var(--text-main); display: flex; align-items: center; gap: 6px;"><i
                                        class="fas fa-bolt" style="color: #FFB300;"></i> Энергичность (Energy)</span>
                                <span id="valMixEnergy" style="color: #FFB300; font-weight: 700;">60%</span>
                            </div>
                            <input type="range" id="sliderMixEnergy" min="0" max="100" value="60"
                                oninput="document.getElementById('valMixEnergy').textContent = this.value + '%'; autoMixVibe();"
                                style="width: 100%; accent-color: #FFB300; background: var(--panel-border); border-radius: 4px; height: 6px; outline: none; transition: background 0.3s;">
                        </div>

                        <!-- Control: Valence -->
                        <div>
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-family: 'Outfit', sans-serif;">
                                <span
                                    style="font-weight: 600; color: var(--text-main); display: flex; align-items: center; gap: 6px;"><i
                                        class="fas fa-sun" style="color: #00E676;"></i> Настроение / Позитив
                                    (Valence)</span>
                                <span id="valMixValence" style="color: #00E676; font-weight: 700;">50%</span>
                            </div>
                            <input type="range" id="sliderMixValence" min="0" max="100" value="50"
                                oninput="document.getElementById('valMixValence').textContent = this.value + '%'; autoMixVibe();"
                                style="width: 100%; accent-color: #00E676; background: var(--panel-border); border-radius: 4px; height: 6px; outline: none; transition: background 0.3s;">
                        </div>

                        <!-- Control: Acousticness -->
                        <div>
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-family: 'Outfit', sans-serif;">
                                <span
                                    style="font-weight: 600; color: var(--text-main); display: flex; align-items: center; gap: 6px;"><i
                                        class="fas fa-guitar" style="color: #BF5FFF;"></i> Акустичность
                                    (Acoustic)</span>
                                <span id="valMixAcoustic" style="color: #BF5FFF; font-weight: 700;">30%</span>
                            </div>
                            <input type="range" id="sliderMixAcoustic" min="0" max="100" value="30"
                                oninput="document.getElementById('valMixAcoustic').textContent = this.value + '%'; autoMixVibe();"
                                style="width: 100%; accent-color: #BF5FFF; background: var(--panel-border); border-radius: 4px; height: 6px; outline: none; transition: background 0.3s;">
                        </div>
                    </div>

                    <!-- Right Column: Quick Vibe Presets & Wheel of Fortune -->
                    <div
                        style="background: var(--card-bg); border: 1px solid var(--panel-border); padding: 25px; border-radius: 16px; display: flex; flex-direction: column; gap: 20px; box-shadow: var(--card-shadow);">
                        <h3
                            style="margin: 0; color: var(--text-main); font-size: 18px; font-family: 'Outfit', sans-serif; border-bottom: 1px solid var(--panel-border); padding-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-magic" style="color: var(--spotify-green);"></i> Готовые Рецепты и
                            Вайб-Рулетка
                        </h3>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <button onclick="applyPresetRecipe(85, 90, 80, 10)" class="btn-preset-vibe"
                                style="display: flex; flex-direction: column; align-items: center; gap: 6px; background: var(--panel-bg); border: 1px solid var(--panel-border); color: var(--text-main); padding: 12px; border-radius: 12px; cursor: pointer; transition: all 0.3s; font-family: 'Outfit', sans-serif;">
                                <span style="font-size: 20px;">🏋️‍♂️</span>
                                <span style="font-size: 12px; font-weight: 700;">Тренировка</span>
                            </button>
                            <button onclick="applyPresetRecipe(15, 10, 20, 85)" class="btn-preset-vibe"
                                style="display: flex; flex-direction: column; align-items: center; gap: 6px; background: var(--panel-bg); border: 1px solid var(--panel-border); color: var(--text-main); padding: 12px; border-radius: 12px; cursor: pointer; transition: all 0.3s; font-family: 'Outfit', sans-serif;">
                                <span style="font-size: 20px;">🌌</span>
                                <span style="font-size: 12px; font-weight: 700;">Чилл Дзен</span>
                            </button>
                            <button onclick="applyPresetRecipe(95, 85, 90, 5)" class="btn-preset-vibe"
                                style="display: flex; flex-direction: column; align-items: center; gap: 6px; background: var(--panel-bg); border: 1px solid var(--panel-border); color: var(--text-main); padding: 12px; border-radius: 12px; cursor: pointer; transition: all 0.3s; font-family: 'Outfit', sans-serif;">
                                <span style="font-size: 20px;">💃</span>
                                <span style="font-size: 12px; font-weight: 700;">Ночной Клуб</span>
                            </button>
                            <button onclick="applyPresetRecipe(40, 20, 10, 60)" class="btn-preset-vibe"
                                style="display: flex; flex-direction: column; align-items: center; gap: 6px; background: var(--panel-bg); border: 1px solid var(--panel-border); color: var(--text-main); padding: 12px; border-radius: 12px; cursor: pointer; transition: all 0.3s; font-family: 'Outfit', sans-serif;">
                                <span style="font-size: 20px;">🌧️</span>
                                <span style="font-size: 12px; font-weight: 700;">Меланхолия</span>
                            </button>
                        </div>

                        <!-- Vibe Roulette -->
                        <div
                            style="margin-top: 10px; border-top: 1px solid var(--panel-border); padding-top: 20px; display: flex; flex-direction: column; gap: 10px; align-items: center;">
                            <button onclick="spinVibeRoulette()" class="roulette-btn"
                                style="background: linear-gradient(135deg, #00F5FF 0%, #BF5FFF 100%); color: #000; border: none; padding: 12px 24px; border-radius: 30px; font-weight: 800; font-size: 14px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-family: 'Outfit', sans-serif; transition: all 0.3s; box-shadow: 0 0 15px rgba(0, 245, 255, 0.3);">
                                <i class="fas fa-random"></i> 🎯 Испытать Удачу (Вайб-Рулетка)
                            </button>
                            <p
                                style="color: var(--text-muted); font-size: 12px; margin: 0; font-family: 'Outfit', sans-serif; text-align: center;">
                                Случайный трек с праздничной анимацией и автоматическим открытием характеристик!
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Chosic-style BPM & Vibe Curator Card -->
                <div class="weekly-card" style="margin-bottom: 30px; width: 100%; display: grid; grid-template-columns: 1fr 2fr; gap: 30px; align-items: center; flex-wrap: wrap;">
                    <!-- Left: BPM Beats Visualizer -->
                    <div style="display: flex; flex-direction: column; align-items: center; text-align: center; padding: 15px;">
                        <div id="bpm-pulse-circle" style="width: 120px; height: 120px; border-radius: 50%; background: radial-gradient(circle at 30% 30%, #1DB954 0%, #191414 100%); border: 3px solid rgba(29, 185, 84, 0.4); display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; box-shadow: 0 0 25px rgba(29, 185, 84, 0.3); transition: all 0.3s ease; animation: pulse 0.5s infinite ease-in-out;">
                            <i class="fas fa-heartbeat" style="color: #fff; font-size: 32px; margin-bottom: 4px;"></i>
                            <span id="bpm-pulse-value" style="font-size: 18px; font-weight: 800; color: #fff; font-family: 'Outfit', sans-serif;">120</span>
                            <span style="font-size: 9px; font-weight: 700; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.5px;">BPM</span>
                        </div>
                        <div style="font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 15px;">Умный BPM-Куратор</div>
                    </div>
                    
                    <!-- Right: Curate controls -->
                    <div style="display: flex; flex-direction: column; gap: 15px; align-items: flex-start; width: 100%;">
                        <h3 style="margin: 0; color: var(--text-main); font-size: 20px; font-family: 'Outfit', sans-serif; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-sliders-h" style="color: var(--spotify-green);"></i> 🎯 Генератор Миксов Chosic (BPM & Вайб)
                        </h3>
                        <p style="color: var(--text-muted); font-size: 13.5px; margin: 0; text-align: left; line-height: 1.5; font-family: 'Outfit', sans-serif;">
                            Сгенерируйте сбалансированную подборку из 10 треков, настроив желаемый темп (BPM) и музыкальный вайб. Полученный плейлист можно мгновенно экспортировать!
                        </p>
                        
                        <!-- Inputs Grid -->
                        <div style="display: flex; gap: 20px; width: 100%; flex-wrap: wrap;">
                            <div style="flex: 1; min-width: 150px;">
                                <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px; letter-spacing: 0.5px;">Целевой Темп (BPM)</label>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <input type="range" id="curator-bpm-slider" min="60" max="200" value="120" oninput="updateCuratorBpm(this.value)" style="flex-grow: 1; accent-color: var(--spotify-green); cursor: pointer;">
                                </div>
                            </div>
                            <div style="width: 180px; min-width: 140px;">
                                <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px; letter-spacing: 0.5px;">Характер / Вайб</label>
                                <select id="curator-vibe-select" style="width: 100%; background: var(--panel-bg); border: 1px solid var(--panel-border); color: var(--text-main); padding: 8px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; outline: none; cursor: pointer; font-family: 'Outfit', sans-serif;">
                                    <option value="All">Все вайбы</option>
                                    <option value="Party">💃 Вечеринка (Party)</option>
                                    <option value="Chill">🌌 Чилл (Chill)</option>
                                    <option value="Focus">🧠 Концентрация (Focus)</option>
                                    <option value="Melancholic">🌧️ Меланхолия</option>
                                    <option value="Dark">🌑 Темный вайб</option>
                                </select>
                            </div>
                        </div>
                        
                        <button onclick="curateChosicMix()" style="background: linear-gradient(135deg, #1DB954 0%, #1ED760 100%); color: #000; border: none; padding: 12px 24px; border-radius: 30px; font-weight: 800; font-size: 14px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-family: 'Outfit', sans-serif; transition: all 0.3s; box-shadow: 0 0 15px rgba(29, 185, 84, 0.3);">
                            <i class="fas fa-bolt"></i> Сгенерировать Микс
                        </button>
                    </div>
                </div>

                <!-- Mysterious Musical Oracle Card -->
                <div class="weekly-card" style="margin-bottom: 30px; width: 100%; display: grid; grid-template-columns: 1fr 2fr; gap: 30px; align-items: center; flex-wrap: wrap;">
                    
                    <!-- Left: Crystal Ball -->
                    <div style="display: flex; flex-direction: column; align-items: center; text-align: center; padding: 15px;">
                        <div id="oracle-ball" onclick="askMusicalOracle()" style="width: 140px; height: 140px; border-radius: 50%; background: radial-gradient(circle at 30% 30%, #BF5FFF 0%, #00F5FF 55%, #0a0a0a 100%); box-shadow: 0 0 35px rgba(191, 95, 255, 0.45); display: flex; align-items: center; justify-content: center; position: relative; cursor: pointer; transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);">
                            <i class="fas fa-magic" style="color: #fff; font-size: 42px; text-shadow: 0 0 10px rgba(255,255,255,0.8); animation: pulse 2s infinite ease-in-out;"></i>
                        </div>
                        <div style="font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 15px;">Кликни на сферу</div>
                    </div>
                    
                    <!-- Right: Oracle controls & message -->
                    <div style="display: flex; flex-direction: column; gap: 15px; align-items: flex-start;">
                        <h3 style="margin: 0; color: var(--text-main); font-size: 20px; font-family: 'Outfit', sans-serif; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-quill" style="color: #BF5FFF;"></i> 🔮 Музыкальный Оракул Судьбы
                        </h3>
                        <p style="color: var(--text-muted); font-size: 13.5px; margin: 0; text-align: left; line-height: 1.5; font-family: 'Outfit', sans-serif;">
                            Спросите Оракула о вашей судьбе на сегодня! Он выберет случайный трек из вашей медиатеки и составит персональный музыкальный гороскоп, основанный на его аудио-характеристиках.
                        </p>
                        
                        <!-- Prediction display box -->
                        <div id="oracle-result" style="width: 100%; min-height: 80px; background: var(--panel-bg); border: 1px solid var(--panel-border); padding: 20px; border-radius: 14px; text-align: center; display: flex; flex-direction: column; justify-content: center; transition: all 0.3s ease;">
                            <span style="color: var(--text-muted); font-style: italic; font-size: 13.5px;">«Вглядись в хрустальную сферу и призови музыкальных духов...»</span>
                        </div>
                        
                        <div style="display: flex; gap: 12px; align-items: center;">
                            <button onclick="askMusicalOracle()" style="background: linear-gradient(135deg, #BF5FFF 0%, #00F5FF 100%); color: #000; border: none; padding: 12px 24px; border-radius: 30px; font-weight: 800; font-size: 14px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-family: 'Outfit', sans-serif; transition: all 0.3s; box-shadow: 0 0 15px rgba(191, 95, 255, 0.3);">
                                <i class="fas fa-star"></i> Спросить Оракула
                            </button>
                            <button id="oracle-play-btn" style="display: none; background: rgba(29, 185, 84, 0.15); color: var(--spotify-green); border: 1px solid rgba(29, 185, 84, 0.4); padding: 11px 22px; border-radius: 30px; font-weight: 700; font-size: 13.5px; cursor: pointer; align-items: center; gap: 8px; transition: all 0.3s;">
                                <i class="fas fa-play"></i> Слушать превью
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Mixed Results Grid -->
                <div
                    style="background: var(--card-bg); border: 1px solid var(--panel-border); padding: 25px; border-radius: 16px; box-shadow: var(--card-shadow);">
                    <h3
                        style="margin: 0 0 20px 0; color: var(--text-main); font-size: 18px; font-family: 'Outfit', sans-serif; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;">
                        <span style="display: flex; align-items: center; gap: 8px;"><i class="fas fa-glass-martini-alt"
                                style="color: var(--spotify-green);"></i> Результат Смешивания</span>
                        <span id="mixMatchCount"
                            style="font-size: 13px; color: var(--text-muted); font-weight: 400;">Найдены лучшие
                            совпадения</span>
                    </h3>

                    <div id="vibesMixerResults" class="tracks-grid"
                        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px;">
                        <!-- Match results injected dynamically by JS -->
                    </div>

                    <!-- Export Actions (Chosic style) -->
                    <div id="mixerExportTools" style="margin-top: 20px; border-top: 1px solid var(--panel-border); padding-top: 15px; display: none; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 15px;">
                        <span style="font-size: 13px; color: var(--text-muted); font-weight: 500;">
                            <i class="fas fa-info-circle"></i> Подборка готова! Вы можете экспортировать этот треклист.
                        </span>
                        <div style="display: flex; gap: 10px;">
                            <button onclick="exportMixList('csv')" style="background: rgba(29, 185, 84, 0.1); border: 1px solid rgba(29, 185, 84, 0.3); color: var(--spotify-green); padding: 8px 16px; border-radius: 20px; font-weight: 700; font-size: 12.5px; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.3s;" onmouseover="this.style.background='rgba(29, 185, 84, 0.18)'" onmouseout="this.style.background='rgba(29, 185, 84, 0.1)'">
                                <i class="fas fa-file-csv"></i> Экспорт в CSV
                            </button>
                            <button onclick="exportMixList('txt')" style="background: rgba(255, 255, 255, 0.05); border: 1px solid var(--panel-border); color: var(--text-main); padding: 8px 16px; border-radius: 20px; font-weight: 700; font-size: 12.5px; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.3s;" onmouseover="this.style.background='rgba(255, 255, 255, 0.1)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.05)'">
                                <i class="fas fa-file-alt"></i> Экспорт в TXT
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>



    <!-- Premium Details Modal Overlay -->
    <div id="detailsModal" class="modal-overlay" onclick="closeDetailsModal(event)">
        <div class="modal-container" onclick="event.stopPropagation()">
            <button class="modal-close" onclick="closeDetailsModal(event)">&times;</button>
            <div id="modalContent" class="modal-content">
                <!-- Dynamic contents injected by JavaScript -->
            </div>
        </div>
    </div>

    <!-- Achievements Hall of Fame Modal Overlay -->
    <div id="achievementsModal" class="modal-overlay" onclick="closeAchievementsModal(event)">
        <div class="modal-container" onclick="event.stopPropagation()" style="max-width: 800px; width: 95%;">
            <button class="modal-close" onclick="closeAchievementsModal(event)">&times;</button>
            <div class="modal-content">
                <div class="modal-header-premium"
                    style="display: flex; align-items: center; gap: 15px; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 15px; margin-bottom: 15px;">
                    <i class="fas fa-medal"
                        style="font-size: 28px; color: #FFD700; filter: drop-shadow(0 0 10px rgba(255,215,0,0.4));"></i>
                    <div>
                        <h2
                            style="margin: 0; font-family: 'Outfit', sans-serif; font-size: 22px; color: #fff; font-weight: 800; letter-spacing: 0.3px;">
                            🏆 Зал Музыкальной Славы</h2>
                        <p
                            style="margin: 4px 0 0 0; font-family: 'Outfit', sans-serif; font-size: 13px; color: var(--text-muted);">
                            Все уникальные достижения ваших любимых исполнителей и песен за всю историю</p>
                    </div>
                </div>

                <!-- Dynamic tabs inside Achievements modal -->
                <div
                    style="display: flex; gap: 10px; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px;">
                    <button id="achTabArtists" onclick="switchAchievementsTab('artists')"
                        style="background: var(--spotify-green); color: #000; border: none; padding: 8px 16px; border-radius: 20px; font-weight: 700; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-family: 'Outfit', sans-serif; transition: all 0.3s;">
                        <i class="fas fa-users"></i> Артисты
                    </button>
                    <button id="achTabSongs" onclick="switchAchievementsTab('songs')"
                        style="background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1); padding: 8px 16px; border-radius: 20px; font-weight: 700; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-family: 'Outfit', sans-serif; transition: all 0.3s;">
                        <i class="fas fa-music"></i> Песни
                    </button>
                </div>

                <div id="achievementsModalBody"
                    style="max-height: 500px; overflow-y: auto; padding-right: 8px; font-family: 'Outfit', sans-serif;">
                    <!-- Dynamically populated achievements list -->
                </div>
            </div>
        </div>
    </div>

        <!-- Favorites Pane -->
        <div id="pane-favorites" class="tab-pane">
            <div class="evolution-wrapper">
                <div class="evolution-header" style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                    <div class="evolution-title">
                        <i class="fas fa-heart" style="color: #FF6B6B; filter: drop-shadow(0 0 8px rgba(255, 107, 107, 0.4));"></i>
                        <span>Мое Избранное</span>
                    </div>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
                        <input type="text" id="favoritesSearch" placeholder="Поиск по избранному..." oninput="filterFavorites()" style="background: rgba(255,255,255,0.03); border: 1px solid var(--panel-border); color: #fff; padding: 8px 16px; border-radius: 20px; font-size: 13px; outline: none; transition: border 0.3s; width: 220px;" onfocus="this.style.borderColor='var(--spotify-green)'" onblur="this.style.borderColor='var(--panel-border)'">
                        <button onclick="exportFavorites()" style="background: rgba(0, 245, 255, 0.1); border: 1px solid rgba(0, 245, 255, 0.2); color: var(--accent-cyan); padding: 8px 16px; border-radius: 20px; font-weight: 700; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-family: 'Outfit', sans-serif; transition: all 0.3s;" onmouseover="this.style.background='rgba(0, 245, 255, 0.18)'" onmouseout="this.style.background='rgba(0, 245, 255, 0.1)'">
                            <i class="fas fa-download"></i> Экспорт
                        </button>
                        <button onclick="clearFavorites()" style="background: rgba(255, 107, 107, 0.1); border: 1px solid rgba(255, 107, 107, 0.2); color: #FF6B6B; padding: 8px 16px; border-radius: 20px; font-weight: 700; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-family: 'Outfit', sans-serif; transition: all 0.3s;" onmouseover="this.style.background='rgba(255, 107, 107, 0.18)'" onmouseout="this.style.background='rgba(255, 107, 107, 0.1)'">
                            <i class="fas fa-trash-alt"></i> Сбросить всё
                        </button>
                    </div>
                </div>

                <div id="favorites-count-label" style="font-size: 14px; color: var(--text-muted); margin-bottom: 20px; font-weight: 500;">
                    У вас пока нет избранных треков. Нажмите на сердечко ❤️ на карточке любого трека в архиве!
                </div>

                <div id="favoritesGrid" class="tracks-grid">
                    <!-- Favorites list will be populated dynamically -->
                </div>
            </div>
        </div>
            </div> <!-- End of infinite-canvas -->

            <!-- Spatial HUD (Zoom & Minimap) controls -->
            <div class="spatial-hud-wrapper">
                <!-- Floating Zoom Dashboard pill -->
                <div class="hud-panel zoom-hud-pill">
                    <button class="zoom-btn" onclick="zoomCanvas(-0.1)" title="Отдалить (Zoom Out)"><i class="fas fa-minus"></i></button>
                    <span class="zoom-value-text" id="zoomPercentDisplay" onclick="resetZoomAndCenter()" title="Сбросить масштаб">100%</span>
                    <button class="zoom-btn" onclick="zoomCanvas(0.1)" title="Приблизить (Zoom In)"><i class="fas fa-plus"></i></button>
                </div>

                <!-- Floating Minimap panel -->
                <div class="hud-panel minimap-hud-panel">
                    <div class="minimap-inner" id="minimapContainer">
                        <!-- Representing Island Nodes -->
                        <div class="minimap-island-node" id="mm-node-archive" onclick="switchTab('archive')" title="Общий архив (Центр)" style="left: 50%; top: 50%;"><i class="fas fa-archive"></i></div>
                        <div class="minimap-island-node" id="mm-node-favorites" onclick="switchTab('favorites')" title="Любимая медиатека (Вверх)" style="left: 50%; top: 18%;"><i class="fas fa-heart"></i></div>
                        <div class="minimap-island-node" id="mm-node-vibes-mixer" onclick="switchTab('vibes-mixer')" title="Коктейль вайбов (Влево)" style="left: 18%; top: 50%;"><i class="fas fa-sliders-h"></i></div>
                        <div class="minimap-island-node" id="mm-node-weekly" onclick="switchTab('weekly')" title="Недельные чарты (Вправо)" style="left: 82%; top: 50%;"><i class="fas fa-calendar-week"></i></div>
                        <div class="minimap-island-node" id="mm-node-evolution" onclick="switchTab('evolution')" title="Эволюция артистов (Вниз)" style="left: 50%; top: 82%;"><i class="fas fa-chart-line"></i></div>
                        
                        <!-- Real-time Viewport Frame boundary -->
                        <div class="minimap-camera-viewer" id="minimapCameraViewer"></div>
                    </div>
                </div>
            </div>
        </div> <!-- End of canvas-viewport -->
    </div>

