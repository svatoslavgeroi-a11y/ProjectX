                                        <span style="font-size: 18px; font-weight: 900; color: #cd7f32; text-shadow: 0 0 6px rgba(205, 127, 50, 0.3);">3</span>
                                        <span id="podium-art-3-score" style="font-size: 9px; color: var(--text-muted); font-weight: 600; margin-top: 4px;">—</span>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                        
                        <!-- Top Tracks Podium Section -->
                        <div style="display: flex; flex-direction: column; align-items: center; background: var(--panel-bg); border-radius: 20px; border: 1px solid var(--panel-border); padding: 20px;">
                            <h4 style="font-size: 15px; font-weight: 700; margin-bottom: 25px; display: flex; align-items: center; gap: 8px; color: var(--text-main);">
