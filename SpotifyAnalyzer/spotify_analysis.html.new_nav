                        <div style="font-size: 11px; font-weight: 600; color: var(--spotify-green);">
                            👑 <strong style="color: var(--text-main);">${ach.dominator.artist}</strong> лидирует в чартах с рекордными <strong style="color: #FF6B6B;">${ach.dominator.count} попаданиями</strong> (${ach.dominator.percentage} всех недель)!
                        </div>
                    </div>
                </div>
                
                <!-- Streak Badge -->
                <div class="achievement-badge" style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--panel-border); border-radius: 16px; padding: 20px; display: flex; gap: 16px; align-items: flex-start;">
                    <div style="font-size: 24px; background: rgba(29, 185, 84, 0.1); color: var(--spotify-green); width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"><i class="fas fa-fire"></i></div>
                    <div>
                        <div style="font-weight: 700; font-size: 14px; color: var(--text-main); margin-bottom: 4px;">Железная Стабильность</div>
                        <div style="font-size: 11px; color: var(--text-muted); line-height: 1.4; margin-bottom: 8px;">Максимальная серия непрерывного пребывания артиста в Топ-5.</div>
                        <div style="font-size: 11px; font-weight: 600; color: var(--spotify-green);">
                            🔥 <strong style="color: var(--text-main);">${ach.streak.artist}</strong> держался в топе рекордные <strong style="color: var(--spotify-green);">${ach.streak.streak} недель подряд</strong>!
                        </div>
                    </div>
                </div>
                
                <!-- BPM Badge -->
                <div class="achievement-badge" style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--panel-border); border-radius: 16px; padding: 20px; display: flex; gap: 16px; align-items: flex-start;">
                    <div style="font-size: 24px; background: rgba(0, 245, 255, 0.1); color: #00F5FF; width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"><i class="fas fa-heartbeat"></i></div>
                    <div>
                        <div style="font-weight: 700; font-size: 14px; color: var(--text-main); margin-bottom: 4px;">Звуковой Удар</div>
                        <div style="font-size: 11px; color: var(--text-muted); line-height: 1.4; margin-bottom: 8px;">Самая быстрая и темповая неделя по среднему значению BPM.</div>
                        <div style="font-size: 11px; font-weight: 600; color: var(--spotify-green);">
                            ⚡ Неделя <em>${ach.bpm.week}</em> разогналась до средних <strong style="color: #00F5FF;">${ach.bpm.bpm} BPM</strong>!
                        </div>
                    </div>
                </div>
                
                <!-- Acoustic Badge -->
                <div class="achievement-badge" style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--panel-border); border-radius: 16px; padding: 20px; display: flex; gap: 16px; align-items: flex-start;">
                    <div style="font-size: 24px; background: rgba(255, 215, 0, 0.1); color: #FFD700; width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"><i class="fas fa-guitar"></i></div>
                    <div>
                        <div style="font-weight: 700; font-size: 14px; color: var(--text-main); margin-bottom: 4px;">Ламповый Акустик</div>
                        <div style="font-size: 11px; color: var(--text-muted); line-height: 1.4; margin-bottom: 8px;">Самая теплая, ламповая и акустическая неделя во всем топе.</div>
                        <div style="font-size: 11px; font-weight: 600; color: var(--spotify-green);">
                            🎸 Неделя <em>${ach.acoustic.week}</em> имела рекордные <strong style="color: #FFD700;">${ach.acoustic.acoustic}% акустичности</strong>!
                        </div>
                    </div>
                </div>
            `;
        }

        // --- WEEKLY CHARTS JS LOGIC ---
        function initWeeklyCharts() {
            const selectEl = document.getElementById('weeklySelect');
            const artistsListEl = document.getElementById('weekly-artists-list');
            const tracksListEl = document.getElementById('weekly-tracks-list');

            if (!selectEl || !weeklyTop) return;
            
            // Render dynamic achievements
            renderWeeklyAchievements();

            // Clear existing options
            selectEl.innerHTML = '';

            const weeks = Object.keys(weeklyTop);
            if (weeks.length === 0) {
                // Handle empty weeklyTop state gracefully
                const parentPane = document.getElementById('pane-weekly');
                if (parentPane) {
                    parentPane.innerHTML = `
                        <div style="text-align: center; padding: 50px; color: var(--text-muted); background: var(--card-bg); border-radius: 24px; border: 1px solid var(--border-color); width: 100%;">
                            <i class="fas fa-calendar-times" style="font-size: 50px; color: #ffb703; margin-bottom: 20px;"></i>
                            <h2>Недельные чарты не найдены</h2>
                            <p style="margin-top: 10px;">Добавьте файл <code>weekly_top.csv</code> в корень проекта и перезапустите анализ.</p>
                        </div>
                    `;
                }
                return;
            }

            // Populate select options
            weeks.forEach((week, index) => {
                const opt = document.createElement('option');
                opt.value = week;
                opt.textContent = week;
                selectEl.appendChild(opt);
            });

            // Render first week by default
            updateWeeklyCharts(weeks[0]);

            // Populate showdown options
            const showdownA = document.getElementById('showdownWeekA');
            const showdownB = document.getElementById('showdownWeekB');
            if (showdownA && showdownB) {
                showdownA.innerHTML = '';
                showdownB.innerHTML = '';
                weeks.forEach((week, index) => {
                    const optA = document.createElement('option');
                    optA.value = week;
                    optA.textContent = week;
                    showdownA.appendChild(optA);
                    
                    const optB = document.createElement('option');
                    optB.value = week;
                    optB.textContent = week;
                    showdownB.appendChild(optB);
                });
                
                if (weeks.length > 1) {
                    showdownA.value = weeks[0];
                    showdownB.value = weeks[1];
                } else if (weeks.length > 0) {
                    showdownA.value = weeks[0];
                    showdownB.value = weeks[0];
                }
                updateWeeklyShowdown();
            }

            // --- SCAN UNIQUE ARTISTS FOR TIMELINE DETECTIVE ---
            const allArtistsSet = new Set();
            weeks.forEach(week => {
                const artists = weeklyTop[week].artists || [];
                artists.forEach(art => {
                    const cleanName = art.replace(/\s+-\s+\d+$/, '').trim();
                    if (cleanName && cleanName !== '—') {
                        allArtistsSet.add(cleanName);
                    }
                });
            });

            const uniqueArtists = Array.from(allArtistsSet).sort();

            // Populate artist select for Detective widget
            const artistSelectEl = document.getElementById('detectiveArtistSelect');
            if (artistSelectEl) {
                artistSelectEl.innerHTML = '';
                uniqueArtists.forEach(art => {
                    const opt = document.createElement('option');
                    opt.value = art;
                    opt.textContent = art;
                    artistSelectEl.appendChild(opt);
                });

                // Select the first artist by default and render their timeline
                if (uniqueArtists.length > 0) {
                    artistSelectEl.value = uniqueArtists[0];
                    updateArtistTimeline(uniqueArtists[0]);
                }
            }

            // Render cumulative weekly statistics chart & table
            renderWeeklyStats('artists');
        }

        function updateWeeklyCharts(weekName) {
            const artistsListEl = document.getElementById('weekly-artists-list');
            const tracksListEl = document.getElementById('weekly-tracks-list');

            if (!artistsListEl || !tracksListEl || !weeklyTop || !weeklyTop[weekName]) return;

            const data = weeklyTop[weekName];
            const artists = data.artists || [];
            const tracks = data.tracks || [];

            // Render Top 5 Artists
            artistsListEl.innerHTML = '';
            artists.forEach((artist, idx) => {
                let clickableStyle = "";
                let clickAction = "";

                // Match with canonical artist name (ignoring count suffix)
                const cleanName = artist.replace(/\s+-\s+\d+$/, '').trim().toLowerCase();
                const canonicalName = Object.keys(artistsHistory).find(k => k.toLowerCase() === cleanName);

                if (canonicalName) {
                    clickableStyle = 'style="cursor: pointer; transition: color 0.2s;" class="weekly-list-item clickable-artist"';
                    clickAction = `onclick="focusArtistFromWeekly('${canonicalName}')"`;
                } else {
                    clickableStyle = 'class="weekly-list-item"';
                }

                const artistHtml = `
                    <li ${clickableStyle} ${clickAction}>
                        <div class="weekly-num">${idx + 1}</div>
                        <div class="weekly-name">${artist}</div>
                        ${canonicalName ? '<i class="fas fa-chart-line" style="color: var(--spotify-green); font-size: 13px;" title="Посмотреть эволюцию артиста"></i>' : ''}
                    </li>
                `;
                artistsListEl.insertAdjacentHTML('beforeend', artistHtml);
            });

            // Render Top 5 Tracks
            tracksListEl.innerHTML = '';
            tracks.forEach((track, idx) => {
                const cleanTrackName = track.replace(/\s*-\s*\d+$/, '').trim();
                const trackHtml = `
                    <li class="weekly-list-item" style="cursor: pointer;" onclick="openDetailsByNameAndArtist('${cleanTrackName.replace(/'/g, "\\'")}', '')">
                        <div class="weekly-num">${idx + 1}</div>
                        <div class="weekly-name">${track}</div>
                        <i class="fas fa-search-plus" style="color: var(--accent-cyan); font-size: 13px; opacity: 0.7;" title="Посмотреть подробности трека"></i>
                    </li>
                `;
                tracksListEl.insertAdjacentHTML('beforeend', trackHtml);
            });
        }

        // Helper to focus on an artist and switch to Evolution tab when clicked in weekly top
        function focusArtistFromWeekly(artistName) {
            switchTab('evolution');

            const selectEl = document.getElementById('artistSelect');
            if (selectEl) {
                let found = false;
                for (let i = 0; i < selectEl.options.length; i++) {
                    if (selectEl.options[i].value === artistName) {
                        selectEl.selectedIndex = i;
                        found = true;
                        break;
                    }
                }

                if (found) {
                    const event = new Event('change');
                    selectEl.dispatchEvent(event);

                    switchTab('evolution');
                }
            }
        }

        function getCanonicalArtist(artist) {
            if (!artist || artist === '—') return '';
            let clean = artist.replace(/\s*-\s*\d+$/, '').trim();
            if (clean.toLowerCase().startsWith('ksb ')) return 'KSB Music';
            return clean;
        }

        // Helper to find if any track in weekly tracks belongs to this artist
        function findArtistTrackInWeeklyTop(weeklyTracks, artistName) {
            if (!weeklyTracks || weeklyTracks.length === 0 || !artistName) return null;

            const cleanArtist = getCanonicalArtist(artistName).toLowerCase();

            for (let i = 0; i < weeklyTracks.length; i++) {
                const rawTrack = weeklyTracks[i];
                if (!rawTrack || rawTrack === '—') continue;

                // Clean track name from playcount suffix e.g. "SHINOBI - 3" or "SHINOBI"
                const cleanTrack = rawTrack.replace(/\s*-\s*\d+$/, '').trim().toLowerCase();

                // Search in global tracks list for a match
                const found = tracks.find(t => {
                    const tArt = getCanonicalArtist(t.artist).toLowerCase();
                    const tName = t.name.toLowerCase();

                    // Match artist name and track name (direct or substring)
                    return (tArt === cleanArtist || tArt.includes(cleanArtist) || cleanArtist.includes(tArt)) &&
                        (tName === cleanTrack || tName.includes(cleanTrack) || cleanTrack.includes(tName));
                });

                if (found) {
                    return rawTrack.replace(/\s*-\s*\d+$/, '').trim(); // Return cleaned track name
                }
            }

            // Fuzzy fallback: check if either string contains the other
            for (let i = 0; i < weeklyTracks.length; i++) {
                const rawTrack = weeklyTracks[i];
                if (!rawTrack || rawTrack === '—') continue;

                const cleanTrack = rawTrack.toLowerCase();
                if (cleanTrack.includes(cleanArtist) || cleanArtist.includes(cleanTrack)) {
                    return rawTrack.replace(/\s*-\s*\d+$/, '').trim();
                }
            }

            return null;
        }

        // Timeline Detective for Weekly Charts
        function updateArtistTimeline(artistName) {
            const timelineEl = document.getElementById('detective-timeline');
            const weeksCountEl = document.getElementById('det-weeks-count');
            const bestRankEl = document.getElementById('det-best-rank');
            const frequentTrackEl = document.getElementById('det-frequent-track');

            if (!timelineEl || !weeklyTop || !artistName) return;

            timelineEl.innerHTML = '';

            const weeks = Object.keys(weeklyTop);
            let inTopCount = 0;
            let bestRank = 6;
            const trackFrequencies = {};

            const lowerArtist = getCanonicalArtist(artistName).toLowerCase();

            weeks.forEach((week, wIdx) => {
                const data = weeklyTop[week];
                const artists = data.artists || [];
                const weeklyTracks = data.tracks || [];

                let foundRank = null;

                // Find artist rank in even columns
                for (let i = 0; i < artists.length; i++) {
                    const cleanArt = getCanonicalArtist(artists[i]).toLowerCase();
                    if (cleanArt === lowerArtist) {
                        foundRank = i + 1;
                        break;
                    }
                }

                // Independently find if this artist had a track in the weekly Top-5 tracks!
                let foundTrack = findArtistTrackInWeeklyTop(weeklyTracks, artistName) || "—";

                const node = document.createElement('div');
                node.className = `detective-timeline-node ${foundRank ? 'active' : ''}`;

                let nodeContent = `
                    <div class="detective-node-date">${week.split(' - ')[0]}</div>
                    <div class="detective-node-dot"></div>
                `;

                if (foundRank) {
                    inTopCount++;
                    if (foundRank < bestRank) {
                        bestRank = foundRank;
                    }
                    if (foundTrack && foundTrack !== '—') {
                        trackFrequencies[foundTrack] = (trackFrequencies[foundTrack] || 0) + 1;
                    }

                    nodeContent += `
                        <div class="detective-node-rank">#${foundRank}</div>
                        <div class="detective-node-track" title="${foundTrack}">${foundTrack}</div>
                    `;
                }

                if (wIdx < weeks.length - 1) {
                    nodeContent += `<div class="detective-node-line"></div>`;
                }

                node.innerHTML = nodeContent;
                timelineEl.appendChild(node);
            });

            // Update stats cards
            weeksCountEl.textContent = inTopCount;
            bestRankEl.textContent = bestRank < 6 ? `#${bestRank}` : '—';

            // Find most frequent track
            let mostFreqTrack = '—';
            let maxFreq = 0;
            for (const [track, freq] of Object.entries(trackFrequencies)) {
                if (freq > maxFreq) {
                    maxFreq = freq;
                    mostFreqTrack = track;
                }
            }
            frequentTrackEl.textContent = mostFreqTrack;
            frequentTrackEl.title = mostFreqTrack;
        }

        // Weekly Showdown (Battle of Weeks)
        function calculateWeekVibeMetrics(weekName) {
            if (!weeklyTop || !weeklyTop[weekName]) return null;
            const tracksList = weeklyTop[weekName].tracks || [];
            const artistsList = (weeklyTop[weekName].artists || []).map(a => getCanonicalArtist(a));
            
            let sumBpm = 0, countBpm = 0;
            let sumEnergy = 0, countEnergy = 0;
            let sumDance = 0, countDance = 0;
            let sumValence = 0, countValence = 0;
            
            const cleanTracks = tracksList.map(t => t.replace(/\s*-\s*\d+$/, '').trim());
            
            cleanTracks.forEach(trackName => {
                const dbTrack = (tracks || []).find(t => t.name.toLowerCase() === trackName.toLowerCase());
                if (dbTrack) {
                    if (dbTrack.bpm && dbTrack.bpm !== 'N/A' && !isNaN(dbTrack.bpm)) {
                        sumBpm += parseFloat(dbTrack.bpm);
                        countBpm++;
                    }
                    if (dbTrack.energy !== undefined && dbTrack.energy !== 'N/A' && !isNaN(dbTrack.energy)) {
                        sumEnergy += parseFloat(dbTrack.energy);
                        countEnergy++;
                    }
                    if (dbTrack.danceability !== undefined && dbTrack.danceability !== 'N/A' && !isNaN(dbTrack.danceability)) {
                        sumDance += parseFloat(dbTrack.danceability);
                        countDance++;
                    }
                    if (dbTrack.valence !== undefined && dbTrack.valence !== 'N/A' && !isNaN(dbTrack.valence)) {
                        sumValence += parseFloat(dbTrack.valence);
                        countValence++;
                    }
                }
            });
            
            return {
                bpm: countBpm > 0 ? Math.round(sumBpm / countBpm) : 120,
                energy: countEnergy > 0 ? Math.round((sumEnergy / countEnergy) * 100) : 50,
                danceability: countDance > 0 ? Math.round((sumDance / countDance) * 100) : 50,
                valence: countValence > 0 ? Math.round((sumValence / countValence) * 100) : 50,
                artists: artistsList,
                tracks: cleanTracks
            };
        }

        function updateWeeklyShowdown() {
            const weekA = document.getElementById('showdownWeekA').value;
            const weekB = document.getElementById('showdownWeekB').value;
            
            if (!weekA || !weekB) return;
            
            const metricsA = calculateWeekVibeMetrics(weekA);
            const metricsB = calculateWeekVibeMetrics(weekB);
            
            if (!metricsA || !metricsB) return;
            
            // Render VS Stats
            document.getElementById('showdown-energy-val-a').textContent = metricsA.energy + '%';
            document.getElementById('showdown-energy-val-b').textContent = metricsB.energy + '%';
            document.getElementById('showdown-energy-bar-a').style.width = metricsA.energy + '%';
            document.getElementById('showdown-energy-bar-b').style.width = metricsB.energy + '%';
            
            document.getElementById('showdown-dance-val-a').textContent = metricsA.danceability + '%';
            document.getElementById('showdown-dance-val-b').textContent = metricsB.danceability + '%';
            document.getElementById('showdown-dance-bar-a').style.width = metricsA.danceability + '%';
            document.getElementById('showdown-dance-bar-b').style.width = metricsB.danceability + '%';
            
            document.getElementById('showdown-valence-val-a').textContent = metricsA.valence + '%';
            document.getElementById('showdown-valence-val-b').textContent = metricsB.valence + '%';
            document.getElementById('showdown-valence-bar-a').style.width = metricsA.valence + '%';
            document.getElementById('showdown-valence-bar-b').style.width = metricsB.valence + '%';
            
            document.getElementById('showdown-bpm-val-a').textContent = metricsA.bpm + ' BPM';
            document.getElementById('showdown-bpm-val-b').textContent = metricsB.bpm + ' BPM';
            const bpmPctA = Math.min(100, Math.round((metricsA.bpm / 200) * 100));
            const bpmPctB = Math.min(100, Math.round((metricsB.bpm / 200) * 100));
            document.getElementById('showdown-bpm-bar-a').style.width = bpmPctA + '%';
            document.getElementById('showdown-bpm-bar-b').style.width = bpmPctB + '%';
            
            // Common ground
            const commonArtists = metricsA.artists.filter(art => metricsB.artists.some(bArt => bArt.toLowerCase() === art.toLowerCase()));
            const uniqueCommonArtists = [...new Set(commonArtists)];
            
            const commonTracks = metricsA.tracks.filter(track => metricsB.tracks.some(bTrack => bTrack.toLowerCase() === track.toLowerCase()));
            
            const commonEl = document.getElementById('showdown-common-ground');
            if (uniqueCommonArtists.length === 0 && commonTracks.length === 0) {
                commonEl.innerHTML = `<span style="color: var(--text-muted); font-size: 13px;">Разные миры! Общих артистов и треков на этих неделях нет.</span>`;
            } else {
                let html = '';
                if (uniqueCommonArtists.length > 0) {
                    html += `<div style="font-size: 13px; color: var(--text-main); margin-bottom: 5px;">👥 <strong>Общие артисты:</strong> <span style="color: var(--spotify-green); font-weight: 600;">${uniqueCommonArtists.join(', ')}</span></div>`;
                }
                if (commonTracks.length > 0) {
                    html += `<div style="font-size: 13px; color: var(--text-main);">🎵 <strong>Общие песни:</strong> <span style="color: var(--accent-cyan); font-style: italic; font-weight: 600;">${commonTracks.join(', ')}</span></div>`;
                }
                commonEl.innerHTML = html;
            }
            
            // Witty Verdict
            const verdictEl = document.getElementById('showdown-verdict');
            let verdict = '';
            if (metricsA.energy > metricsB.energy + 15) {
                verdict += `💥 <strong>${weekA}</strong> была значительно более взрывной и драйвовой! `;
            } else if (metricsB.energy > metricsA.energy + 15) {
                verdict += `💥 <strong>${weekB}</strong> заряжала драйвом намного сильнее! `;
            } else {
                verdict += `⚖️ Обе недели держали похожий уровень энергии. `;
            }
            
            if (metricsA.valence > metricsB.valence + 15) {
                verdict += `☀️ На неделе <strong>${weekA}</strong> преобладало светлое, позитивное настроение, в то время как <strong>${weekB}</strong> звучала более меланхолично и глубоко.`;
            } else if (metricsB.valence > metricsA.valence + 15) {
                verdict += `☀️ Неделя <strong>${weekB}</strong> принесла больше солнечного вайба, а <strong>${weekA}</strong> склонялась к более минорным тонам.`;
            } else {
                verdict += `🎵 Эмоциональная окраска и настроение музыки были очень близки.`;
            }
            
            verdictEl.innerHTML = verdict;
        }

        // 🛠️ Grab & Drag (Figma-style) Canvas Panning and Smart Snapping Engine
        let isDragging = false;
        let startX, startY;
        let startCanvasX, startCanvasY;

        function initCanvasDrag() {
            const canvas = document.getElementById('infinite-canvas');
            const viewport = document.getElementById('canvas-viewport');
            if (!canvas || !viewport) return;

            // Precision mouse-wheel zooming
            viewport.addEventListener('wheel', (e) => {
                e.preventDefault();
                const zoomIntensity = 0.05;
                let nextScale = canvasScale;
                
                if (e.deltaY < 0) {
                    // Zoom In
                    nextScale = Math.min(1.2, canvasScale + zoomIntensity);
                } else {
                    // Zoom Out
                    nextScale = Math.max(0.4, canvasScale - zoomIntensity);
                }
                
                if (nextScale !== canvasScale) {
                    canvasScale = nextScale;
                    updateCanvasCamera();
                }
            }, { passive: false });

            // Double click empty space to reset zoom & center
            viewport.addEventListener('dblclick', (e) => {
                if (e.target.closest('button, a, input, select, textarea, canvas, .track-card, .metric-card, .weekly-card, .weekly-timeline-wrap, .radar-details-modal, .hud-panel')) return;
                resetZoomAndCenter();
            });

            viewport.addEventListener('mousedown', (e) => {
                // Ignore drags starting inside scrollable containers or inputs/buttons/cards
                if (e.target.closest('button, a, input, select, textarea, canvas, .track-card, .metric-card, .weekly-card, .weekly-timeline-wrap, .radar-details-modal, .hud-panel')) return;
                
                // Smart Scrollbar Clicks Detection: Ignore drags starting on scrollbars of panels or sub-elements
                let current = e.target;
                while (current && current !== viewport) {
                    if (current.scrollHeight > current.clientHeight) {
                        const rect = current.getBoundingClientRect();
                        const clickX = e.clientX - rect.left;
                        if (clickX >= current.clientWidth) {
                            return; // Clicked on a vertical scrollbar!
                        }
                    }
                    current = current.parentElement;
                }
                
                isDragging = true;
                viewport.style.cursor = 'grabbing';
                canvas.classList.add('dragging');
                
                startX = e.clientX;
                startY = e.clientY;
                startCanvasX = canvasX;
                startCanvasY = canvasY;
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                
                const rect = viewport.getBoundingClientRect();
                const deltaX = (e.clientX - startX) * (100 / rect.width);
                const deltaY = (e.clientY - startY) * (100 / rect.height);
                
                // Move opposite to drag direction, scaled for precise 1:1 cursor locking
                canvasX = startCanvasX - (deltaX / canvasScale);
                canvasY = startCanvasY - (deltaY / canvasScale);
                
                // Keep within reasonable boundaries of our 5 islands
                canvasX = Math.max(-160, Math.min(160, canvasX));
                canvasY = Math.max(-160, Math.min(160, canvasY));
                
                updateCanvasCamera();
            });

            window.addEventListener('mouseup', () => {
                if (!isDragging) return;
                isDragging = false;
                viewport.style.cursor = 'grab';
                canvas.classList.remove('dragging');
                
                snapToNearestPane();
            });
        }

        function snapToNearestPane() {
            let nearestId = 'archive';
            let minDistance = Infinity;

            for (const [id, coords] of Object.entries(paneCoordinates)) {
                const dist = Math.hypot(canvasX - coords.x, canvasY - coords.y);
                if (dist < minDistance) {
                    minDistance = dist;
                    nearestId = id;
                }
            }

            // Always snap cleanly to the nearest page!
            switchTab(nearestId);
        }

        // Initialize weekly charts & canvas drag engine
        initWeeklyCharts();
        initCanvasDrag();

        // Initial setup for HUD cameras and default active node
        updateCanvasCamera();
        const defaultNode = document.getElementById('mm-node-archive');
        if (defaultNode) defaultNode.classList.add('active');
    </script>
</body>

</html>