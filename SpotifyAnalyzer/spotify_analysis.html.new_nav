 {"bpm": 55.7, "energy": 37.4, "valence": 34.0}, "Primus": {"bpm": 63.7, "energy": 89.2, "valence": 53.8}, "Queen": {"bpm": 52.1, "energy": 57.7, "valence": 52.7}, "Radiohead": {"bpm": 61.2, "energy": 55.8, "valence": 31.2}, "RHCP": {"bpm": 50.0, "energy": 50.0, "valence": 50.0}, "Richard Cheese": {"bpm": 66.7, "energy": 69.3, "valence": 52.0}, "Rob Zombie": {"bpm": 57.0, "energy": 95.5, "valence": 57.0}, "Robert Johnson": {"bpm": 60.0, "energy": 50.0, "valence": 15.0}, "Royal Blood": {"bpm": 60.3, "energy": 85.7, "valence": 66.7}, "SALUKI": {"bpm": 60.0, "energy": 50.0, "valence": 37.3}, "Scorpions": {"bpm": 63.3, "energy": 66.3, "valence": 33.3}, "Serj Tankian": {"bpm": 73.6, "energy": 92.0, "valence": 30.0}, "SLAVA MARLOW": {"bpm": 60.0, "energy": 50.0, "valence": 41.2}, "Slipknot": {"bpm": 57.5, "energy": 92.8, "valence": 24.0}, "SOAD": {"bpm": 50.0, "energy": 50.0, "valence": 50.0}, "SQWOZ BAB": {"bpm": 60.0, "energy": 50.0, "valence": 58.2}, "Stevie Wonder": {"bpm": 55.2, "energy": 54.7, "valence": 81.7}, "Stromae": {"bpm": 78.3, "energy": 59.3, "valence": 67.8}, "Taylor Swift": {"bpm": 63.3, "energy": 52.6, "valence": 65.0}, "The Beatles": {"bpm": 60.0, "energy": 46.7, "valence": 64.7}, "The Neighbourhood": {"bpm": 62.0, "energy": 81.0, "valence": 40.0}, "The Notorious B.I.G.": {"bpm": 44.6, "energy": 63.2, "valence": 63.5}, "The Prodigy": {"bpm": 66.4, "energy": 90.8, "valence": 38.6}, "The Weeknd": {"bpm": 67.4, "energy": 64.5, "valence": 41.6}, "Twenty One Pilots": {"bpm": 60.5, "energy": 67.3, "valence": 48.6}, "Tyler, The Creator": {"bpm": 57.9, "energy": 59.5, "valence": 36.7}, "Vacio": {"bpm": 50.0, "energy": 50.0, "valence": 50.0}, "Yanix": {"bpm": 60.0, "energy": 50.0, "valence": 33.6}, "Андрей Катиков": {"bpm": 60.0, "energy": 50.0, "valence": 61.5}, "Антоха МС": {"bpm": 60.0, "energy": 50.0, "valence": 59.2}, "Валентин Дядька": {"bpm": 60.0, "energy": 50.0, "valence": 40.2}, "Валентин Стрыкало": {"bpm": 60.0, "energy": 50.0, "valence": 52.0}, "Гряз