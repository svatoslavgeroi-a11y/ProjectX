                                    <div style="width: 42px; height: 42px; border-radius: 50%; background: var(--panel-bg); border: 2px solid #c0c0c0; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; box-shadow: 0 0 10px rgba(192, 192, 192, 0.2);">
